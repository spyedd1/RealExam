@model IEnumerable<GFLHApp.Models.BasketProducts>
@{
    ViewData["Title"] = "Index";
    var basketId = Model.FirstOrDefault()?.BasketId;
}
@if (!Model.Any())
{
    <div align="center">
        <br />
        <h3>Your basket is empty</h3>
        <p>You need to add some products to your basket.</p>
        <br />
        <a asp-controller="Products" asp-action="Index">&#8592; Continue Shopping</a>
    </div>
}
else
{
    <div style="max-width:800px; margin:auto;">
        <h2>Your Basket</h2>
        <hr />
        <table border="1" cellpadding="12" cellspacing="0" width="100%">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th align="left">Product</th>
                    <th align="left">Price</th>
                    <th align="left">Qty</th>
                    <th align="left">Total</th>
                    <th align="left">Allergens</th>
                    <th align="left">Action</th>
                </tr>
            </thead>
            <tbody>
				@foreach (var item in Model) // Model is already filtered to current basket's products in controller, so no need for extra check here
                {
                    <tr>
                        <td><strong>@item.Products.ItemName</strong></td>
                        <td>£@item.Products.ItemPrice.ToString("0.00")</td>
                        <td align="center">@item.ProductQuantity</td>
                        <td>£@((item.Products.ItemPrice * item.ProductQuantity).ToString("0.00"))</td>
                        <td>
							@if (string.IsNullOrWhiteSpace(item.Products.Allergens)) // If no allergens declared, show green checkmark and "None declared"
							{
                                <span style="color:green;">&#10003; None declared</span>
                            }
							else // If allergens are declared, show warning symbol and allergen list in amber
							{
                                <span style="color:#856404;">&#9888; @item.Products.Allergens</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="BasketProducts" asp-action="Delete" asp-route-id="@item.BasketProductsId"
                               style="color:red;">
                                Remove
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <br />

        <!-- Allergen Notice - Required under Natasha's Law -->
        <div style="background:#fff3cd; border:1px solid #ffc107; padding:12px 16px; border-radius:4px; margin-bottom:16px; font-size:14px;">
            &#9888;&#65039; <strong>Allergen Notice:</strong> Allergen information is displayed above for each product.
            If you have any concerns about allergens, please contact the producer before purchasing.
            Allergen information is provided in accordance with Natasha's Law.
        </div>

        <table border="1" cellpadding="12" cellspacing="0" width="350">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th colspan="2" align="left">Order Summary</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Subtotal</td>
                    <td>£@(((decimal)ViewBag.Subtotal).ToString("0.00"))</td>
                </tr>
                <tr>
                    <td>Loyalty Discount</td>
                    <td style="color:green;">
                        - £@(((decimal)ViewBag.Discount).ToString("0.00"))
                    </td>
                </tr>
            </tbody>
            <tfoot>
                <tr bgcolor="#f0f0f0">
                    <td><strong>Total</strong></td>
                    <td><strong>£@(((decimal)ViewBag.Total).ToString("0.00"))</strong></td>
                </tr>
            </tfoot>
        </table>

        @if (ViewBag.Discount > 0)
        {
            <br />
            <p style="color:green;"><strong>Congratulations!</strong> Your loyalty discount has been applied.</p>
        }

        <br />

        <a asp-controller="Orders" asp-action="Create" asp-route-basketId="@basketId"
           style="color:white; background-color:#333; padding:10px 20px; text-decoration:none; display:inline-block;">
            Proceed to Checkout
        </a>
        &nbsp;
        <a asp-controller="Products" asp-action="Index">Continue Shopping</a>
    </div>
}