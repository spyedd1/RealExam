@model IEnumerable<GFLHApp.Models.Products>
@{
    ViewData["Title"] = "Producer Dashboard";
}
<div style="max-width:800px; margin:auto;">
    <h1>Producer Dashboard</h1>
    <hr />
    <h2>Overview</h2>
    <table border="1" cellpadding="12" cellspacing="0" width="350">
        <thead bgcolor="#333" style="color:white;">
            <tr>
                <th align="left">Metric</th>
                <th align="left">Value</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong>Total Products</strong></td>
                <td>@ViewBag.TotalProducts</td>
            </tr>
            <tr>
                <td><strong>Low Stock Products</strong></td>
                <td>@ViewBag.LowStockCount</td>
            </tr>
            <tr>
                <td><strong>Total Stock Units</strong></td>
                <td>@ViewBag.TotalStock</td>
            </tr>
        </tbody>
    </table>

    <br />
    <h2>Products</h2>
    <hr />

    @if (!Model.Any())
    {
        <p>You do not have any products yet.</p>
    }
    else
    {
        <table border="1" cellpadding="12" cellspacing="0" width="100%">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th align="left">Product</th>
                    <th align="left">Price</th>
                    <th align="left">Stock</th>
                    <th align="left">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Take(5))
                {
                    <tr>
                        <td><strong>@item.ItemName</strong></td>
                        <td>£@item.ItemPrice.ToString("0.00")</td>
                        <td>@item.QuantityInStock</td>
                        <td>
                            <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.ProductsId">Edit</a>
                            &nbsp;|&nbsp;
                            <a asp-controller="Products" asp-action="Delete" asp-route-id="@item.ProductsId"
                               style="color:red;">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <br />
        <a asp-controller="Products" asp-action="Index"
           style="color:white; background-color:#333; padding:10px 20px; text-decoration:none; display:inline-block;">
            View All Products &#8594;
        </a>
    }

    <br /><br />
    <h2>Recent Orders</h2>
    <hr />

	@if (ViewBag.ProducerOrders == null || ((List<GFLHApp.Models.ProducerOrders>)ViewBag.ProducerOrders).Count == 0) // Check if there are any orders for this producer
    {
        <p>No recent orders found.</p>
    }
	else // If there are orders, show the 5 most recent ones with their details and actions
    {
        <table border="1" cellpadding="12" cellspacing="0" width="100%">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th align="left">Order ID</th>
                    <th align="left">Order Date</th>
                    <th align="left">Your Products</th>
                    <th align="left">Your Subtotal</th>
                    <th align="left">Status</th>
                    <th align="left">Actions</th>
                </tr>
            </thead>
            <tbody>
				@foreach (var producerOrder in ((List<GFLHApp.Models.ProducerOrders>)ViewBag.ProducerOrders).Take(5)) // Show only the 5 most recent orders
                { 
                    <tr>
                        <td>#@producerOrder.Orders.OrdersId</td> 
                        <td>@producerOrder.Orders.OrderDate</td>
                        <td>
							@foreach (var orderProduct in producerOrder.OrderProducts) // List all products in this order slice
							{
                                <div>@orderProduct.Products.ItemName x @orderProduct.ProductQuantity</div>
                            }
                        </td>
						<td>£@producerOrder.ProducerSubtotal.ToString("0.00")</td> 
                        <td>
							@if (producerOrder.TrackingStatus == "Cancelled") // Highlight cancelled orders in red, accepted in green, pending in orange
							{
                                <span style="color:red;"><strong>Cancelled</strong></span>
                            }
							else if (producerOrder.TrackingStatus == "Accepted") // Highlight accepted orders in green
							{
                                <span style="color:green;"><strong>Accepted</strong></span>
                            }
							else if (producerOrder.TrackingStatus == "Pending") // Highlight pending orders in orange
							{
                                <span style="color:orange;"><strong>Pending</strong></span>
                            }
							else // For any other status, just show it without special styling
							{
                                <span>@producerOrder.TrackingStatus</span>
                            }
                        </td>
                        <td>
							@if (producerOrder.TrackingStatus == "Pending")  // Only show Accept/Cancel options for pending orders
							{  
                               <!-- Accept button — POST form so it goes through the AcceptProducerOrder action -->  
                               <form asp-controller="ProducerDashboard"  
                                     asp-action="AcceptProducerOrder"  
                                     asp-route-id="@producerOrder.ProducerOrdersId"  
                                     method="post"  
                                     style="display:inline;"  
                                     onsubmit="return confirm('Accept this order slice?')">  
                                   @Html.AntiForgeryToken()  
                                   <button type="submit"  
                                           style="background-color:green; color:white; padding:6px 14px; border:none; cursor:pointer;">  
                                       Accept &#10003;  
                                   </button>  
                               </form>  
                               <span>&nbsp;|&nbsp;</span>  
                               <!-- Cancel link — goes to CancelProducerOrder GET confirmation page -->  
                               <a asp-controller="ProducerDashboard"  
                                  asp-action="CancelProducerOrder"  
                                  asp-route-id="@producerOrder.ProducerOrdersId"  
                                  style="color:red;">  
                                   Cancel &#10007;  
                               </a>  
                            }
							else if (producerOrder.TrackingStatus == "Accepted")   // If already accepted, only show the option to cancel (which goes to the GET confirmation page)
							{  
                               <!-- Once accepted only allow cancellation via the detail page -->  
                               <a asp-controller="ProducerDashboard"  
                                  asp-action="CancelProducerOrder"  
                                  asp-route-id="@producerOrder.ProducerOrdersId"  
                                  style="color:red;">  
                                   Cancel &#10007;  
                               </a>  
                            }
							else  // For cancelled or any other status, just show that no actions are available
							{  
                               <span style="color:grey;">No actions available</span>  
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <br />
        <a asp-controller="ProducerDashboard" asp-action="AllOrders"
           style="color:white; background-color:#333; padding:10px 20px; text-decoration:none; display:inline-block;">
            View All Orders &#8594;
        </a>
    }

    <br /><br />
</div>