 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model ExternalLoginsModel
@{
    ViewData["Title"] = "External Logins"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins; // Reads view data supplied by the controller.
}

 @* ----- Status Messages ----- *@
<partial name="_StatusMessage" for="StatusMessage" /> @* Renders a shared partial view here. *@

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Security</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">External Logins</h2> @* Renders a heading for this page section. *@
 @* ----- Conditional Rendering ----- *@
<p class="pw-manage-content__sub">Link third-party accounts to sign in to Greenfield without a password.</p> @* Renders paragraph text for the user. *@

 @* ----- Loop Rendering ----- *@
@if (Model.CurrentLogins?.Count > 0) @* Conditionally renders this block when the check passes. *@
{
 @* ----- Page Header ----- *@
    <h3 style="font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--text);margin:0 0 14px;">Linked accounts</h3> @* Renders a heading for this page section. *@
    <div style="max-width:560px;margin-bottom:32px;"> @* Starts a layout container for this section. *@
 @* ----- Loop Rendering ----- *@
        @foreach (var login in Model.CurrentLogins) @* Loops through the collection and renders each item. *@
        {
 @* ----- Styling Section ----- *@
            <div class="pw-login-provider"> @* Starts a layout container for this section. *@
                <span class="pw-login-provider__name" id="@($"login-provider-{login.LoginProvider}")"> @* Renders inline text or badge content. *@
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> @* Renders part of the identity page markup. *@
                    @login.ProviderDisplayName @* Outputs Razor data or executes Razor logic. *@
                </span> @* Closes the matching HTML element. *@
 @* ----- Loop Rendering ----- *@
                @if (Model.ShowRemoveButton) @* Conditionally renders this block when the check passes. *@
                {
 @* ----- Form Setup ----- *@
                    <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post" style="display:inline;"> @* Starts the form that submits this page's user input. *@
 @* ----- Form Fields ----- *@
                        <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" /> @* Binds this input to the matching model property. *@
                        <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" /> @* Binds this input to the matching model property. *@
 @* ----- Form Actions ----- *@
                        <button type="submit" class="pw-btn pw-btn--ghost pw-btn--sm" title="Remove @login.ProviderDisplayName login"> @* Renders a button for the user action. *@
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> @* Renders part of the identity page markup. *@
                            Remove @* Renders part of the identity page markup. *@
                        </button> @* Closes the matching HTML element. *@
                    </form> @* Closes the form after its fields and actions. *@
                }
            </div> @* Closes the matching HTML element. *@
        }
    </div> @* Closes the matching HTML element. *@
}

 @* ----- Loop Rendering ----- *@
@if (Model.OtherLogins?.Count > 0) @* Conditionally renders this block when the check passes. *@
{
 @* ----- Styling Section ----- *@
    <hr class="pw-manage-divider" /> @* Renders part of the identity page markup. *@
 @* ----- Page Header ----- *@
    <h3 style="font-family:var(--font-display);font-size:18px;font-weight:700;color:var(--text);margin:0 0 6px;">Add another login</h3> @* Renders a heading for this page section. *@
    <p style="font-size:14px;color:var(--text-muted);margin:0 0 20px;">Link another service to make signing in even easier.</p> @* Renders paragraph text for the user. *@
 @* ----- Form Setup ----- *@
    <form id="link-login-form" asp-page-handler="LinkLogin" method="post"> @* Starts the form that submits this page's user input. *@
 @* ----- Styling Section ----- *@
        <div id="socialLoginList" class="pw-manage-actions"> @* Starts a layout container for this section. *@
 @* ----- Loop Rendering ----- *@
            @foreach (var provider in Model.OtherLogins) @* Loops through the collection and renders each item. *@
            {
 @* ----- Form Actions ----- *@
                <button id="@($"link-login-button-{provider.Name}")" type="submit" class="pw-btn pw-btn--ghost pw-btn--sm" name="provider" value="@provider.Name" title="Link your @provider.DisplayName account"> @* Renders a button for the user action. *@
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> @* Renders part of the identity page markup. *@
                    @provider.DisplayName @* Outputs Razor data or executes Razor logic. *@
                </button> @* Closes the matching HTML element. *@
            }
        </div> @* Closes the matching HTML element. *@
    </form> @* Closes the form after its fields and actions. *@
}

 @* ----- Loop Rendering ----- *@
@if ((Model.CurrentLogins == null || Model.CurrentLogins.Count == 0) && (Model.OtherLogins == null || Model.OtherLogins.Count == 0)) @* Conditionally renders this block when the check passes. *@
{
 @* ----- Styling Section ----- *@
    <div class="pw-manage-info-block"> @* Starts a layout container for this section. *@
        No external login providers are currently configured for this application. @* Renders part of the identity page markup. *@
    </div> @* Closes the matching HTML element. *@
}
