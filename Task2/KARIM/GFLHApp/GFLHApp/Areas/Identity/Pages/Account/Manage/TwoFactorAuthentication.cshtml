@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;

    var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
    var canTrack = consentFeature?.CanTrack ?? true;
}

<partial name="_StatusMessage" for="StatusMessage" />

<span class="pw-manage-content__eyebrow">Security</span>
<h2 class="pw-manage-content__title">Two-Factor Authentication</h2>
<p class="pw-manage-content__sub">Add an extra layer of protection by requiring a code alongside your password.</p>

@if (canTrack)
{
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;flex-wrap:wrap;">
        @if (Model.Is2faEnabled)
        {
            <span class="pw-2fa-status pw-2fa-status--on">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                2FA Enabled
            </span>
        }
        else
        {
            <span class="pw-2fa-status pw-2fa-status--off">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                2FA Disabled
            </span>
        }
    </div>

    @if (Model.Is2faEnabled)
    {
        @if (Model.RecoveryCodesLeft == 0)
        {
            <div class="pw-manage-alert pw-manage-alert--danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div><strong>You have no recovery codes left.</strong><br />You must <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">generate a new set of recovery codes</a> before you can log in with a recovery code.</div>
            </div>
        }
        else if (Model.RecoveryCodesLeft == 1)
        {
            <div class="pw-manage-alert pw-manage-alert--danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <div><strong>You have 1 recovery code left.</strong> <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">Generate new codes</a> now.</div>
            </div>
        }
        else if (Model.RecoveryCodesLeft <= 3)
        {
            <div class="pw-manage-alert pw-manage-alert--warning" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <div><strong>Only @Model.RecoveryCodesLeft recovery codes remaining.</strong> Consider <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">generating a new set</a> soon.</div>
            </div>
        }

        <div class="pw-manage-actions">
            @if (Model.IsMachineRemembered)
            {
                <form method="post" style="display:inline;">
                    <button type="submit" class="pw-btn pw-btn--ghost pw-btn--sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        Forget this browser
                    </button>
                </form>
            }
            <a asp-page="./Disable2fa" class="pw-btn pw-btn--ghost pw-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9.09" y1="9" x2="14.91" y2="9"/><line x1="12" y1="12" x2="12" y2="15"/></svg>
                Disable 2FA
            </a>
            <a asp-page="./GenerateRecoveryCodes" class="pw-btn pw-btn--ghost pw-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Reset recovery codes
            </a>
        </div>
    }

    <hr class="pw-manage-divider" />

    <h3 style="font-family:var(--font-display);font-size:19px;font-weight:700;margin:0 0 16px;color:var(--text);">Authenticator App</h3>

    <div class="pw-manage-actions">
        @if (!Model.HasAuthenticator)
        {
            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="pw-btn pw-btn--primary pw-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
                Add authenticator app
            </a>
        }
        else
        {
            <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="pw-btn pw-btn--primary pw-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
                Set up authenticator app
            </a>
            <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="pw-btn pw-btn--ghost pw-btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
                Reset authenticator
            </a>
        }
    </div>
}
else
{
    <div class="pw-manage-alert pw-manage-alert--danger" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div><strong>Privacy and cookie policy have not been accepted.</strong><br />You must accept the policy before you can enable two-factor authentication.</div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
