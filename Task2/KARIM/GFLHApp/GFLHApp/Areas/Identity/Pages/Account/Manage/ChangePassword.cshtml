 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = ManageNavPages.ChangePassword; // Reads view data supplied by the controller.
}

 @* ----- Status Messages ----- *@
<partial name="_StatusMessage" for="StatusMessage" /> @* Renders a shared partial view here. *@

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Security</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">Change Password</h2> @* Renders a heading for this page section. *@
 @* ----- Conditional Rendering ----- *@
<p class="pw-manage-content__sub">Choose a strong password to keep your account safe.</p> @* Renders paragraph text for the user. *@

 @* ----- Form Setup ----- *@
<form id="change-password-form" method="post" class="pw-manage-form" style="max-width:480px;"> @* Starts the form that submits this page's user input. *@
 @* ----- Status Messages ----- *@
    <div asp-validation-summary="ModelOnly" class="pw-manage-alert pw-manage-alert--danger" role="alert"></div> @* Shows page-level validation messages. *@

 @* ----- Styling Section ----- *@
    <div class="form-floating mb-3"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Current password" /> @* Binds this input to the matching model property. *@
        <label asp-for="Input.OldPassword">Current password</label> @* Renders a label tied to the model field. *@
 @* ----- Status Messages ----- *@
        <span asp-validation-for="Input.OldPassword" class="text-danger"></span> @* Shows validation feedback for this model field. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
    <div class="form-floating mb-3"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" /> @* Binds this input to the matching model property. *@
        <label asp-for="Input.NewPassword">New password</label> @* Renders a label tied to the model field. *@
 @* ----- Status Messages ----- *@
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span> @* Shows validation feedback for this model field. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
    <div class="form-floating mb-4"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" /> @* Binds this input to the matching model property. *@
        <label asp-for="Input.ConfirmPassword">Confirm new password</label> @* Renders a label tied to the model field. *@
 @* ----- Status Messages ----- *@
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span> @* Shows validation feedback for this model field. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Form Actions ----- *@
    <button type="submit" class="pw-btn pw-btn--primary pw-btn--md" style="width:100%;"> @* Renders a button for the user action. *@
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> @* Renders part of the identity page markup. *@
        Update password @* Renders part of the identity page markup. *@
    </button> @* Closes the matching HTML element. *@
</form> @* Closes the form after its fields and actions. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    <partial name="_ValidationScriptsPartial" /> @* Renders a shared partial view here. *@
}
