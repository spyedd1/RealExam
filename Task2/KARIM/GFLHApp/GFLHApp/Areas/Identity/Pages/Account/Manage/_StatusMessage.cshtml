 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model string

 @* ----- Conditional Rendering ----- *@
@if (!String.IsNullOrEmpty(Model)) @* Conditionally renders this block when the check passes. *@
{
 @* ----- Loop Rendering ----- *@
    var isError = Model.StartsWith("Error"); @* Displays or uses data from the identity model. *@
 @* ----- Status Messages ----- *@
    var alertClass = isError ? "pw-manage-alert--danger" : "pw-manage-alert--success"; @* Renders part of the identity page markup. *@
    <div class="pw-manage-alert @alertClass" role="alert"> @* Starts a layout container for this section. *@
 @* ----- Conditional Rendering ----- *@
        @if (isError) @* Conditionally renders this block when the check passes. *@
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> @* Renders part of the identity page markup. *@
        }
        else @* Renders the fallback branch for the previous condition. *@
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> @* Renders part of the identity page markup. *@
        }
        <span>@Model</span> @* Renders inline text or badge content. *@
 @* ----- Status Messages ----- *@
        <button type="button" class="pw-manage-alert__dismiss" aria-label="Dismiss" onclick="this.parentElement.remove()"> @* Renders a button for the user action. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> @* Renders part of the identity page markup. *@
        </button> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@
}
