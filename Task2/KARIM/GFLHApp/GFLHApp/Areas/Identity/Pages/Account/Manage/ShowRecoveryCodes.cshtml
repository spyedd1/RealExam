 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = "TwoFactorAuthentication"; // Reads view data supplied by the controller.
}

 @* ----- Status Messages ----- *@
<partial name="_StatusMessage" for="StatusMessage" /> @* Renders a shared partial view here. *@

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Security · Two-Factor Auth</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">Your Recovery Codes</h2> @* Renders a heading for this page section. *@
 @* ----- Identity Account ----- *@
<p class="pw-manage-content__sub">Each code can be used once to sign in if you lose access to your authenticator app.</p> @* Renders paragraph text for the user. *@

 @* ----- Status Messages ----- *@
<div class="pw-manage-alert pw-manage-alert--warning" role="alert"> @* Starts a layout container for this section. *@
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> @* Renders part of the identity page markup. *@
 @* ----- Form Actions ----- *@
    <div><strong>Save these codes somewhere safe.</strong> They won't be shown again. If you lose your device without these codes, you will lose access to your account.</div> @* Starts a layout container for this section. *@
</div> @* Closes the matching HTML element. *@

 @* ----- Form Fields ----- *@
<div class="pw-recovery-grid" role="list" aria-label="Recovery codes"> @* Starts a layout container for this section. *@
 @* ----- Loop Rendering ----- *@
    @foreach (var code in Model.RecoveryCodes) @* Loops through the collection and renders each item. *@
    {
 @* ----- Identity Account ----- *@
        <code class="pw-recovery-code" role="listitem">@code</code> @* Renders part of the identity page markup. *@
    }
</div> @* Closes the matching HTML element. *@

<div style="margin-top:24px;"> @* Starts a layout container for this section. *@
 @* ----- Form Setup ----- *@
    <a asp-page="./TwoFactorAuthentication" class="pw-btn pw-btn--ghost pw-btn--sm"> @* Builds a link or form target using MVC routing. *@
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg> @* Renders part of the identity page markup. *@
        Back to 2FA settings @* Renders part of the identity page markup. *@
    </a> @* Closes the matching HTML element. *@
</div> @* Closes the matching HTML element. *@
