 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model IEnumerable<GFLHApp.Models.Producers>
 @* ----- Imports and Services ----- *@
 @* Imports a namespace for this Razor file. *@
@using System.Linq
@{
 // ----- Page Model Setup -----
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Chooses the layout used to render this page.
    ViewData["Title"] = "Producers"; // Sets the browser and page title for this view.
    ViewData["AdminSection"] = "producers"; // Reads view data supplied by the controller.
    string search = ViewBag.Search ?? ""; // Reads view data supplied by the controller.
}



 @* ----- Form Setup ----- *@
<form method="get" action="/AdminDashboard/Producers"> @* Starts the form that submits this page's user input. *@
 @* ----- Search and Filters ----- *@
    <div class="adm-filters"> @* Starts a layout container for this section. *@
        <div class="adm-filter-group"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <label>Search</label> @* Renders text identifying a form field. *@
            <input name="search" class="adm-filter-input" value="@search" placeholder="Name or email…" style="width:260px;" /> @* Renders a user input field. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
        <button type="submit" class="adm-btn-filter"><i data-lucide="search" style="width:13px;height:13px;" aria-hidden="true"></i>Search</button> @* Renders a button for the user action. *@
 @* ----- Navigation ----- *@
        <button asp-controller="Producers" asp-action="Create" class="adm-btn-filter"><i  style="width:13px;height:13px;" aria-hidden="true"></i>Create Producer</button> @* Builds a link or form target using MVC routing. *@
 @* ----- Search and Filters ----- *@
        @if (!string.IsNullOrEmpty(search)) @* Conditionally renders this block when the check passes. *@
        {
 @* ----- Form Actions ----- *@
            <a href="/AdminDashboard/Producers" class="adm-btn-clear"><i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>Clear</a> @* Renders a navigation link or action link. *@
        }
    </div> @* Closes the matching HTML element. *@
</form> @* Closes the form after its fields and actions. *@

 @* ----- Card Layout ----- *@
<div class="adm-card"> @* Starts a layout container for this section. *@
 @* ----- Loop Rendering ----- *@
    <div class="adm-results-info">@Model.Count() producer@(Model.Count() == 1 ? "" : "s") found</div> @* Starts a layout container for this section. *@

    @if (Model.Any()) @* Conditionally renders this block when the check passes. *@
    {
        <div style="overflow-x:auto;"> @* Starts a layout container for this section. *@
 @* ----- Table Layout ----- *@
            <table class="adm-table"> @* Starts a table for structured row data. *@
                <thead> @* Starts the table header section. *@
                    <tr> @* Starts one table row. *@
                        <th></th> @* Renders a table header cell. *@
                        <th>Producer</th> @* Renders a table header cell. *@
                        <th>Email</th> @* Renders a table header cell. *@
                        <th>VAT</th> @* Renders a table header cell. *@
                        <th>Products</th> @* Renders a table header cell. *@
                        <th>Total orders</th> @* Renders a table header cell. *@
                        <th>Revenue</th> @* Renders a table header cell. *@
                        <th>Actions</th> @* Renders a table header cell. *@
                    </tr> @* Closes the matching HTML element. *@
                </thead> @* Closes the matching HTML element. *@
                <tbody> @* Starts the table body section. *@
 @* ----- Loop Rendering ----- *@
                @foreach (var p in Model) @* Loops through the collection and renders each item. *@
                {
 @* ----- Conditional Rendering ----- *@
                    int    prodCount  = p.Products?.Count ?? 0; @* Renders part of the admin dashboard page markup. *@
                    int    orderCount = p.ProducerOrders?.Count ?? 0; @* Renders part of the admin dashboard page markup. *@
 @* ----- Search and Filters ----- *@
                    decimal revenue   = p.ProducerOrders?.Where(o => o.TrackingStatus == "Accepted").Sum(o => o.ProducerSubtotal) ?? 0m; @* Renders part of the admin dashboard page markup. *@
 @* ----- Table Layout ----- *@
                    <tr> @* Starts one table row. *@
                        <td style="padding:8px 8px 8px 14px;"> @* Renders a table data cell. *@
 @* ----- Conditional Rendering ----- *@
                            <div class="adm-avatar">@(p.ProducerName?.Substring(0,1).ToUpper() ?? "?")</div> @* Starts a layout container for this section. *@
                        </td> @* Closes the matching HTML element. *@
 @* ----- Table Layout ----- *@
                        <td> @* Renders a table data cell. *@
 @* ----- Producer Display ----- *@
                            <div style="font-weight:700;">@p.ProducerName</div> @* Starts a layout container for this section. *@
 @* ----- Conditional Rendering ----- *@
                            @if (!string.IsNullOrEmpty(p.ProducerInformation)) @* Conditionally renders this block when the check passes. *@
 @* ----- Producer Display ----- *@
                            { <div style="font-size:11px;color:var(--text-muted);max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.ProducerInformation</div> } @* Renders part of the admin dashboard page markup. *@
                        </td> @* Closes the matching HTML element. *@
 @* ----- Table Layout ----- *@
                        <td style="color:var(--text-muted);">@p.ProducerEmail</td> @* Renders a table data cell. *@
                        <td> @* Renders a table data cell. *@
 @* ----- Conditional Rendering ----- *@
                            @if (p.IsVATRegistered) @* Conditionally renders this block when the check passes. *@
 @* ----- Producer Display ----- *@
                            { <span class="adm-badge adm-badge--ok">VAT reg</span> @* Renders part of the admin dashboard page markup. *@
                              if (!string.IsNullOrEmpty(p.VATNumber)) @* Renders part of the admin dashboard page markup. *@
                              { <div style="font-size:10px;color:var(--text-light);margin-top:2px;">@p.VATNumber</div> } @* Renders part of the admin dashboard page markup. *@
                            }
 @* ----- Conditional Rendering ----- *@
                            else { <span class="adm-badge adm-badge--off">No VAT</span> } @* Renders the fallback branch for the previous condition. *@
                        </td> @* Closes the matching HTML element. *@
 @* ----- Table Layout ----- *@
                        <td style="font-weight:600;">@prodCount</td> @* Renders a table data cell. *@
                        <td style="font-weight:600;">@orderCount</td> @* Renders a table data cell. *@
                        <td style="font-weight:700;color:var(--green);">£@revenue.ToString("0.00")</td> @* Renders a table data cell. *@
                        <td> @* Renders a table data cell. *@
                            <div style="display:flex;gap:5px;"> @* Starts a layout container for this section. *@
 @* ----- Form Actions ----- *@
                                <a href="/Producers/Details/@p.ProducersId" class="adm-tbl-btn">View</a> @* Renders a navigation link or action link. *@
                                <a href="/Producers/Edit/@p.ProducersId" class="adm-tbl-btn"><i data-lucide="pencil" style="width:11px;height:11px;" aria-hidden="true"></i>Edit</a> @* Renders a navigation link or action link. *@
                            </div> @* Closes the matching HTML element. *@
                        </td> @* Closes the matching HTML element. *@
                    </tr> @* Closes the matching HTML element. *@
                }
                </tbody> @* Closes the matching HTML element. *@
            </table> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    }
 @* ----- Conditional Rendering ----- *@
    else @* Renders the fallback branch for the previous condition. *@
    {
        <div style="padding:48px;text-align:center;color:var(--text-muted);"> @* Starts a layout container for this section. *@
            <i data-lucide="sprout" style="width:40px;height:40px;display:block;margin:0 auto 10px;opacity:.3;" aria-hidden="true"></i> @* Renders part of the admin dashboard page markup. *@
 @* ----- Producer Display ----- *@
            <p style="font-size:14px;margin:0;">No producers found.</p> @* Renders paragraph text for the user. *@
        </div> @* Closes the matching HTML element. *@
    }
</div> @* Closes the matching HTML element. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
 @* ----- Card Layout ----- *@
    <script src="~/js/pages/admindashboard/AdminDashboardProducers.js" asp-append-version="true"></script>  } @* Starts client-side script for this page. *@

@section Styles { @* Starts a named Razor section rendered by the layout. *@
    <link rel="stylesheet" href="~/css/pages/admindashboard/AdminDashboardProducers.css" asp-append-version="true" /> @* Renders one list item. *@
}
