@* ----- Page Model Setup ----- *@
@* Sets the model type used by this view. *@
@model IEnumerable<GFLHApp.Models.Products>
@using System.Security.Claims
@{
    ViewData["Title"] = "Shop the Harvest"; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.

    // ----- Loop Rendering -----
    var productList = Model.ToList(); // Displays or uses data from the products model.
                                      // ----- Product Display -----
    var categories = productList // Renders part of the products page markup.
                                 // ----- Search and Filters -----
        .Select(p => p.Category) // Renders part of the products page markup.
        .Where(c => !string.IsNullOrWhiteSpace(c)) // Renders part of the products page markup.
        .Distinct() // Renders part of the products page markup.
                    // ----- Order Display -----
        .OrderBy(c => c) // Renders part of the products page markup.
        .ToList(); // Renders part of the products page markup.
                   // ----- Product Display -----
    var producers = productList // Renders part of the products page markup.
                                // ----- Producer Display -----
        .Where(p => p.Producers != null && !string.IsNullOrWhiteSpace(p.Producers.ProducerName)) // Renders part of the products page markup.
        .Select(p => new { p.Producers!.ProducersId, p.Producers.ProducerName }) // Select both ID and name so the filter dropdown uses real IDs.
        .DistinctBy(p => p.ProducersId) // Renders part of the products page markup.
                                        // ----- Order Display -----
        .OrderBy(p => p.ProducerName) // Renders part of the products page markup.
        .ToList(); // Renders part of the products page markup.
                   // ----- Conditional Rendering -----
    var availableCount = productList.Count(p => p.Available && p.QuantityInStock > 0); // Renders part of the products page markup.
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier); // Current signed-in user id for ownership checks.
    var isAdminOrDeveloper = User.IsInRole("Admin") || User.IsInRole("Developer"); // Admins can manage catalogue deletion.
}



@* ── Error Toast ────────────────────────────────────── *@
@* ----- Status Messages ----- *@
@if (TempData["Error"] != null) @* Conditionally renders this block when the check passes. *@
{
    <div id="errorToast" class="pw-toast pw-toast--error" role="alert" aria-live="assertive">
        @* Starts a layout container for this section. *@
        <i data-lucide="alert-triangle" class="pw-icon-sm" aria-hidden="true"></i> @* Renders part of the products page markup. *@
        @TempData["Error"] @* Reads a one-request message supplied by the controller. *@
    </div> @* Closes the matching HTML element. *@
}

