 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model IEnumerable<GFLHApp.Models.Orders>

@{
    ViewData["Title"] = "Your Orders"; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.
 // ----- Authorization Display -----
    var isAdmin    = User.IsInRole("Admin"); // Renders part of the orders page markup.
    var isProducer = User.IsInRole("Producer"); // Renders part of the orders page markup.
 // ----- Loop Rendering -----
    var ordersList = Model.ToList(); // Displays or uses data from the orders model.
 // ----- Conditional Rendering -----
    var totalOrders  = ordersList.Count; // Renders part of the orders page markup.
 // ----- Search and Filters -----
    var activeOrders = ordersList.Count(o => o.TrackingStatus != "Delivered"); // Renders part of the orders page markup.
 // ----- Basket Display -----
    var totalSpend   = ordersList.Sum(o => o.OrdersTotal); // Renders part of the orders page markup.
 // ----- Conditional Rendering -----
    // Controller grants free delivery when orderCount % 3 == 2.
 // ----- Order Display -----
    // So: 0 orders → 2 away, 1 order → 1 away, 2 orders → free now.
 // ----- Basket Display -----
    var remainder = totalOrders % 3; // Renders part of the orders page markup.
 // ----- Conditional Rendering -----
    var nextFreeDeliveryIn = (remainder == 2) ? 0 : (2 - remainder); // Renders part of the orders page markup.
}



