════════════════════════════════════════════ --> @* Renders part of the orders page markup. *@
<section class="pw-section pw-section--white" aria-labelledby="orders-heading"> @* Renders part of the orders page markup. *@
 @* ----- Styling Section ----- *@
    <div class="pw-container"> @* Starts a layout container for this section. *@

 @* ----- Page Header ----- *@
        <h2 id="orders-heading" class="sr-only">Orders list</h2> @* Renders a heading for this page section. *@

 @* ----- Status Messages ----- *@
        @if (TempData["ReorderWarning"] is string reorderWarning) @* Conditionally renders this block when the check passes. *@
        {
 @* ----- Card Layout ----- *@
            <div class="pw-orders-flash" role="status"> @* Starts a layout container for this section. *@
 @* ----- Status Messages ----- *@
                <i data-lucide="triangle-alert" class="pw-icon-sm" aria-hidden="true"></i> @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                <span>@reorderWarning</span> @* Renders inline text or badge content. *@
            </div> @* Closes the matching HTML element. *@
        }

 @* ----- Search and Filters ----- *@
        <!-- ─── Filter & Sort Toolbar ─── --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Fields ----- *@
        <div class="pw-orders-toolbar reveal" role="search" aria-label="Filter and sort orders"> @* Starts a layout container for this section. *@

 @* ----- Search and Filters ----- *@
            <!-- Search --> @* Keeps an existing comment in the Razor file. *@
            <div class="pw-orders-search"> @* Starts a layout container for this section. *@
                <svg class="pw-orders-search__icon" xmlns="http://www.w3.org/2000/svg" @* Renders part of the orders page markup. *@
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"> @* Renders part of the orders page markup. *@
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/> @* Renders part of the orders page markup. *@
                </svg> @* Closes the matching HTML element. *@
 @* ----- Form Fields ----- *@
                <input type="text" id="ordersSearch" class="pw-orders-search__input" @* Renders a user input field. *@
                       placeholder="Search order #…" aria-label="Search by order number" @* Renders part of the orders page markup. *@
                       autocomplete="off"> @* Renders part of the orders page markup. *@
            </div> @* Closes the matching HTML element. *@

 @* ----- Search and Filters ----- *@
            <!-- Sort --> @* Keeps an existing comment in the Razor file. *@
            <div class="pw-orders-sort"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                <label for="ordersSort" class="pw-orders-sort__label"> @* Renders text identifying a form field. *@
 @* ----- Card Layout ----- *@
                    <i data-lucide="arrow-up-down" class="pw-icon-sm"></i> @* Renders part of the orders page markup. *@
 @* ----- Search and Filters ----- *@
                    Sort @* Renders part of the orders page markup. *@
 @* ----- Form Fields ----- *@
                </label> @* Closes the matching HTML element. *@
                <select id="ordersSort" class="pw-orders-sort__select" aria-label="Sort orders"> @* Renders a dropdown selection field. *@
                    <option value="newest">Most Recent</option> @* Renders one dropdown option. *@
                    <option value="oldest">Oldest First</option> @* Renders one dropdown option. *@
                    <option value="highest">Highest Value</option> @* Renders one dropdown option. *@
                    <option value="lowest">Lowest Value</option> @* Renders one dropdown option. *@
                </select> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@

 @* ----- Search and Filters ----- *@
            <!-- Status Filter Chips --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Fields ----- *@
            <div class="pw-orders-filters" role="group" aria-label="Filter by status"> @* Starts a layout container for this section. *@
 @* ----- Form Actions ----- *@
                <button class="pw-orders-filter-btn is-active" data-filter="all" type="button">All</button> @* Renders a button for the user action. *@
                <button class="pw-orders-filter-btn" data-filter="Pending" type="button"> @* Renders a button for the user action. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="package" class="pw-icon-sm"></i> Pending @* Renders part of the orders page markup. *@
                </button> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
                <button class="pw-orders-filter-btn" data-filter="Preparing Delivery" type="button"> @* Renders a button for the user action. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="truck" class="pw-icon-sm"></i> Preparing @* Renders part of the orders page markup. *@
                </button> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
                <button class="pw-orders-filter-btn" data-filter="Awaiting Confirmation" type="button"> @* Renders a button for the user action. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="clock" class="pw-icon-sm"></i> Awaiting @* Renders part of the orders page markup. *@
                </button> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
                <button class="pw-orders-filter-btn" data-filter="Delivered" type="button"> @* Renders a button for the user action. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="check-circle" class="pw-icon-sm"></i> Delivered @* Renders part of the orders page markup. *@
                </button> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@

 @* ----- Conditional Rendering ----- *@
        <!-- Results count --> @* Keeps an existing comment in the Razor file. *@
        <p class="pw-orders-count" id="ordersCount" aria-live="polite"> @* Renders paragraph text for the user. *@
            Showing <strong id="ordersCountNum">@ordersList.Count</strong> @* Renders part of the orders page markup. *@
            order@(ordersList.Count != 1 ? "s" : "") @* Renders part of the orders page markup. *@
        </p> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
        <!-- ─── Order Cards ─── --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Conditional Rendering ----- *@
        @if (!ordersList.Any()) @* Conditionally renders this block when the check passes. *@
        {
 @* ----- Card Layout ----- *@
            <div class="pw-orders-empty reveal" role="status"> @* Starts a layout container for this section. *@
 @* ----- Order Display ----- *@
                <div class="pw-orders-empty__icon" aria-hidden="true"> @* Starts a layout container for this section. *@
                    <i data-lucide="package-open" style="width:36px;height:36px;stroke-width:1.5;color:var(--text-light)"></i> @* Renders part of the orders page markup. *@
                </div> @* Closes the matching HTML element. *@
 @* ----- Page Header ----- *@
                <h2 class="pw-orders-empty__title">No orders yet</h2> @* Renders a heading for this page section. *@
 @* ----- Order Display ----- *@
                <p class="pw-orders-empty__desc"> @* Renders paragraph text for the user. *@
                    When you place an order it'll appear here.<br>Go find something fresh! @* Renders part of the orders page markup. *@
                </p> @* Closes the matching HTML element. *@
 @* ----- Navigation ----- *@
                <a asp-area="" asp-controller="Products" asp-action="Index" @* Builds a link or form target using MVC routing. *@
 @* ----- Form Actions ----- *@
                   class="pw-btn pw-btn--primary pw-btn--lg"> @* Renders part of the orders page markup. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="sprout" class="pw-icon-sm"></i> @* Renders part of the orders page markup. *@
                    Shop the Harvest @* Renders part of the orders page markup. *@
                </a> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@
        }
 @* ----- Conditional Rendering ----- *@
        else @* Renders the fallback branch for the previous condition. *@
        {
 @* ----- Form Fields ----- *@
            <div class="pw-orders-list" id="ordersList" aria-label="Your orders"> @* Starts a layout container for this section. *@

 @* ----- Loop Rendering ----- *@
                @foreach (var order in ordersList.OrderByDescending(o => o.OrderDate)) @* Loops through the collection and renders each item. *@
                {
 @* ----- Search and Filters ----- *@
                    var statusBadge = order.TrackingStatus switch { @* Renders part of the orders page markup. *@
                        "Delivered"             => "pw-badge--green", @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                        "Awaiting Confirmation" => "pw-badge--purple", @* Renders part of the orders page markup. *@
                        "Preparing Delivery"    => "pw-badge--orange", @* Renders part of the orders page markup. *@
                        _                       => "pw-badge--yellow" @* Renders part of the orders page markup. *@
                    };
 @* ----- Search and Filters ----- *@
                    var cardAccent = order.TrackingStatus switch { @* Renders part of the orders page markup. *@
 @* ----- Card Layout ----- *@
                        "Delivered"             => "pw-order-card--delivered", @* Renders part of the orders page markup. *@
                        "Awaiting Confirmation" => "pw-order-card--awaiting", @* Renders part of the orders page markup. *@
                        "Preparing Delivery"    => "pw-order-card--preparing", @* Renders part of the orders page markup. *@
                        _                       => "pw-order-card--pending" @* Renders part of the orders page markup. *@
                    };
 @* ----- Search and Filters ----- *@
                    var statusIcon = order.TrackingStatus switch { @* Renders part of the orders page markup. *@
                        "Delivered"             => "check-circle", @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                        "Awaiting Confirmation" => "clock", @* Renders part of the orders page markup. *@
                        "Preparing Delivery"    => "truck", @* Renders part of the orders page markup. *@
                        _                       => "package" @* Renders part of the orders page markup. *@
                    };
 @* ----- Conditional Rendering ----- *@
                    var itemCount       = order.OrderProducts?.Count ?? 0; @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                    var formattedId     = $"#PF-{order.OrdersId:D6}"; @* Renders part of the orders page markup. *@
 @* ----- Basket Display ----- *@
                    var daysSinceOrder  = (DateTime.Now - order.OrderDate.ToDateTime(TimeOnly.MinValue)).TotalDays; @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                    var autoDelivered   = order.DeliveryConfirmed || daysSinceOrder >= 7; @* Renders part of the orders page markup. *@
 @* ----- Search and Filters ----- *@
                    var canConfirm      = order.Delivery && !autoDelivered && order.TrackingStatus == "Awaiting Confirmation"; @* Renders part of the orders page markup. *@

 @* ----- Card Layout ----- *@
                    <article class="pw-order-card @cardAccent reveal" @* Renders a navigation link or action link. *@
 @* ----- Search and Filters ----- *@
                             data-status="@order.TrackingStatus" @* Renders part of the orders page markup. *@
 @* ----- Conditional Rendering ----- *@
                             data-method="@(order.Delivery ? "delivery" : "collection")" @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                             data-date="@order.OrderDate.ToString("yyyy-MM-dd")" @* Renders part of the orders page markup. *@
 @* ----- Basket Display ----- *@
                             data-value="@order.OrdersTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                             data-id="@order.OrdersId" @* Renders part of the orders page markup. *@
 @* ----- Form Fields ----- *@
                             aria-label="Order @formattedId, @order.TrackingStatus, £@order.OrdersTotal.ToString("0.00")"> @* Renders part of the orders page markup. *@

                        <!-- Accent stripe --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
                        <div class="pw-order-card__accent" aria-hidden="true"></div> @* Starts a layout container for this section. *@

                        <!-- Header: ID + status + total --> @* Keeps an existing comment in the Razor file. *@
                        <div class="pw-order-card__header"> @* Starts a layout container for this section. *@
                            <div class="pw-order-card__header-left"> @* Starts a layout container for this section. *@
 @* ----- Page Header ----- *@
                                <h3 class="pw-order-card__id">@formattedId</h3> @* Renders a heading for this page section. *@
 @* ----- Card Layout ----- *@
                                <span class="pw-badge @statusBadge"> @* Renders inline text or badge content. *@
                                    <i data-lucide="@statusIcon" class="pw-icon-sm"></i> @* Renders part of the orders page markup. *@
 @* ----- Search and Filters ----- *@
                                    @order.TrackingStatus @* Outputs Razor data or executes Razor logic. *@
                                </span> @* Closes the matching HTML element. *@
                            </div> @* Closes the matching HTML element. *@
 @* ----- Card Layout ----- *@
                            <span class="pw-order-card__total">£@order.OrdersTotal.ToString("0.00")</span> @* Renders inline text or badge content. *@
                        </div> @* Closes the matching HTML element. *@

                        <!-- Meta row: date · method · items [· user if admin] --> @* Keeps an existing comment in the Razor file. *@
                        <div class="pw-order-card__meta"> @* Starts a layout container for this section. *@
                            <span class="pw-order-card__meta-item"> @* Renders inline text or badge content. *@
 @* ----- Styling Section ----- *@
                                <i data-lucide="calendar" class="pw-icon-sm pw-icon-muted"></i> @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                                @order.OrderDate.ToString("d MMMM yyyy") @* Outputs Razor data or executes Razor logic. *@
                            </span> @* Closes the matching HTML element. *@
 @* ----- Card Layout ----- *@
                            <span class="pw-order-card__meta-sep" aria-hidden="true">·</span> @* Renders inline text or badge content. *@
                            <span class="pw-order-card__meta-item"> @* Renders inline text or badge content. *@
 @* ----- Conditional Rendering ----- *@
                                @if (order.Delivery) @* Conditionally renders this block when the check passes. *@
                                {
 @* ----- Styling Section ----- *@
                                    <i data-lucide="truck" class="pw-icon-sm pw-icon-muted"></i> @* Renders part of the orders page markup. *@
 @* ----- Order Display ----- *@
                                    <text>Delivery</text> @* Renders part of the orders page markup. *@
 @* ----- Conditional Rendering ----- *@
                                    @if (!string.IsNullOrEmpty(order.DeliveryMethod)) @* Conditionally renders this block when the check passes. *@
                                    {
