 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model GFLHApp.Models.Orders
@{
    ViewData["Title"] = "Checkout"; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.
    var basketProducts = ViewBag.BasketProducts as IEnumerable<GFLHApp.Models.BasketProducts> ?? Enumerable.Empty<GFLHApp.Models.BasketProducts>(); // Reads view data supplied by the controller.
    var subtotal       = (decimal)(ViewBag.Subtotal ?? 0m); // Reads view data supplied by the controller.
    var discount       = (decimal)(ViewBag.Discount ?? 0m); // Reads the server-calculated checkout discount.
    var baseTotal      = subtotal - discount; // Stores the order total before any delivery charge is applied.
    var total          = (decimal)(ViewBag.Total ?? subtotal - discount); // Reads the server-calculated checkout total.
    var hasFreeDelivery = (bool)(ViewBag.HasFreeDelivery ?? false); // Reads view data supplied by the controller.
    var baseTotalForScript = baseTotal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture); // Formats the delivery-free base total for client-side JavaScript.
    var hasFreeDeliveryForScript = hasFreeDelivery.ToString().ToLowerInvariant(); // Formats the free-delivery flag for client-side JavaScript.
 // ----- Conditional Rendering -----
    var anyAllergens   = basketProducts.Any(i => !string.IsNullOrWhiteSpace(i.Products?.Allergens)); // Renders part of the orders page markup.
}



