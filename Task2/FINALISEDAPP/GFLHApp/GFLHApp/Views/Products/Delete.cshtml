                    {
 @* ----- Card Layout ----- *@
                        <div class="pw-del-row"> @* Starts a layout container for this section. *@
                            <div class="pw-del-row__icon pw-del-row__icon--orange"> @* Starts a layout container for this section. *@
 @* ----- Status Messages ----- *@
                                <i data-lucide="alert-triangle" style="width:16px;height:16px;stroke-width:2"></i> @* Renders part of the products page markup. *@
