                    <li><a asp-controller="Products" asp-action="Index">Shop</a></li> @* Builds a link or form target using MVC routing. *@
                    <li><a asp-controller="Products" asp-action="Details" asp-route-id="@Model.ProductsId">@Model.ItemName</a></li> @* Builds a link or form target using MVC routing. *@
 @* ----- Form Actions ----- *@
                    <li><span aria-current="page">Delete</span></li> @* Renders one list item. *@
