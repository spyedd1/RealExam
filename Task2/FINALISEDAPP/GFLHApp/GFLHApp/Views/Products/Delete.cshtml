 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model GFLHApp.Models.Products
@{
    ViewData["Title"] = "Delete — " + Model.ItemName; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.

 // ----- Search and Filters -----
    string CategoryIcon(string cat) => (cat ?? "").ToLower() switch { // Renders part of the products page markup.
        var c when c.Contains("veg")   => "carrot", // Renders part of the products page markup.
        var c when c.Contains("fruit") => "cherry", // Renders part of the products page markup.
        var c when c.Contains("dairy") => "milk", // Renders part of the products page markup.
        var c when c.Contains("meat")  => "beef", // Renders part of the products page markup.
        var c when c.Contains("bread") || c.Contains("bak") => "wheat", // Renders part of the products page markup.
        var c when c.Contains("drink") => "cup-soda", // Renders part of the products page markup.
        var c when c.Contains("egg")   => "egg", // Renders part of the products page markup.
        var c when c.Contains("herb")  => "flower-2", // Renders part of the products page markup.
        var c when c.Contains("honey") => "droplets", // Renders part of the products page markup.
        _                              => "package" // Renders part of the products page markup.
    };

 // ----- Loop Rendering -----
    var hasImage   = !string.IsNullOrWhiteSpace(Model.ImagePath); // Displays or uses data from the products model.
    var inStock    = Model.Available && Model.QuantityInStock > 0; // Displays or uses data from the products model.
    var allergens  = string.IsNullOrWhiteSpace(Model.Allergens) // Displays or uses data from the products model.
 // ----- Conditional Rendering -----
                        ? null // Renders part of the products page markup.
 // ----- Loop Rendering -----
                        : Model.Allergens.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries); // Displays or uses data from the products model.
}



 @* ----- Styling Section ----- *@
<div class="pw-del-page"> @* Starts a layout container for this section. *@

    <!-- ── Header ──────────────────────────────────────── --> @* Keeps an existing comment in the Razor file. *@
