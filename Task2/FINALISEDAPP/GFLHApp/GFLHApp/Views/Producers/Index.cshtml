 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model IEnumerable<GFLHApp.Models.Producers>

@{
    ViewData["Title"] = "Meet Our Growers"; // Page title
    ViewData["FullWidth"] = true; // Enable full-width layout

 // ----- Card Layout -----
    var cardAccents = new[] { "--green", "--orange", "--purple", "--pop", "--green", "--orange" }; // Accent classes cycled per card
    var floatIcons = new[] { "sprout", "leaf", "wheat", "carrot", "flower-2", "cherry" };              // Icons cycled per card sticker
    int idx = 0; // Card index counter for cycling accents, icons and delays
}

<!-- Scroll progress bar --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
<div id="scrollProgress" class="pw-scroll-progress" aria-hidden="true"></div> <!-- Scroll progress indicator --> @* Starts a layout container for this section. *@
<!-- ════════════════════════════════════════════════════ @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
     GROWERS INTRO  (unique — not a copy of home hero) @* Renders part of the producers page markup. *@
════════════════════════════════════════════════════ --> @* Renders part of the producers page markup. *@
 @* ----- Form Fields ----- *@
<section class="gw-intro" aria-label="Meet our growers"> @* Renders part of the producers page markup. *@
