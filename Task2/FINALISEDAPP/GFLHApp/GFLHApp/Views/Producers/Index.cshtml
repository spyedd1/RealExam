 @* ----- Form Fields ----- *@
        <i data-lucide="leaf" style="width:12px;height:12px;"></i> Seasonal <!-- Leaf icon + label --> @* Renders part of the producers page markup. *@
    </div> @* Closes the matching HTML element. *@
 @* ----- Styling Section ----- *@
    <div class="gw-sticker gw-sticker--5" aria-hidden="true"> @* Starts a layout container for this section. *@
        <!-- Floating sticker 5 --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Fields ----- *@
        <i data-lucide="sun" style="width:12px;height:12px;"></i> Fresh! <!-- Sun icon + label --> @* Renders part of the producers page markup. *@
    </div> @* Closes the matching HTML element. *@

    <!-- Main copy --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
    <div class="gw-intro__content"> @* Starts a layout container for this section. *@
        <!-- Main text block --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
        <p class="gw-intro__eyebrow"> @* Renders paragraph text for the user. *@
 @* ----- Form Fields ----- *@
            <!-- Eyebrow label --> @* Keeps an existing comment in the Razor file. *@
            <i data-lucide="users" style="width:14px;height:14px;"></i> <!-- Users icon --> @* Renders part of the producers page markup. *@
 @* ----- Page Model Setup ----- *@
            @Model.Count() grower@(Model.Count() != 1 ? "s" : "") on the platform <!-- Pluralised grower count --> @* Displays or uses data from the producers model. *@
        </p> @* Closes the matching HTML element. *@

 @* ----- Page Header ----- *@
        <h1 class="gw-intro__title"> @* Renders a heading for this page section. *@
            <!-- Main hero heading --> @* Keeps an existing comment in the Razor file. *@
            Say hello to the<br> @* Renders part of the producers page markup. *@
 @* ----- Styling Section ----- *@
            <span class="hl-green hl-squig">humans</span>   <!-- "humans" with green squiggle highlight --> @* Renders inline text or badge content. *@
 @* ----- Card Layout ----- *@
            <span class="hl-orange"> growing</span><br>     <!-- "growing" in orange --> @* Renders inline text or badge content. *@
 @* ----- Styling Section ----- *@
            your <span class="hl-pink">favourite</span>     <!-- "favourite" in pink --> @* Renders part of the producers page markup. *@
            <span class="hl-purple"> things.</span>         <!-- "things." in purple --> @* Renders inline text or badge content. *@
        </h1> @* Closes the matching HTML element. *@

        <p class="gw-intro__sub"> @* Renders paragraph text for the user. *@
            <!-- Intro subtitle paragraph --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Basket Display ----- *@
            Every item in your basket has a face behind it — a real farmer, @* Renders part of the producers page markup. *@
            a real field, a real story. Come and meet them. @* Renders part of the producers page markup. *@
        </p> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
        <div class="gw-intro__cta-row"> @* Starts a layout container for this section. *@
            <!-- CTA button row --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Actions ----- *@
            <a class="pw-btn pw-btn--primary pw-btn--lg" href="#growers-section"> @* Renders a navigation link or action link. *@
 @* ----- Card Layout ----- *@
                <!-- Primary CTA: scroll to grid --> @* Keeps an existing comment in the Razor file. *@
                Meet the Farmers @* Renders part of the producers page markup. *@
            </a> @* Closes the matching HTML element. *@
            <a class="gw-intro__scroll-cta" href="#growers-section"> @* Renders a navigation link or action link. *@
                <!-- Secondary scroll prompt --> @* Keeps an existing comment in the Razor file. *@
                <i data-lucide="arrow-down" style="width:15px;height:15px;"></i> <!-- Down arrow icon --> @* Renders part of the producers page markup. *@
                Scroll to explore @* Renders part of the producers page markup. *@
            </a> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@

    <!-- Polaroid photo strip --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
    <div class="gw-polaroid-strip" aria-hidden="true" role="presentation"> @* Starts a layout container for this section. *@
        <!-- Decorative photo strip --> @* Keeps an existing comment in the Razor file. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 1; data-burst triggers particle effect on hover --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Producer Display ----- *@
            <img class="gw-polaroid__img" src="~/images/producers/meadowFreshOrganicFarm.jpg" alt="" loading="eager"> <!-- Farm field photo --> @* Renders an image for the page content. *@
 @* ----- Styling Section ----- *@
            <span class="gw-polaroid__caption">The fields ☀️</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 2 --> @* Keeps an existing comment in the Razor file. *@
            <img class="gw-polaroid__img" src="~/images/home/olderLady.jpg" alt="" loading="eager"> <!-- Martha photo --> @* Renders an image for the page content. *@
            <span class="gw-polaroid__caption">Martha 🌿</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 3 --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Producer Display ----- *@
            <img class="gw-polaroid__img" src="~/images/producers/greenValleyProduce.jpg" alt="" loading="eager"> <!-- Harvest photo --> @* Renders an image for the page content. *@
 @* ----- Styling Section ----- *@
            <span class="gw-polaroid__caption">Fruit Frenzy</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 4 --> @* Keeps an existing comment in the Razor file. *@
            <img class="gw-polaroid__img" src="~/images/home/manwalking.jpg" alt="" loading="eager"> <!-- Tom's farm photo --> @* Renders an image for the page content. *@
            <span class="gw-polaroid__caption">Tom's farm 🥕</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 5 --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Producer Display ----- *@
            <img class="gw-polaroid__img" src="~/images/producers/oakridgeHarvestHub.jpg" alt="" loading="eager"> <!-- Soil photo --> @* Renders an image for the page content. *@
 @* ----- Styling Section ----- *@
            <span class="gw-polaroid__caption">Platonic Planter        🌱</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
        <div class="gw-polaroid" data-burst> @* Starts a layout container for this section. *@
            <!-- Polaroid 6 --> @* Keeps an existing comment in the Razor file. *@
            <img class="gw-polaroid__img" src="~/images/home/homestrawberries.jpg" alt="" loading="eager"> <!-- Barn photo --> @* Renders an image for the page content. *@
            <span class="gw-polaroid__caption">Strawberries! 🍓</span> <!-- Caption --> @* Renders inline text or badge content. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@

    <!-- Colourful topic tags --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Fields ----- *@
    <div class="gw-tag-row" role="list" aria-label="Topics"> @* Starts a layout container for this section. *@
 @* ----- Card Layout ----- *@
        <!-- Tag row, announced as a list --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
        <span class="gw-tag gw-tag--a" role="listitem"><i data-lucide="sun" style="width:12px;height:12px;"></i> Seasonal</span>        <!-- Seasonal tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--b" role="listitem"><i data-lucide="map-pin" style="width:12px;height:12px;"></i> UK Only</span>          <!-- UK Only tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--c" role="listitem"><i data-lucide="heart" style="width:12px;height:12px;"></i> Family Farms</span>     <!-- Family Farms tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--d" role="listitem"><i data-lucide="sprout" style="width:12px;height:12px;"></i> Sustainable</span>      <!-- Sustainable tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--e" role="listitem"><i data-lucide="package" style="width:12px;height:12px;"></i> Zero Plastic</span>     <!-- Zero Plastic tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--f" role="listitem"><i data-lucide="handshake" style="width:12px;height:12px;"></i> Fair Pay</span>         <!-- Fair Pay tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--g" role="listitem"><i data-lucide="leaf" style="width:12px;height:12px;"></i> Organic Options</span>  <!-- Organic Options tag --> @* Renders inline text or badge content. *@
        <span class="gw-tag gw-tag--h" role="listitem"><i data-lucide="shield-check" style="width:12px;height:12px;"></i> Verified Quality</span> <!-- Verified Quality tag --> @* Renders inline text or badge content. *@
    </div> @* Closes the matching HTML element. *@

    <!-- Soft wave into next section --> @* Keeps an existing comment in the Razor file. *@
    <div class="gw-intro__wave" aria-hidden="true"> @* Starts a layout container for this section. *@
        <!-- Decorative wave transition --> @* Keeps an existing comment in the Razor file. *@
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none"> @* Renders part of the producers page markup. *@
            <!-- Wave SVG --> @* Keeps an existing comment in the Razor file. *@
            <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#F9FAFB" /> <!-- Wave path filled with next section background colour --> @* Renders paragraph text for the user. *@
        </svg> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@
</section> @* Closes the matching HTML element. *@


<!-- ════════════════════════════════════════════════════ @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
     GROWERS GRID @* Renders part of the producers page markup. *@
════════════════════════════════════════════════════ --> @* Renders part of the producers page markup. *@
 @* ----- Form Fields ----- *@
<section id="growers-section" class="pw-section pw-section--cream" aria-labelledby="growers-heading"> @* Renders part of the producers page markup. *@
 @* ----- Card Layout ----- *@
    <!-- Growers grid section; anchor target for CTA links --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
    <div class="pw-container"> @* Starts a layout container for this section. *@
        <!-- Centred container --> @* Keeps an existing comment in the Razor file. *@

        <div class="pw-section__header reveal reveal--blur"> @* Starts a layout container for this section. *@
            <!-- Section header, animates in with blur --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
            <span class="pw-section__eyebrow"> @* Renders inline text or badge content. *@
 @* ----- Form Fields ----- *@
                <!-- Eyebrow label --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                <i data-lucide="users" class="pw-icon-sm"></i> <!-- Users icon --> @* Renders part of the producers page markup. *@
                The people @* Renders part of the producers page markup. *@
            </span> @* Closes the matching HTML element. *@
 @* ----- Page Header ----- *@
            <h2 class="pw-section__title" id="growers-heading"> @* Renders a heading for this page section. *@
                <!-- Section heading --> @* Keeps an existing comment in the Razor file. *@
                Not a supermarket.<br> @* Renders part of the producers page markup. *@
 @* ----- Styling Section ----- *@
                <em class="pw-text--green">Not even close.</em> <!-- Green emphasis --> @* Renders part of the producers page markup. *@
            </h2> @* Closes the matching HTML element. *@
            <p class="pw-section__subtitle"> @* Renders paragraph text for the user. *@
                <!-- Section subtitle --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Product Display ----- *@
                Every product is traceable to a real farm, a real face, and a real story. @* Renders part of the producers page markup. *@
            </p> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@

 @* ----- Authorization Display ----- *@
        @if (User.IsInRole("Admin")) // Only show admin strip to admin users @* Conditionally renders this block when the check passes. *@
        {
 @* ----- Styling Section ----- *@
            <div class="pw-admin-strip reveal" data-delay="100"> @* Starts a layout container for this section. *@
                <!-- Admin toolbar strip --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Fields ----- *@
                <p class="pw-admin-strip__label"> @* Renders paragraph text for the user. *@
                    <!-- Label with producer count --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="shield" class="pw-icon-sm pw-icon-green"></i> <!-- Shield icon --> @* Renders part of the producers page markup. *@
 @* ----- Loop Rendering ----- *@
                    <strong>Admin view</strong> — managing @Model.Count() producer@(Model.Count() != 1 ? "s" : "") <!-- Pluralised count --> @* Displays or uses data from the producers model. *@
                </p> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
                <a class="pw-btn pw-btn--primary pw-btn--sm" @* Renders a navigation link or action link. *@
 @* ----- Navigation ----- *@
                   asp-action="Create"> @* Builds a link or form target using MVC routing. *@
 @* ----- Form Actions ----- *@
                    <!-- Link to Create action --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                    <i data-lucide="plus" class="pw-icon-sm"></i> <!-- Plus icon --> @* Renders part of the producers page markup. *@
 @* ----- Producer Display ----- *@
                    Add Producer @* Renders part of the producers page markup. *@
                </a> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@
        }

 @* ----- Card Layout ----- *@
        @if (Model.Any()) // Render grid if producers exist @* Conditionally renders this block when the check passes. *@
        {
            <div class="pw-grid pw-grid--2 pw-producers-grid"> @* Starts a layout container for this section. *@
                <!-- 2-column producer card grid --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Loop Rendering ----- *@
                @foreach (var item in Model) // Loop through each producer @* Loops through the collection and renders each item. *@
                {
 @* ----- Card Layout ----- *@
                    var accentClass = cardAccents[idx % cardAccents.Length]; // Cycle accent class by index @* Renders part of the producers page markup. *@
                    var delay = (idx % 4) * 120;                       // Staggered animation delay: 0, 120, 240, 360ms @* Renders part of the producers page markup. *@
                    var revealDir = idx % 2 == 0 ? "reveal--left" : "reveal--right"; // Alternate reveal direction per card @* Renders part of the producers page markup. *@
                    var floatIcon = floatIcons[idx % floatIcons.Length];   // Cycle sticker icon by index @* Renders part of the producers page markup. *@
                    var paletteCls = "pw-card__no-photo--" + (idx % 6);     // Cycle colour palette class (0–5) @* Renders part of the producers page markup. *@
 @* ----- Producer Display ----- *@
                    var hasImage = !string.IsNullOrWhiteSpace(item.ImagePath); // Whether the producer has an image to show @* Renders part of the producers page markup. *@
 @* ----- Card Layout ----- *@
                    idx++; // Increment index for next card @* Renders part of the producers page markup. *@

                    <article class="pw-card pw-card--grower pw-card--producer reveal @revealDir" @* Renders a navigation link or action link. *@
                             data-delay="@delay" @* Renders part of the producers page markup. *@
 @* ----- Producer Display ----- *@
                             data-producer-id="@item.ProducersId"> @* Renders part of the producers page markup. *@
 @* ----- Card Layout ----- *@
                        <!-- Producer card article --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Producer Display ----- *@
                        <!-- Coloured icon panel (no image on Producer model — show farm icon) --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
                        <div class="pw-card__grower-img pw-card__burst-target @(hasImage ? "pw-card__has-photo" : $"pw-card__no-photo {paletteCls}")"> @* Starts a layout container for this section. *@
                            <!-- Coloured image panel; burst-target triggers particle effect --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Conditional Rendering ----- *@
                            @if (hasImage) @* Conditionally renders this block when the check passes. *@
                            {
 @* ----- Card Layout ----- *@
                                <img class="pw-card__grower-photo" @* Renders an image for the page content. *@
                                     src="@item.ImagePath" @* Renders part of the producers page markup. *@
 @* ----- Producer Display ----- *@
                                     alt="@item.ProducerName" @* Renders part of the producers page markup. *@
                                     loading="lazy" /> @* Renders part of the producers page markup. *@
                            }
 @* ----- Conditional Rendering ----- *@
                            else @* Renders the fallback branch for the previous condition. *@
                            {
 @* ----- Card Layout ----- *@
                                <div class="pw-card__farm-icon"> @* Starts a layout container for this section. *@
                                    <!-- Large centred farm icon --> @* Keeps an existing comment in the Razor file. *@
                                    <i data-lucide="warehouse" style="width:40px;height:40px;stroke:rgba(255,255,255,.92);stroke-width:1.5;"></i> <!-- Warehouse icon --> @* Renders part of the producers page markup. *@
                                </div> @* Closes the matching HTML element. *@
                            }
                            <!-- sticker sits inside the panel at top --> @* Keeps an existing comment in the Razor file. *@
                            <div class="pw-card__sticker"> @* Starts a layout container for this section. *@
                                <!-- Small sticker badge --> @* Keeps an existing comment in the Razor file. *@
                                <i data-lucide="@floatIcon" style="width:10px;height:10px;"></i> <!-- Cycled icon --> @* Renders part of the producers page markup. *@
                                Local Farm @* Renders part of the producers page markup. *@
                            </div> @* Closes the matching HTML element. *@
                            <div class="pw-card__img-badge"> @* Starts a layout container for this section. *@
                                <!-- Badge row at bottom of panel --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                                <span class="pw-badge pw-badge--green" style="font-size:.62rem;padding:2px 7px;"> @* Renders inline text or badge content. *@
                                    <!-- Verified badge --> @* Keeps an existing comment in the Razor file. *@
                                    <i data-lucide="check-circle" style="width:10px;height:10px;"></i> <!-- Check icon --> @* Renders part of the producers page markup. *@
                                    Verified @* Renders part of the producers page markup. *@
                                </span> @* Closes the matching HTML element. *@
 @* ----- Conditional Rendering ----- *@
                                @if (item.IsVATRegistered) // Only show VAT badge if registered @* Conditionally renders this block when the check passes. *@
                                {
 @* ----- Producer Display ----- *@
                                    <span class="pw-badge pw-badge--purple" style="font-size:.62rem;padding:2px 7px;">VAT Reg.</span> <!-- VAT registered badge --> @* Renders inline text or badge content. *@
                                }
                            </div> @* Closes the matching HTML element. *@
 @* ----- Card Layout ----- *@
                            <div class="pw-card__img-number">@idx.ToString("D2")</div> <!-- Zero-padded card number --> @* Starts a layout container for this section. *@
                        </div> @* Closes the matching HTML element. *@

                        <!-- Body --> @* Keeps an existing comment in the Razor file. *@
                        <div class="pw-card__body"> @* Starts a layout container for this section. *@
                            <!-- Card text content --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Page Header ----- *@
                            <h3 class="pw-card__producer-name">@item.ProducerName</h3> <!-- Producer name --> @* Renders a heading for this page section. *@

 @* ----- Card Layout ----- *@
                            <p class="pw-card__email"> @* Renders paragraph text for the user. *@
                                <!-- Email row --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                                <i data-lucide="mail" class="pw-icon-sm pw-icon-muted"></i> <!-- Mail icon --> @* Renders part of the producers page markup. *@
 @* ----- Producer Display ----- *@
                                @item.ProducerEmail <!-- Producer email --> @* Outputs Razor data or executes Razor logic. *@
                            </p> @* Closes the matching HTML element. *@

 @* ----- Conditional Rendering ----- *@
                            @if (!string.IsNullOrWhiteSpace(item.ProducerInformation)) // Only show bio if one exists @* Conditionally renders this block when the check passes. *@
                            {
 @* ----- Card Layout ----- *@
                                <p class="pw-card__info">"@item.ProducerInformation"</p> <!-- Producer bio in quotes --> @* Renders paragraph text for the user. *@
                            }

                            <div class="pw-card__meta"> @* Starts a layout container for this section. *@
