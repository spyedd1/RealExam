    <div class="gw-blob gw-blob--lime" aria-hidden="true"></div> <!-- Decorative lime blob --> @* Starts a layout container for this section. *@
    <div class="gw-blob gw-blob--peach" aria-hidden="true"></div> <!-- Decorative peach blob --> @* Starts a layout container for this section. *@
    <!-- Floating sticker badges --> @* Keeps an existing comment in the Razor file. *@
