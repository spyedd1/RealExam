 @* ----- Form Actions ----- *@
    <link rel="stylesheet" href="~/css/pages/producers/ProducersCreate.css" /> @* Renders one list item. *@
}

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial"); // Renders part of the producers page markup.
    }
 @* ----- Form Actions ----- *@
    <script src="~/js/pages/producers/ProducersCreate.js"></script> @* Starts client-side script for this page. *@
