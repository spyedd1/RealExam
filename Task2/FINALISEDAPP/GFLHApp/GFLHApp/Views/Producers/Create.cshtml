 @* ----- Styling Section ----- *@
                        <span id="nameError" class="pw-field__error"></span> @* Renders inline text or badge content. *@
                    </div> @* Closes the matching HTML element. *@
                </div> @* Closes the matching HTML element. *@

                <div class="pw-form-section"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                    <p class="pw-form-section__label">Contact</p> @* Renders paragraph text for the user. *@
 @* ----- Styling Section ----- *@
                    <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                        <label asp-for="ProducerEmail">Email address <span class="pw-field__req" aria-hidden="true">*</span></label> @* Renders a label tied to the model field. *@
                        <input asp-for="ProducerEmail" class="pw-input" id="producerEmail" @* Binds this input to the matching model property. *@
 @* ----- Identity Account ----- *@
                               type="email" placeholder="hello@example.com" autocomplete="email" /> @* Renders part of the producers page markup. *@
 @* ----- Status Messages ----- *@
                        <span asp-validation-for="ProducerEmail" class="pw-field__error"></span> @* Shows validation feedback for this model field. *@
 @* ----- Identity Account ----- *@
                        <span id="emailError" class="pw-field__error"></span> @* Renders inline text or badge content. *@
 @* ----- Card Layout ----- *@
                        <span class="pw-field__hint">Used for login, order notifications, and grower communications.</span> @* Renders inline text or badge content. *@
                    </div> @* Closes the matching HTML element. *@
                </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
                <div class="pw-form-section"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                    <p class="pw-form-section__label">About</p> @* Renders paragraph text for the user. *@
 @* ----- Styling Section ----- *@
                    <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                        <label asp-for="ProducerInformation">Bio / description <span class="pw-field__req" aria-hidden="true">*</span></label> @* Renders a label tied to the model field. *@
                        <textarea asp-for="ProducerInformation" class="pw-textarea" id="producerInfo" @* Renders a multi-line text input. *@
 @* ----- Card Layout ----- *@
                                  placeholder="Tell customers about your farm, growing practices, certifications..." @* Renders part of the producers page markup. *@
                                  rows="5"></textarea> @* Renders part of the producers page markup. *@
 @* ----- Status Messages ----- *@
                        <span asp-validation-for="ProducerInformation" class="pw-field__error"></span> @* Shows validation feedback for this model field. *@
 @* ----- Styling Section ----- *@
                        <span id="infoError" class="pw-field__error"></span> @* Renders inline text or badge content. *@
 @* ----- Producer Display ----- *@
                        <span class="pw-field__hint">Shown on the public producer page. Use 10 to 500 characters.</span> @* Renders inline text or badge content. *@
                    </div> @* Closes the matching HTML element. *@
                </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
                <div class="pw-form-section"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                    <p class="pw-form-section__label">Image</p> @* Renders paragraph text for the user. *@
 @* ----- Card Layout ----- *@
                    <div class="pw-form-row"> @* Starts a layout container for this section. *@
 @* ----- Styling Section ----- *@
                        <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                            <label for="imageUpload">Upload producer image</label> @* Renders text identifying a form field. *@
                            <input type="file" id="imageUpload" name="imageUpload" class="pw-file" accept=".jpg,.jpeg,.png,.webp" /> @* Renders a user input field. *@
 @* ----- Form Actions ----- *@
                            <span class="pw-field__hint">Upload a JPG, PNG, or WebP image up to 5 MB. Files save to /images/producers.</span> @* Renders inline text or badge content. *@
 @* ----- Styling Section ----- *@
                            <span id="imageError" class="pw-field__error"></span> @* Renders inline text or badge content. *@
                            <span class="pw-field__error">@Html.ValidationMessage("imageUpload")</span> @* Renders inline text or badge content. *@
                        </div> @* Closes the matching HTML element. *@

                        <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                            <label asp-for="ImagePath">Or choose an existing producer image</label> @* Renders a label tied to the model field. *@
 @* ----- Page Model Setup ----- *@
                            <select asp-for="ImagePath" class="pw-select" id="liveImagePathInput" asp-items="ViewBag.ExistingImages"> @* Binds this input to the matching model property. *@
                                <option value="">No existing image selected</option> @* Renders one dropdown option. *@
                            </select> @* Closes the matching HTML element. *@
 @* ----- Status Messages ----- *@
                            <span asp-validation-for="ImagePath" class="pw-field__error"></span> @* Shows validation feedback for this model field. *@
                        </div> @* Closes the matching HTML element. *@
                    </div> @* Closes the matching HTML element. *@
                </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
                <div class="pw-form-section"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
