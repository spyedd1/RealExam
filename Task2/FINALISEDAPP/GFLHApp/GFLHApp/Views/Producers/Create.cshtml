                    <li><a asp-controller="Producers" asp-action="Index">Growers</a></li> @* Builds a link or form target using MVC routing. *@
 @* ----- Form Actions ----- *@
                    <li><span aria-current="page">Create</span></li> @* Renders one list item. *@
                </ol> @* Closes the matching HTML element. *@
            </nav> @* Closes the matching HTML element. *@
 @* ----- Styling Section ----- *@
            <div class="pw-admin-header__title"> @* Starts a layout container for this section. *@
                <div class="pw-admin-header__icon" aria-hidden="true"> @* Starts a layout container for this section. *@
                    <i data-lucide="user-plus" style="width:20px;height:20px;stroke-width:2"></i> @* Renders part of the producers page markup. *@
                </div> @* Closes the matching HTML element. *@
                <div> @* Starts a layout container for this section. *@
 @* ----- Page Header ----- *@
                    <h1>Create producer</h1> @* Renders a heading for this page section. *@
 @* ----- Card Layout ----- *@
                    <p>Add a new grower account, profile, and image.</p> @* Renders paragraph text for the user. *@
                </div> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
