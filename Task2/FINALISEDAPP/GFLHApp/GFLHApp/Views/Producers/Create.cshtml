 @* ----- Card Layout ----- *@
            <div class="pw-form-card"> @* Starts a layout container for this section. *@
 @* ----- Status Messages ----- *@
                <div asp-validation-summary="ModelOnly" class="pw-form-errors" hidden></div> @* Shows page-level validation messages. *@

 @* ----- Styling Section ----- *@
                <div class="pw-form-section"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                    <p class="pw-form-section__label">Identity</p> @* Renders paragraph text for the user. *@
 @* ----- Styling Section ----- *@
                    <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                        <label asp-for="ProducerName">Producer / business name <span class="pw-field__req" aria-hidden="true">*</span></label> @* Renders a label tied to the model field. *@
                        <input asp-for="ProducerName" class="pw-input" id="producerName" @* Binds this input to the matching model property. *@
                               placeholder="e.g. Green Valley Farm" autocomplete="organization" /> @* Renders part of the producers page markup. *@
 @* ----- Status Messages ----- *@
