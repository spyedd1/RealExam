 @* ----- Conditional Rendering ----- *@
                            <span class="pw-field__error">@Html.ValidationMessage("AccountPassword")</span> @* Renders inline text or badge content. *@
                        </div> @* Closes the matching HTML element. *@

 @* ----- Styling Section ----- *@
                        <div class="pw-field"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                            <label for="confirmPassword">Confirm password <span class="pw-field__req" aria-hidden="true">*</span></label> @* Renders text identifying a form field. *@
                            <input type="password" id="confirmPassword" class="pw-input" @* Renders a user input field. *@
 @* ----- Identity Account ----- *@
                                   placeholder="Re-enter password" autocomplete="new-password" /> @* Renders part of the producers page markup. *@
 @* ----- Order Display ----- *@
