<!-- ═══════════════════════════════════════════════════════ @* Keeps an existing comment in the Razor file. *@
 @* ----- Producer Display ----- *@
     PRODUCE FROM THIS PRODUCER @* Renders part of the producers page markup. *@
════════════════════════════════════════════════════════ --> @* Renders part of the producers page markup. *@
 @* ----- Form Fields ----- *@
<section class="pd-produce" aria-labelledby="produce-heading"> @* Renders part of the producers page markup. *@
 @* ----- Product Display ----- *@
    <!-- Products section --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
    <div class="pw-container"> @* Starts a layout container for this section. *@
        <!-- Centred container --> @* Keeps an existing comment in the Razor file. *@

        <div class="pw-section__header reveal reveal--blur"> @* Starts a layout container for this section. *@
            <!-- Section header, animates in with blur --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Card Layout ----- *@
            <span class="pw-section__eyebrow" style="color:#15803d;"> @* Renders inline text or badge content. *@
 @* ----- Form Fields ----- *@
                <!-- Eyebrow label --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Styling Section ----- *@
                <i data-lucide="sprout" class="pw-icon-sm"></i> <!-- Sprout icon --> @* Renders part of the producers page markup. *@
                Straight from the source @* Renders part of the producers page markup. *@
            </span> @* Closes the matching HTML element. *@
 @* ----- Page Header ----- *@
            <h2 class="pw-section__title" id="produce-heading"> @* Renders a heading for this page section. *@
                <!-- Section heading --> @* Keeps an existing comment in the Razor file. *@
                Produce from<br> @* Renders part of the producers page markup. *@
 @* ----- Loop Rendering ----- *@
                <em class="pw-text--green">@Model.ProducerName</em> <!-- Producer name in green --> @* Displays or uses data from the producers model. *@
            </h2> @* Closes the matching HTML element. *@
 @* ----- Conditional Rendering ----- *@
            @if (productCount > 0) // Only show subtitle if there are products @* Conditionally renders this block when the check passes. *@
            {
 @* ----- Styling Section ----- *@
                <p class="pw-section__subtitle"> @* Renders paragraph text for the user. *@
 @* ----- Card Layout ----- *@
                    <!-- Product count summary --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Conditional Rendering ----- *@
                    @productCount product@(productCount != 1 ? "s" : "") listed · @availCount available now <!-- Pluralised counts --> @* Outputs Razor data or executes Razor logic. *@
                </p> @* Closes the matching HTML element. *@
            }
        </div> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
        @if (products.Any()) // Render product grid if products exist @* Conditionally renders this block when the check passes. *@
        {
            <div class="pw-grid pw-grid--3"> @* Starts a layout container for this section. *@
                <!-- 3-column product grid --> @* Keeps an existing comment in the Razor file. *@
                @{
                    int pi = 0; // Renders part of the producers page markup.
 // ----- Product Display -----
                } <!-- Product index for gradient/delay cycling --> 
 @* ----- Loop Rendering ----- *@
                @foreach (var p in products) // Loop through each product @* Loops through the collection and renders each item. *@
                {
                    var grad = prodGradients[pi % prodGradients.Length]; // Pick gradient by index @* Renders part of the producers page markup. *@
 @* ----- Search and Filters ----- *@
                    var icon = CategoryIcon(p.Category);                 // Icon based on category @* Renders part of the producers page markup. *@
                    var delay = (pi % 3) * 120;                           // Staggered delay: 0, 120, 240ms @* Renders part of the producers page markup. *@
 @* ----- Basket Display ----- *@
                    var inStock = p.Available && p.QuantityInStock > 0;     // Whether product is in stock @* Renders part of the producers page markup. *@
 @* ----- Card Layout ----- *@
                    pi++; // Increment index for next card @* Renders part of the producers page markup. *@

                    <article class="pd-product-card reveal reveal--pop" data-delay="@delay"> @* Renders a navigation link or action link. *@
                        <!-- Product card --> @* Keeps an existing comment in the Razor file. *@

                        <div class="pd-product-card__img-wrap"> @* Starts a layout container for this section. *@
                            <!-- Image/fallback wrapper --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Conditional Rendering ----- *@
                            @if (!string.IsNullOrWhiteSpace(p.ImagePath)) // Show image if path exists @* Conditionally renders this block when the check passes. *@
                            {
 @* ----- Card Layout ----- *@
                                <img class="pd-product-card__img" @* Renders an image for the page content. *@
                                     src="@p.ImagePath" @* Renders part of the producers page markup. *@
 @* ----- Product Display ----- *@
                                     alt="@p.ItemName" @* Renders part of the producers page markup. *@
                                     loading="lazy"> <!-- Lazy-loaded product image --> @* Renders part of the producers page markup. *@
                            }
 @* ----- Search and Filters ----- *@
                            else // No image — show gradient + category icon instead @* Renders the fallback branch for the previous condition. *@
                            {
 @* ----- Card Layout ----- *@
                                <div class="pd-product-card__no-img" style="background:@grad;"> @* Starts a layout container for this section. *@
                                    <!-- Gradient fallback --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Search and Filters ----- *@
                                    <i data-lucide="@icon"></i> <!-- Category icon --> @* Renders part of the producers page markup. *@
