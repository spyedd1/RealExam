 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model IEnumerable<GFLHApp.Models.Orders>
 @* ----- Imports and Services ----- *@
 @* Imports a namespace for this Razor file. *@
@using System.Linq
@{
 // ----- Page Model Setup -----
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Chooses the layout used to render this page.
    ViewData["Title"] = "Orders"; // Sets the browser and page title for this view.
    ViewData["AdminSection"] = "orders"; // Reads view data supplied by the controller.
    string search  = ViewBag.Search  ?? ""; // Reads view data supplied by the controller.
    string oStatus = ViewBag.OrderStatus   ?? ""; // Reads view data supplied by the controller.
    string tStatus = ViewBag.TrackingStatus ?? ""; // Reads view data supplied by the controller.
    string sort    = ViewBag.Sort    ?? "newest"; // Reads view data supplied by the controller.
}



 @* ----- Search and Filters ----- *@
<!-- Filters --> @* Keeps an existing comment in the Razor file. *@
 @* ----- Form Setup ----- *@
<form method="get" action="/AdminDashboard/Orders"> @* Starts the form that submits this page's user input. *@
 @* ----- Search and Filters ----- *@
    <div class="adm-filters"> @* Starts a layout container for this section. *@
        <div class="adm-filter-group"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <label>Search</label> @* Renders text identifying a form field. *@
            <input name="search" class="adm-filter-input" value="@search" placeholder="Order # or user ID…" style="width:200px;" /> @* Renders a user input field. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Search and Filters ----- *@
        <div class="adm-filter-group"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <label>Order status</label> @* Renders text identifying a form field. *@
            <select name="orderStatus" class="adm-filter-select"> @* Renders a dropdown selection field. *@
 @* ----- Card Layout ----- *@
                <option value="">All statuses</option> @* Renders one dropdown option. *@
 @* ----- Form Actions ----- *@
                @foreach (var s in new[]{"Pending","Accepted","Partially Complete","Cancelled"}) @* Loops through the collection and renders each item. *@
 @* ----- Card Layout ----- *@
                { <option value="@s" selected="@(oStatus == s)">@s</option> } @* Renders part of the admin dashboard page markup. *@
            </select> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Search and Filters ----- *@
        <div class="adm-filter-group"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <label>Tracking</label> @* Renders text identifying a form field. *@
            <select name="trackingStatus" class="adm-filter-select"> @* Renders a dropdown selection field. *@
                <option value="">All tracking</option> @* Renders one dropdown option. *@
 @* ----- Form Actions ----- *@
                @foreach (var s in new[]{"Preparing Delivery","Awaiting Confirmation","Delivered","Collecting","Cancelled"}) @* Loops through the collection and renders each item. *@
 @* ----- Card Layout ----- *@
                { <option value="@s" selected="@(tStatus == s)">@s</option> } @* Renders part of the admin dashboard page markup. *@
            </select> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Search and Filters ----- *@
        <div class="adm-filter-group"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <label>Sort</label> @* Renders text identifying a form field. *@
            <select name="sort" class="adm-filter-select"> @* Renders a dropdown selection field. *@
 @* ----- Search and Filters ----- *@
                <option value="newest"     selected="@(sort=="newest")">Newest first</option> @* Renders one dropdown option. *@
                <option value="oldest"     selected="@(sort=="oldest")">Oldest first</option> @* Renders one dropdown option. *@
                <option value="total_desc" selected="@(sort=="total_desc")">Highest total</option> @* Renders one dropdown option. *@
                <option value="total_asc"  selected="@(sort=="total_asc")">Lowest total</option> @* Renders one dropdown option. *@
            </select> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Form Actions ----- *@
        <button type="submit" class="adm-btn-filter"> @* Renders a button for the user action. *@
 @* ----- Search and Filters ----- *@
            <i data-lucide="search" style="width:13px;height:13px;" aria-hidden="true"></i> @* Renders part of the admin dashboard page markup. *@
            Filter @* Renders part of the admin dashboard page markup. *@
        </button> @* Closes the matching HTML element. *@
        @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(oStatus) || !string.IsNullOrEmpty(tStatus)) @* Conditionally renders this block when the check passes. *@
        {
 @* ----- Form Actions ----- *@
            <a href="/AdminDashboard/Orders" class="adm-btn-clear"> @* Renders a navigation link or action link. *@
                <i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i> @* Renders part of the admin dashboard page markup. *@
                Clear @* Renders part of the admin dashboard page markup. *@
            </a> @* Closes the matching HTML element. *@
        }
    </div> @* Closes the matching HTML element. *@
</form> @* Closes the form after its fields and actions. *@

 @* ----- Card Layout ----- *@
<div class="adm-card"> @* Starts a layout container for this section. *@
 @* ----- Loop Rendering ----- *@
    <div class="adm-results-info">@Model.Count() order@(Model.Count() == 1 ? "" : "s") found</div> @* Starts a layout container for this section. *@

    @if (Model.Any()) @* Conditionally renders this block when the check passes. *@
    {
        <div style="overflow-x:auto;"> @* Starts a layout container for this section. *@
 @* ----- Table Layout ----- *@
            <table class="adm-table"> @* Starts a table for structured row data. *@
                <thead> @* Starts the table header section. *@
                    <tr> @* Starts one table row. *@
                        <th>Order</th> @* Renders a table header cell. *@
                        <th>Date</th> @* Renders a table header cell. *@
                        <th>Type</th> @* Renders a table header cell. *@
                        <th>Items</th> @* Renders a table header cell. *@
                        <th>Total</th> @* Renders a table header cell. *@
                        <th>Order status</th> @* Renders a table header cell. *@
                        <th>Tracking</th> @* Renders a table header cell. *@
                        <th>Actions</th> @* Renders a table header cell. *@
                    </tr> @* Closes the matching HTML element. *@
                </thead> @* Closes the matching HTML element. *@
                <tbody> @* Starts the table body section. *@
 @* ----- Loop Rendering ----- *@
                @foreach (var o in Model) @* Loops through the collection and renders each item. *@
                {
 @* ----- Search and Filters ----- *@
                    string obm = (o.OrderStatus ?? "") switch { @* Renders part of the admin dashboard page markup. *@
                        "Accepted"          => "adm-badge--accepted", @* Renders part of the admin dashboard page markup. *@
 @* ----- Form Actions ----- *@
                        "Cancelled"         => "adm-badge--cancelled", @* Renders part of the admin dashboard page markup. *@
                        "Partially Complete"=> "adm-badge--partial", @* Renders part of the admin dashboard page markup. *@
                        _                   => "adm-badge--pending" @* Renders part of the admin dashboard page markup. *@
                    };
 @* ----- Search and Filters ----- *@
                    string tbm = (o.TrackingStatus ?? "") switch { @* Renders part of the admin dashboard page markup. *@
                        var t when t.Contains("Delivered") => "adm-badge--accepted", @* Renders part of the admin dashboard page markup. *@
 @* ----- Order Display ----- *@
                        var t when t.Contains("Awaiting")  => "adm-badge--delivery", @* Renders part of the admin dashboard page markup. *@
                        var t when t.Contains("Preparing") => "adm-badge--pending", @* Renders part of the admin dashboard page markup. *@
 @* ----- Form Actions ----- *@
                        _                                   => "adm-badge--cancelled" @* Renders part of the admin dashboard page markup. *@
                    };
 @* ----- Table Layout ----- *@
                    <tr> @* Starts one table row. *@
                        <td><strong>#@o.OrdersId</strong></td> @* Renders a table data cell. *@
                        <td style="white-space:nowrap;">@o.OrderDate.ToString("d MMM yyyy")</td> @* Renders a table data cell. *@
                        <td> @* Renders a table data cell. *@
 @* ----- Conditional Rendering ----- *@
                            @if (o.Delivery)   { <span class="adm-badge adm-badge--delivery">Delivery</span> } @* Conditionally renders this block when the check passes. *@
                            else if (o.Collection) { <span class="adm-badge adm-badge--pending">Collection</span> } @* Renders the fallback branch for the previous condition. *@
                        </td> @* Closes the matching HTML element. *@
 @* ----- Table Layout ----- *@
                        <td>@(o.OrderProducts?.Count ?? 0)</td> @* Renders a table data cell. *@
                        <td style="font-weight:700;">£@o.OrdersTotal.ToString("0.00")</td> @* Renders a table data cell. *@
 @* ----- Search and Filters ----- *@
                        <td><span class="adm-badge @obm">@o.OrderStatus</span></td> @* Renders a table data cell. *@
                        <td><span class="adm-badge @tbm" style="font-size:10px;">@o.TrackingStatus</span></td> @* Renders a table data cell. *@
 @* ----- Table Layout ----- *@
                        <td> @* Renders a table data cell. *@
                            <div style="display:flex;gap:5px;"> @* Starts a layout container for this section. *@
 @* ----- Form Actions ----- *@
                                <a href="/Orders/Details/@o.OrdersId" class="adm-tbl-btn">View</a> @* Renders a navigation link or action link. *@
 @* ----- Navigation ----- *@
                                <form asp-action="UpdateTrackingStatus" method="post" style="display:inline;" id="ts-@o.OrdersId"> @* Starts the form that submits this page's user input. *@
                                    @Html.AntiForgeryToken() @* Uses an HTML helper to render dynamic output. *@
 @* ----- Form Fields ----- *@
                                    <input type="hidden" name="id" value="@o.OrdersId" /> @* Renders a user input field. *@
                                    <select name="status" class="adm-filter-select" style="height:28px;font-size:11px;padding:0 24px 0 6px;" onchange="document.getElementById('ts-@o.OrdersId').submit()"> @* Renders a dropdown selection field. *@
 @* ----- Form Actions ----- *@
                                        @foreach (var ts in new[]{"Preparing Delivery","Awaiting Confirmation","Delivered","Collecting","Cancelled"}) @* Loops through the collection and renders each item. *@
                                        {
 @* ----- Search and Filters ----- *@
                                            <option value="@ts" selected="@(o.TrackingStatus == ts)">@ts</option> @* Renders one dropdown option. *@
                                        }
                                    </select> @* Closes the matching HTML element. *@
                                </form> @* Closes the form after its fields and actions. *@
                            </div> @* Closes the matching HTML element. *@
                        </td> @* Closes the matching HTML element. *@
                    </tr> @* Closes the matching HTML element. *@
                }
                </tbody> @* Closes the matching HTML element. *@
            </table> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    }
 @* ----- Conditional Rendering ----- *@
    else @* Renders the fallback branch for the previous condition. *@
    {
        <div style="padding:48px;text-align:center;color:var(--text-muted);"> @* Starts a layout container for this section. *@
            <i data-lucide="inbox" style="width:40px;height:40px;display:block;margin:0 auto 10px;opacity:.3;" aria-hidden="true"></i> @* Renders part of the admin dashboard page markup. *@
 @* ----- Search and Filters ----- *@
            <p style="font-size:14px;margin:0;">No orders match your filters.</p> @* Renders paragraph text for the user. *@
        </div> @* Closes the matching HTML element. *@
    }
</div> @* Closes the matching HTML element. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
 @* ----- Card Layout ----- *@
    <script src="~/js/pages/admindashboard/AdminDashboardOrders.js" asp-append-version="true"></script>  } @* Starts client-side script for this page. *@

@section Styles { @* Starts a named Razor section rendered by the layout. *@
    <link rel="stylesheet" href="~/css/pages/admindashboard/AdminDashboardOrders.css" asp-append-version="true" /> @* Renders one list item. *@
}
