 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code sign-in"; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.
}

 @* ----- Styling Section ----- *@
<div class="pw-auth-page"> @* Starts a layout container for this section. *@
    <div class="pw-auth-blob pw-auth-blob--1"></div> @* Starts a layout container for this section. *@
    <div class="pw-auth-blob pw-auth-blob--2"></div> @* Starts a layout container for this section. *@

 @* ----- Card Layout ----- *@
    <div class="pw-auth-card"> @* Starts a layout container for this section. *@
        <div class="pw-auth-card__header"> @* Starts a layout container for this section. *@
            <div class="pw-auth-card__brand"> @* Starts a layout container for this section. *@
                <i data-lucide="sprout" style="width:18px;height:18px;stroke-width:2.5"></i> @* Renders part of the identity page markup. *@
                Greenfield @* Renders part of the identity page markup. *@
            </div> @* Closes the matching HTML element. *@
 @* ----- Page Header ----- *@
            <h1 class="pw-auth-card__title">Recovery code</h1> @* Renders a heading for this page section. *@
 @* ----- Form Actions ----- *@
            <p class="pw-auth-card__subtitle">Sign in using a saved recovery code</p> @* Renders paragraph text for the user. *@
        </div> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
        <div class="pw-auth-card__body"> @* Starts a layout container for this section. *@
 @* ----- Order Display ----- *@
            <div style="background:var(--yellow-100);border:1.5px solid #FDE68A;border-radius:var(--r-md);padding:14px 16px;margin-bottom:24px;font-size:13.5px;color:#92400E;display:flex;gap:10px;align-items:flex-start;"> @* Starts a layout container for this section. *@
 @* ----- Status Messages ----- *@
                <i data-lucide="alert-triangle" style="width:17px;height:17px;stroke-width:2;flex-shrink:0;margin-top:1px"></i> @* Renders part of the identity page markup. *@
 @* ----- Identity Account ----- *@
                <span>This sign-in won't be remembered. After signing in, set up your authenticator again to restore full 2FA protection.</span> @* Renders inline text or badge content. *@
            </div> @* Closes the matching HTML element. *@

 @* ----- Form Setup ----- *@
            <form method="post" class="pw-auth-form"> @* Starts the form that submits this page's user input. *@
 @* ----- Status Messages ----- *@
                <div asp-validation-summary="ModelOnly" class="pw-auth-errors" role="alert"></div> @* Shows page-level validation messages. *@

 @* ----- Styling Section ----- *@
                <div class="form-floating mb-4"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
                    <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="xxxx-xxxx" @* Binds this input to the matching model property. *@
                           style="font-family:'JetBrains Mono','Courier New',monospace;letter-spacing:.08em;font-size:16px;font-weight:600;" /> @* Renders part of the identity page markup. *@
                    <label asp-for="Input.RecoveryCode">Recovery code</label> @* Renders a label tied to the model field. *@
 @* ----- Status Messages ----- *@
                    <span asp-validation-for="Input.RecoveryCode" class="pw-auth-field-error"></span> @* Shows validation feedback for this model field. *@
                </div> @* Closes the matching HTML element. *@

 @* ----- Form Actions ----- *@
                <button type="submit" class="pw-btn pw-btn--primary pw-btn--lg pw-auth-submit"> @* Renders a button for the user action. *@
                    <i data-lucide="key" style="width:17px;height:17px;stroke-width:2.5"></i> @* Renders part of the identity page markup. *@
 @* ----- Identity Account ----- *@
                    Sign in with recovery code @* Renders part of the identity page markup. *@
                </button> @* Closes the matching HTML element. *@
            </form> @* Closes the form after its fields and actions. *@
        </div> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
        <div class="pw-auth-card__footer"> @* Starts a layout container for this section. *@
            <div class="pw-auth-link-row"> @* Starts a layout container for this section. *@
 @* ----- Form Setup ----- *@
                <a asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl"> @* Builds a link or form target using MVC routing. *@
 @* ----- Card Layout ----- *@
                    <i data-lucide="arrow-left" style="width:14px;height:14px;stroke-width:2.5;vertical-align:middle;margin-right:4px"></i> @* Renders part of the identity page markup. *@
 @* ----- Identity Account ----- *@
                    Use authenticator code instead @* Renders part of the identity page markup. *@
                </a> @* Closes the matching HTML element. *@
            </div> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@
</div> @* Closes the matching HTML element. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    <partial name="_ValidationScriptsPartial" /> @* Renders a shared partial view here. *@
}
