 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = ManageNavPages.PersonalData; // Reads view data supplied by the controller.
}

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Privacy</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">Personal Data</h2> @* Renders a heading for this page section. *@
 @* ----- Form Actions ----- *@
<p class="pw-manage-content__sub">Your account holds personal data you've shared with us. You can download a copy or permanently delete it.</p> @* Renders paragraph text for the user. *@

<div style="display:flex;flex-direction:column;gap:16px;max-width:560px;"> @* Starts a layout container for this section. *@
 @* ----- Card Layout ----- *@
    <div class="pw-data-card"> @* Starts a layout container for this section. *@
        <div class="pw-data-card__icon pw-data-card__icon--green"> @* Starts a layout container for this section. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> @* Renders part of the identity page markup. *@
        </div> @* Closes the matching HTML element. *@
        <div class="pw-data-card__body"> @* Starts a layout container for this section. *@
 @* ----- Page Header ----- *@
            <h3 class="pw-data-card__title">Download your data</h3> @* Renders a heading for this page section. *@
 @* ----- Card Layout ----- *@
            <p class="pw-data-card__desc">Get a copy of all personal data we hold on your account as a JSON file.</p> @* Renders paragraph text for the user. *@
 @* ----- Form Setup ----- *@
            <form id="download-data" asp-page="DownloadPersonalData" method="post"> @* Starts the form that submits this page's user input. *@
 @* ----- Form Actions ----- *@
                <button class="pw-btn pw-btn--primary pw-btn--sm" type="submit"> @* Renders a button for the user action. *@
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> @* Renders part of the identity page markup. *@
                    Download data @* Renders part of the identity page markup. *@
                </button> @* Closes the matching HTML element. *@
            </form> @* Closes the form after its fields and actions. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Card Layout ----- *@
    <div class="pw-data-card pw-data-card--danger"> @* Starts a layout container for this section. *@
        <div class="pw-data-card__icon pw-data-card__icon--red"> @* Starts a layout container for this section. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg> @* Renders part of the identity page markup. *@
        </div> @* Closes the matching HTML element. *@
        <div class="pw-data-card__body"> @* Starts a layout container for this section. *@
 @* ----- Page Header ----- *@
            <h3 class="pw-data-card__title" style="color:#991B1B;">Delete your account</h3> @* Renders a heading for this page section. *@
 @* ----- Card Layout ----- *@
            <p class="pw-data-card__desc"><strong>This is permanent and cannot be undone.</strong> Deleting your data will close your Greenfield account.</p> @* Renders paragraph text for the user. *@
 @* ----- Form Setup ----- *@
            <a id="delete" asp-page="DeletePersonalData" class="pw-btn pw-btn--danger pw-btn--sm"> @* Builds a link or form target using MVC routing. *@
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg> @* Renders part of the identity page markup. *@
 @* ----- Form Actions ----- *@
                Delete account @* Renders part of the identity page markup. *@
            </a> @* Closes the matching HTML element. *@
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@
</div> @* Closes the matching HTML element. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    <partial name="_ValidationScriptsPartial" /> @* Renders a shared partial view here. *@
}
