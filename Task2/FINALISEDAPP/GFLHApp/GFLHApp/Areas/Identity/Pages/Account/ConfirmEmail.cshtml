 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email confirmed"; // Sets the browser and page title for this view.
    ViewData["FullWidth"] = true; // Reads view data supplied by the controller.
 // ----- Status Messages -----
    var isError = Model.StatusMessage?.StartsWith("Error") == true; // Displays or uses data from the identity model.
}

 @* ----- Styling Section ----- *@
<div class="pw-auth-page"> @* Starts a layout container for this section. *@
    <div class="pw-auth-blob pw-auth-blob--1"></div> @* Starts a layout container for this section. *@
    <div class="pw-auth-blob pw-auth-blob--2"></div> @* Starts a layout container for this section. *@

 @* ----- Card Layout ----- *@
    <div class="pw-auth-card"> @* Starts a layout container for this section. *@
        <div class="pw-auth-card__header"> @* Starts a layout container for this section. *@
            <div class="pw-auth-card__brand"> @* Starts a layout container for this section. *@
                <i data-lucide="sprout" style="width:18px;height:18px;stroke-width:2.5"></i> @* Renders part of the identity page markup. *@
                Greenfield @* Renders part of the identity page markup. *@
            </div> @* Closes the matching HTML element. *@
 @* ----- Page Header ----- *@
            <h1 class="pw-auth-card__title">@(isError ? "Something went wrong" : "Email confirmed")</h1> @* Renders a heading for this page section. *@
 @* ----- Card Layout ----- *@
            <p class="pw-auth-card__subtitle">@(isError ? "We couldn't verify your email" : "Your account is ready to use")</p> @* Renders paragraph text for the user. *@
        </div> @* Closes the matching HTML element. *@

        <div class="pw-auth-card__body"> @* Starts a layout container for this section. *@
 @* ----- Status Messages ----- *@
            @if (!string.IsNullOrEmpty(Model.StatusMessage)) @* Conditionally renders this block when the check passes. *@
            {
 @* ----- Card Layout ----- *@
                <div class="pw-auth-status"> @* Starts a layout container for this section. *@
                    <div class="pw-auth-status__icon @(isError ? "pw-auth-status__icon--danger" : "pw-auth-status__icon--success")"> @* Starts a layout container for this section. *@
 @* ----- Conditional Rendering ----- *@
                        <i data-lucide="@(isError ? "x-circle" : "check-circle-2")" style="width:34px;height:34px;stroke-width:1.75"></i> @* Renders part of the identity page markup. *@
                    </div> @* Closes the matching HTML element. *@
 @* ----- Card Layout ----- *@
                    <p class="pw-auth-status__title">@(isError ? "Confirmation failed" : "You're all set!")</p> @* Renders paragraph text for the user. *@
 @* ----- Status Messages ----- *@
                    <p class="pw-auth-status__body">@Model.StatusMessage</p> @* Renders paragraph text for the user. *@
 @* ----- Conditional Rendering ----- *@
                    @if (!isError) @* Conditionally renders this block when the check passes. *@
                    {
 @* ----- Form Setup ----- *@
                        <a asp-page="./Login" class="pw-btn pw-btn--primary pw-btn--md" style="width:100%;justify-content:center;"> @* Builds a link or form target using MVC routing. *@
                            <i data-lucide="log-in" style="width:16px;height:16px;stroke-width:2.5"></i> @* Renders part of the identity page markup. *@
                            Sign in to Greenfield @* Renders part of the identity page markup. *@
                        </a> @* Closes the matching HTML element. *@
                    }
 @* ----- Conditional Rendering ----- *@
                    else @* Renders the fallback branch for the previous condition. *@
                    {
 @* ----- Form Setup ----- *@
                        <a asp-page="./ResendEmailConfirmation" class="pw-btn pw-btn--outline pw-btn--md" style="width:100%;justify-content:center;"> @* Builds a link or form target using MVC routing. *@
                            <i data-lucide="refresh-cw" style="width:16px;height:16px;stroke-width:2.5"></i> @* Renders part of the identity page markup. *@
 @* ----- Order Display ----- *@
                            Resend confirmation @* Renders part of the identity page markup. *@
                        </a> @* Closes the matching HTML element. *@
                    }
                </div> @* Closes the matching HTML element. *@
            }
        </div> @* Closes the matching HTML element. *@
    </div> @* Closes the matching HTML element. *@
</div> @* Closes the matching HTML element. *@
