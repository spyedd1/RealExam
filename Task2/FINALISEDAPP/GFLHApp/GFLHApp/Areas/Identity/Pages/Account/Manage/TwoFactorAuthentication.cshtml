 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* ----- Imports and Services ----- *@
 @* Imports a namespace for this Razor file. *@
@using Microsoft.AspNetCore.Http.Features
 @* ----- Page Model Setup ----- *@
 @* Sets the model type used by this view. *@
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication; // Reads view data supplied by the controller.
}

 @* ----- Status Messages ----- *@
<partial name="_StatusMessage" for="StatusMessage" /> @* Renders a shared partial view here. *@

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Security</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">Two-Factor Authentication</h2> @* Renders a heading for this page section. *@
 @* ----- Identity Account ----- *@
<p class="pw-manage-content__sub">Add an extra layer of protection by requiring a code alongside your password.</p> @* Renders paragraph text for the user. *@

@{
    var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>(); // Renders part of the identity page markup.
 // ----- Conditional Rendering -----
    @if (consentFeature?.CanTrack ?? true) // Conditionally renders this block when the check passes.
    {
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;flex-wrap:wrap;"> // Starts a layout container for this section.
 // ----- Loop Rendering -----
            @if (Model.Is2faEnabled) // Conditionally renders this block when the check passes.
            {
 // ----- Card Layout -----
                <span class="pw-2fa-status pw-2fa-status--on"> // Renders inline text or badge content.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    2FA Enabled // Renders part of the identity page markup.
                </span> // Closes the matching HTML element.
            }
 // ----- Conditional Rendering -----
            else // Renders the fallback branch for the previous condition.
            {
 // ----- Card Layout -----
                <span class="pw-2fa-status pw-2fa-status--off"> // Renders inline text or badge content.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    2FA Disabled // Renders part of the identity page markup.
                </span> // Closes the matching HTML element.
            }
        </div> // Closes the matching HTML element.

 // ----- Loop Rendering -----
        @if (Model.Is2faEnabled) // Conditionally renders this block when the check passes.
        {
            if (Model.RecoveryCodesLeft == 0) // Displays or uses data from the identity model.
            {
 // ----- Status Messages -----
                <div class="pw-manage-alert pw-manage-alert--danger" role="alert"> // Starts a layout container for this section.
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
 // ----- Form Setup -----
                    <div><strong>You have no recovery codes left.</strong><br>You must <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">generate a new set of recovery codes</a> before you can log in with a recovery code.</div> // Builds a link or form target using MVC routing.
                </div> // Closes the matching HTML element.
            }
 // ----- Loop Rendering -----
            else if (Model.RecoveryCodesLeft == 1) // Renders the fallback branch for the previous condition.
            {
 // ----- Status Messages -----
                <div class="pw-manage-alert pw-manage-alert--danger" role="alert"> // Starts a layout container for this section.
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
 // ----- Form Setup -----
                    <div><strong>You have 1 recovery code left.</strong> <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">Generate new codes</a> now.</div> // Builds a link or form target using MVC routing.
                </div> // Closes the matching HTML element.
            }
 // ----- Loop Rendering -----
            else if (Model.RecoveryCodesLeft <= 3) // Renders the fallback branch for the previous condition.
            {
 // ----- Status Messages -----
                <div class="pw-manage-alert pw-manage-alert--warning" role="alert"> // Starts a layout container for this section.
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
 // ----- Form Setup -----
                    <div><strong>Only @Model.RecoveryCodesLeft recovery codes remaining.</strong> Consider <a asp-page="./GenerateRecoveryCodes" class="pw-link" style="font-size:inherit;">generating a new set</a> soon.</div> // Builds a link or form target using MVC routing.
                </div> // Closes the matching HTML element.
            }

 // ----- Styling Section -----
            <div class="pw-manage-actions"> // Starts a layout container for this section.
 // ----- Loop Rendering -----
                @if (Model.IsMachineRemembered) // Conditionally renders this block when the check passes.
                {
 // ----- Form Setup -----
                    <form method="post" style="display:inline;"> // Starts the form that submits this page's user input.
 // ----- Form Actions -----
                        <button type="submit" class="pw-btn pw-btn--ghost pw-btn--sm"> // Renders a button for the user action.
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
 // ----- Card Layout -----
                            Forget this browser // Renders part of the identity page markup.
                        </button> // Closes the matching HTML element.
                    </form> // Closes the form after its fields and actions.
                }
 // ----- Form Setup -----
                <a asp-page="./Disable2fa" class="pw-btn pw-btn--ghost pw-btn--sm"> // Builds a link or form target using MVC routing.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9.09" y1="9" x2="14.91" y2="9"/><line x1="12" y1="12" x2="12" y2="15"/></svg>
                    Disable 2FA // Renders part of the identity page markup.
                </a> // Closes the matching HTML element.
                <a asp-page="./GenerateRecoveryCodes" class="pw-btn pw-btn--ghost pw-btn--sm"> // Builds a link or form target using MVC routing.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
 // ----- Identity Account -----
                    Reset recovery codes // Renders part of the identity page markup.
                </a> // Closes the matching HTML element.
            </div> // Closes the matching HTML element.
        }

 // ----- Styling Section -----
        <hr class="pw-manage-divider" /> // Renders part of the identity page markup.

 // ----- Page Header -----
        <h3 style="font-family:var(--font-display);font-size:19px;font-weight:700;margin:0 0 16px;color:var(--text);">Authenticator App</h3> // Renders a heading for this page section.

 // ----- Styling Section -----
        <div class="pw-manage-actions"> // Starts a layout container for this section.
 // ----- Loop Rendering -----
            @if (!Model.HasAuthenticator) // Conditionally renders this block when the check passes.
            {
 // ----- Form Setup -----
                <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="pw-btn pw-btn--primary pw-btn--sm"> // Builds a link or form target using MVC routing.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
 // ----- Identity Account -----
                    Add authenticator app // Renders part of the identity page markup.
                </a> // Closes the matching HTML element.
            }
 // ----- Conditional Rendering -----
            else // Renders the fallback branch for the previous condition.
            {
 // ----- Form Setup -----
                <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="pw-btn pw-btn--primary pw-btn--sm"> // Builds a link or form target using MVC routing.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
 // ----- Identity Account -----
                    Set up authenticator app // Renders part of the identity page markup.
                </a> // Closes the matching HTML element.
 // ----- Form Setup -----
                <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="pw-btn pw-btn--ghost pw-btn--sm"> // Builds a link or form target using MVC routing.
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
 // ----- Identity Account -----
                    Reset authenticator // Renders part of the identity page markup.
                </a> // Closes the matching HTML element.
            }
        </div> // Closes the matching HTML element.
    }
 // ----- Conditional Rendering -----
    else // Renders the fallback branch for the previous condition.
    {
 // ----- Status Messages -----
        <div class="pw-manage-alert pw-manage-alert--danger" role="alert"> // Starts a layout container for this section.
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <div><strong>Privacy and cookie policy have not been accepted.</strong><br>You must accept the policy before you can enable two-factor authentication.</div> // Starts a layout container for this section.
        </div> // Closes the matching HTML element.
    }
}

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    <partial name="_ValidationScriptsPartial" /> @* Renders a shared partial view here. *@
}
