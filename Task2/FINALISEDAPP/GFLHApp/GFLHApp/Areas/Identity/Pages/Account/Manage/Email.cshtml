 @* ----- Page Model Setup ----- *@
@page
@* Declares this Razor file as a routable page. *@
 @* Declares this Razor file as a routable page. *@
 @* Sets the model type used by this view. *@
@model EmailModel
@{
    ViewData["Title"] = "Manage Email"; // Sets the browser and page title for this view.
    ViewData["ActivePage"] = ManageNavPages.Email; // Reads view data supplied by the controller.
}

 @* ----- Status Messages ----- *@
<partial name="_StatusMessage" for="StatusMessage" /> @* Renders a shared partial view here. *@

 @* ----- Card Layout ----- *@
<span class="pw-manage-content__eyebrow">Contact</span> @* Renders inline text or badge content. *@
 @* ----- Page Header ----- *@
<h2 class="pw-manage-content__title">Email Address</h2> @* Renders a heading for this page section. *@
 @* ----- Conditional Rendering ----- *@
<p class="pw-manage-content__sub">Your email is used to sign in and receive important account notices.</p> @* Renders paragraph text for the user. *@

 @* ----- Form Setup ----- *@
<form id="email-form" method="post" class="pw-manage-form" style="max-width:480px;"> @* Starts the form that submits this page's user input. *@
 @* ----- Status Messages ----- *@
    <div asp-validation-summary="All" class="pw-manage-alert pw-manage-alert--danger" role="alert"></div> @* Shows page-level validation messages. *@

 @* ----- Loop Rendering ----- *@
    @if (Model.IsEmailConfirmed) @* Conditionally renders this block when the check passes. *@
    {
 @* ----- Form Fields ----- *@
        <div class="pw-email-confirmed" aria-label="Email verified"> @* Starts a layout container for this section. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> @* Renders part of the identity page markup. *@
 @* ----- Identity Account ----- *@
            Verified email @* Renders part of the identity page markup. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Styling Section ----- *@
        <div class="form-floating mb-3"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <input asp-for="Email" class="form-control" placeholder="Email" disabled /> @* Binds this input to the matching model property. *@
            <label asp-for="Email">Current email</label> @* Renders a label tied to the model field. *@
        </div> @* Closes the matching HTML element. *@
    }
 @* ----- Conditional Rendering ----- *@
    else @* Renders the fallback branch for the previous condition. *@
    {
 @* ----- Status Messages ----- *@
        <div class="pw-manage-alert pw-manage-alert--warning" role="alert"> @* Starts a layout container for this section. *@
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> @* Renders part of the identity page markup. *@
 @* ----- Form Setup ----- *@
            <span>Your email is not verified. <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="pw-link" style="background:none;border:none;padding:0;cursor:pointer;font-size:inherit;">Send verification email</button></span> @* Builds a link or form target using MVC routing. *@
        </div> @* Closes the matching HTML element. *@
 @* ----- Styling Section ----- *@
        <div class="form-floating mb-3"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
            <input asp-for="Email" class="form-control" placeholder="Email" disabled /> @* Binds this input to the matching model property. *@
            <label asp-for="Email">Current email</label> @* Renders a label tied to the model field. *@
        </div> @* Closes the matching HTML element. *@
    }

 @* ----- Styling Section ----- *@
    <div class="form-floating mb-4"> @* Starts a layout container for this section. *@
 @* ----- Form Fields ----- *@
        <input asp-for="Input.NewEmail" class="form-control" autocomplete="email" aria-required="true" placeholder="New email address" /> @* Binds this input to the matching model property. *@
        <label asp-for="Input.NewEmail">New email address</label> @* Renders a label tied to the model field. *@
 @* ----- Status Messages ----- *@
        <span asp-validation-for="Input.NewEmail" class="text-danger"></span> @* Shows validation feedback for this model field. *@
    </div> @* Closes the matching HTML element. *@

 @* ----- Form Setup ----- *@
    <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="pw-btn pw-btn--primary pw-btn--md" style="width:100%;"> @* Builds a link or form target using MVC routing. *@
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> @* Renders part of the identity page markup. *@
 @* ----- Form Actions ----- *@
        Update email @* Renders part of the identity page markup. *@
    </button> @* Closes the matching HTML element. *@
</form> @* Closes the form after its fields and actions. *@

 @* ----- Script Section ----- *@
@section Scripts { @* Starts a named Razor section rendered by the layout. *@
    <partial name="_ValidationScriptsPartial" /> @* Renders a shared partial view here. *@
}
