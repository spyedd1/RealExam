    sup { position: relative; font-size: .75em; top: -.5em; }

    /* ── Section: Hero ────────────────────────────────────────────── */
    .section-hero {
        min-height: 700px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url('/assets/images/landing/home/hero/bg-hero.webp');
        background-repeat: no-repeat;
        background-position: center bottom;
        background-size: cover;
        position: relative;
        overflow: hidden;
    }
    .section-hero::before {
        content: "";
        height: 100%;
        width: 100%;
        background: linear-gradient(100deg, #005536 25.84%, rgba(0,85,54,.6) 48.37%, rgba(0,85,54,0) 70.81%);
        position: absolute;
        top: 0; left: 0;
    }
    .section-hero::after {
        content: "";
        height: 100%;
        width: 100%;
        background-image: url('/assets/images/landing/home/hero/pattern.svg');
        background-repeat: no-repeat;
        background-position: left -50px;
        background-size: contain;
        position: absolute;
        top: 0; left: 0;
    }
    .section-hero .container { position: relative; z-index: 10; }
    .section-hero .title__main { color: #fff; font-family: Fraunces, sans-serif; margin-bottom: 10px; font-size: clamp(2rem, 4vw, var(--font-size-1)); font-weight: 600; }
    .section-hero .title__sub  { color: var(--glh-green-light); font-family: Fraunces, sans-serif; font-size: var(--font-size-3); }
    .section-hero .hero-actions {
        width: 100%;
        position: absolute;
        bottom: 30px; right: 30px;
        z-index: 10;
    }
    .action-btn-wrap { display: flex; gap: 10px; justify-content: flex-end; }
    .section-padding-lg { padding-block: 65px; }

    @@media (max-width: 991px) {
        .section-hero { min-height: auto; text-align: center; align-items: flex-start; display: block; }
        .section-hero .hero-actions { position: relative; bottom: auto; right: auto; padding-bottom: 30px; }
        .action-btn-wrap { justify-content: center; }
    }
    @@media (max-width: 767px) {
        .action-btn-wrap { flex-direction: column; }
    }
    .hero-actions .btn { padding-left: 30px; padding-right: 30px; }

    /* ── Section: Text Banner ─────────────────────────────────────── */
    .text-banner {
        font-size: var(--font-size-1);
        font-weight: 700;
        color: #92519e;
        text-align: center;
        text-transform: uppercase;
        position: relative;
        display: table;
        margin: 50px auto 20px;
        transform: translate(-6ch);
    }
    .text-banner span { color: var(--glh-yellow); font-family: Fraunces, sans-serif; font-weight: 700; position: absolute; left: calc(100% + 20px); top: 0; white-space: nowrap; }
    @@media (max-width: 991px) {
        .text-banner { transform: initial; font-size: var(--font-size-3); }
        .text-banner span { position: relative; top: initial; left: initial; display: block; }
    }

    /* ── Section: Live Local (pink wavy bg) ───────────────────────── */
    .section-live-local {
        background: url('/assets/images/landing/pattern.png') no-repeat center, linear-gradient(90deg, #F3DCD9, #F6C4C3);
        background-size: 100% 100%;
        padding-block: 8vw;
        position: relative;
        margin-bottom: 30px;
    }
    .section-live-local::before {
        content: ""; height: calc(8vw - 30px); width: 100%;
        position: absolute; top: 0; left: 0;
        background-color: #fff;
        -webkit-mask-image: url('/assets/images/landing/bottom-curve.svg');
        mask-image: url('/assets/images/landing/bottom-curve.svg');
        -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
        -webkit-mask-size: 100% 8vw; mask-size: 100% 8vw;
        -webkit-mask-position: bottom; mask-position: bottom;
        z-index: 9;
    }
    .section-live-local::after {
        content: ""; height: calc(8vw - 30px); width: 100%;
        position: absolute; bottom: 0; left: 0;
        background-color: #fff;
        -webkit-mask-image: url('/assets/images/landing/top-curve.svg');
        mask-image: url('/assets/images/landing/top-curve.svg');
        -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
        -webkit-mask-size: 100% calc(8vw - 30px); mask-size: 100% calc(8vw - 30px);
        -webkit-mask-position: bottom; mask-position: bottom;
        z-index: 9;
    }
    .section-live-local .pre-header { color: var(--glh-green-dark); }
    @@media (max-width: 767px) { .section-live-local { text-align: center; } }
    .has-padding-block-5 { padding-block: 60px; }

    /* ── Image grids ──────────────────────────────────────────────── */
    .img-grid { position: relative; }
    .img-grid .img-main {
        width: 70%; object-fit: cover; object-position: center;
        aspect-ratio: 4/5; border-radius: 10px; margin-bottom: 100px;
    }
    .img-grid .img-main-alone {
        width: 70%; height: 376px;
        object-fit: cover; object-position: center;
        aspect-ratio: 4/5; border-radius: 10px; margin-bottom: 166px;
    }
    .img-grid .img-sub {
        width: 50%; object-fit: cover; object-position: center;
        aspect-ratio: 3/2.2; position: absolute; bottom: 0; right: 0;
        border-radius: 20px; background: #fff; padding: 8px;
    }
    .img-grid-badge {
        height: 140px; width: 140px; border-radius: 50%;
        display: grid; place-items: center;
        border: 1px solid var(--glh-orange);
        background: rgba(241,116,65,.3);
        position: absolute; top: 0; right: calc(30% - 100px);
    }
    .img-grid-badge .icon {
        height: 90px; width: 90px; border-radius: 50%;
        display: grid; place-items: center;
        background: var(--glh-orange); color: #fff; font-size: 40px;
    }
    @@media (max-width: 767px) { .img-grid { max-width: 80vw; margin-inline: auto; } }

    /* ── Section: Why ─────────────────────────────────────────────── */
    .section-why { padding-block: 65px; position: relative; }

    /* ── Icon list ────────────────────────────────────────────────── */
    .ul-icon-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: row; gap: 10px; flex-wrap: wrap; }
    .ul-icon-list > li { display: flex; flex-direction: row; align-items: flex-start; gap: 10px; }
    .ul-icon-list.col-2 { width: 100%; display: grid; grid-template-columns: repeat(2,1fr); }
    .list-icon { color: var(--glh-green-dark); font-size: 24px; width: 24px; height: 24px; }

    /* ── Section: Grid info ───────────────────────────────────────── */
    .section-img-grid { padding: 36px 12px; }
    .grid-info-list { display: flex; flex-direction: column; align-items: center; gap: 30px; }
    .grid-info {
        max-width: 800px; display: grid;
        grid-template-columns: repeat(2,1fr); gap: 20px;
    }
    .grid-info .info { text-align: right; }
    .grid-info .info__title { text-transform: uppercase; font-weight: 700; font-size: var(--font-size-3); }
    .grid-info .img { height: 200px; display: flex; overflow: hidden; border-radius: 5px; }
