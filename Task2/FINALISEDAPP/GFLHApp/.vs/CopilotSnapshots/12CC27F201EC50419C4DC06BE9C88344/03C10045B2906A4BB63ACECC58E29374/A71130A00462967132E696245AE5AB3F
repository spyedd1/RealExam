    /* ── Section: How it Works ────────────────────────────────────── */
    .section-how { padding-block: 60px; position: relative; }
    .how-banner {
        background: url('/assets/images/landing/home/how/pattern.svg') no-repeat left center,
                    linear-gradient(90deg, var(--glh-green), var(--glh-green-light));
        padding: 40px; border-radius: 20px; color: #fff; z-index: 9;
    }
    .how-step { text-align: center; position: relative; display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .how-step::before { content: ""; width: 100%; height: 1px; background: var(--glh-orange); position: absolute; top: 24.5px; left: 50%; }
    .how-step.has-no-dash::before { display: none; }
    .how-step .icon { height: 50px; width: 50px; border-radius: 50%; font-size: 32px; font-weight: 600; background: var(--glh-orange); color: #fff; display: grid; place-content: center; position: relative; z-index: 9; }
    .how-step .detail { display: flex; gap: 10px; align-items: center; }
    .how-step .detail .num { flex: 0 0 24px; height: 24px; width: 24px; display: grid; place-content: center; border-radius: 50%; background: var(--glh-orange); color: #fff; font-size: var(--font-size-5); }
    .how-step .detail .text { text-align: center; }
    @@media (max-width: 991px) {
        .how-step::before { display: none; }
        .how-step { gap: 10px; margin-bottom: 24px; }
        .how-step .detail { text-align: left; gap: 10px; align-items: center; }
    }

    /* ── Section: Categories ──────────────────────────────────────── */
    .section-categories { margin-bottom: 36px; }
    .card-category { background: #fff; border-radius: 10px; padding: 12px; }
    .card-category__img { width: 100%; aspect-ratio: 1/1; object-fit: cover; margin-bottom: 10px; border-radius: 10px; }
    .card-category__title { font-family: Inter, sans-serif; font-size: var(--font-size-4); margin-bottom: 0; }
    .card-category .btn { padding-inline: 0; margin: 0; font-weight: 700; font-size: var(--font-size-8); color: var(--glh-green); text-transform: uppercase; letter-spacing: 2px; background: none; border: none; cursor: pointer; }
    @@media (max-width: 991px) { .card-category__img { aspect-ratio: 2/1.4; } }

    /* ── Section: Delivery (blue wavy) ───────────────────────────── */
    .section-delivery {
        background: url('/assets/images/landing/pattern.png') no-repeat center, linear-gradient(90deg, #B8D6EB, #6BB1E2);
        background-size: 100% 100%;
        padding-block: 8vw;
        position: relative;
        margin-bottom: 30px;
    }
    .section-delivery::before { content: ""; height: calc(8vw - 30px); width: 100%; position: absolute; top: 0; left: 0; background-color: #fff; -webkit-mask-image: url('/assets/images/landing/bottom-curve.svg'); mask-image: url('/assets/images/landing/bottom-curve.svg'); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-size: 100% 8vw; mask-size: 100% 8vw; -webkit-mask-position: bottom; mask-position: bottom; z-index: 9; }
    .section-delivery::after  { content: ""; height: calc(8vw - 30px); width: 100%; position: absolute; bottom: 0; left: 0; background-color: #fff; -webkit-mask-image: url('/assets/images/landing/top-curve.svg'); mask-image: url('/assets/images/landing/top-curve.svg'); -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-size: 100% calc(8vw - 30px); mask-size: 100% calc(8vw - 30px); -webkit-mask-position: bottom; mask-position: bottom; z-index: 9; }

    /* ── Section: Testimonials ────────────────────────────────────── */
    .testimonial { padding: 50px 20px 40px 40px; background: #fff; border-radius: 10px; height: 100%; }
    .testimonial blockquote { padding-inline: 20px; color: #483e07; font-weight: 500; font-size: var(--font-size-5); font-style: normal; position: relative; display: inline-block; z-index: 4; margin: 0; }
    .testimonial cite { display: flex; justify-content: flex-end; font-style: normal; }
    .testimonial.is-info    { background: #E1EAEC; }
    .testimonial.is-danger  { background: #F3E4E0; }
    .testimonial.is-success { background: rgba(130,224,189,.2); }
    @@media (max-width: 767px) { .testimonial { margin: 10px; height: auto; } }

    /* ── Grid cards ───────────────────────────────────────────────── */
    .grid-card { aspect-ratio: 1/1; border-radius: 10px; overflow: hidden; position: relative; }
    .grid-card__img { height: 100%; width: 100%; object-fit: cover; object-position: center; }
    .grid-card__detail { text-align: center; position: absolute; top: 0; left: 0; height: 100%; width: 100%; z-index: 1; display: grid; place-content: center; padding: 10px; }
    .grid-card__detail .text { text-align: center; color: #fff; line-height: 1.4; }
    .grid-card .only-text { color: var(--glh-green-dark); font-weight: 500; font-size: var(--font-size-1); height: 100%; width: 100%; display: grid; place-content: center; }
    @@media (max-width: 767px) { .grid-card { aspect-ratio: 1/.6; } }

    /* ── Pre-footer CTA ───────────────────────────────────────────── */
    .pre-footer {
        padding-block: 8vw 30px;
        color: #fff;
        background: url('/assets/images/landing/pattern.png') no-repeat center, linear-gradient(90deg, var(--glh-green), var(--glh-green-light));
        background-size: cover;
        position: relative;
    }
    .pre-footer::before {
        content: ""; height: calc(8vw - 30px); width: 100%;
        position: absolute; top: 0; left: 0;
        background-color: #fff;
        -webkit-mask-image: url('/assets/images/landing/bottom-curve.svg');
        mask-image: url('/assets/images/landing/bottom-curve.svg');
        -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat;
        -webkit-mask-size: 100% 8vw; mask-size: 100% 8vw;
        -webkit-mask-position: bottom; mask-position: bottom;
        z-index: 9;
    }
    .pre-footer .title { font-family: Fraunces, sans-serif; font-size: 32px; margin-bottom: 10px; }
    .pre-footer .title span { color: var(--glh-green-light); }
    @@media (max-width: 767px) { .pre-footer { padding-top: 100px; } }

    /* ── Material icons ───────────────────────────────────────────── */
    .material-symbols-outlined {
        font-family: 'Material Symbols Outlined';
        font-weight: normal; font-style: normal; font-size: 24px;
        line-height: 1; letter-spacing: normal; text-transform: none;
        display: inline-block; white-space: nowrap;
        direction: ltr; -webkit-font-smoothing: antialiased;
    }

    /* ── Fraunces font ────────────────────────────────────────────── */
    .is-tertiary-font { font-family: Poppins, sans-serif; }
    .head-font, .is-head-font { font-family: Fraunces, sans-serif; }

    /* ── Title block ──────────────────────────────────────────────── */
    .title { margin-inline: auto; margin-block: 0 30px; }
    .title.is-center { width: clamp(400px, 50vw, 800px); text-align: center; }
    .title.is-full-width { width: 100%; }
    .title__main { font-family: Fraunces, sans-serif; line-height: 1; color: #323232; font-weight: 600; font-size: clamp(2rem, 4vw, var(--font-size-1)); }
    .title__sub  { font-size: var(--font-size-4); color: #323232; }
    @@media (max-width: 991px) {
        .title.is-center { width: 100%; }
        .title__main { font-size: var(--font-size-2); }
        .title__sub  { font-size: var(--font-size-5); font-weight: 500; }
    }

    /* ── Background patterns ──────────────────────────────────────── */
    .bg-pattern { z-index: -1; }
    .bg-pattern + .container { position: relative; z-index: 9; }
    .bg-pattern-1 { height: 300px; width: 300px; background-image: url('/assets/images/landing/bg-pattern-1.svg'); background-repeat: no-repeat; background-position: left center; background-size: contain; position: absolute; left: 0; bottom: 0; }
    .bg-pattern-2, .bg-pattern-4 { height: 300px; width: 300px; background-image: url('/assets/images/landing/bg-pattern-2.svg'); background-repeat: no-repeat; background-position: right center; background-size: contain; position: absolute; right: 0; bottom: 0; }
