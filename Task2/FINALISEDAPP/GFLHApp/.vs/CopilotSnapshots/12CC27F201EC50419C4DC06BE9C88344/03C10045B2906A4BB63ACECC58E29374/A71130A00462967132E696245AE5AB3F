    /* ── Headings ─────────────────────────────────────────────────── */
    h1, h2, h3, h5 { margin-top: 0; margin-bottom: 6px; font-weight: 500; line-height: 1.2; }
    h2 { font-size: clamp(1.6rem, 2.5vw, 2rem); }
