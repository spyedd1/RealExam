<!-- ════════════════════════════════════════════════════
     FIND YOUR FARMER  (speech-bubble CTA)
════════════════════════════════════════════════════ -->
<section class="gw-cta" aria-labelledby="farmer-cta-heading">
    <!-- CTA section -->
    <div class="gw-cta__blob-a" aria-hidden="true"></div> <!-- Decorative blob A -->
    <div class="gw-cta__blob-b" aria-hidden="true"></div> <!-- Decorative blob B -->

    <div class="gw-cta__inner">
        <!-- Inner content wrapper -->
        <div class="gw-cta__bubble reveal reveal--pop">
            <!-- Speech-bubble card, animates in with pop -->
            <!-- Mini farmer avatar row -->
            <div class="gw-cta__farmers-row" aria-hidden="true">
                <!-- Decorative avatar row -->
                <div class="gw-cta__farmer-avatar">
                    <!-- Photo avatar -->
                    <img src="~/images/home/olderLady.jpg" alt=""> <!-- Martha photo -->
                </div>
                <div class="gw-cta__farmer-avatar" style="background:#fef08a;color:#713f12;">T</div> <!-- Initial avatar: T -->
                <div class="gw-cta__farmer-avatar" style="background:#ddd6fe;color:#4c1d95;">S</div> <!-- Initial avatar: S -->
                <div class="gw-cta__farmer-avatar" style="background:#fed7aa;color:#7c2d12;">R</div> <!-- Initial avatar: R -->
                <div class="gw-cta__farmer-avatar">
                    <!-- Photo avatar -->
                    <img src="~/images/home/manwalking.jpg" alt=""> <!-- Tom photo -->
                </div>
            </div>

            <h2 class="gw-cta__bubble-text" id="farmer-cta-heading">
                <!-- Bubble heading -->
                Your perfect farmer is<br>probably <em>on this page</em> right now. <!-- Italic emphasis -->
            </h2>
            <p class="gw-cta__bubble-sub">
                <!-- Bubble subtext -->
                Scroll back up. Pick someone whose story resonates. Then buy their things.
            </p>
        </div>

        <div class="gw-cta__actions reveal" data-delay="160">
            <!-- CTA button row -->
            <a class="pw-btn pw-btn--primary pw-btn--xl"
               asp-area="" asp-controller="Products" asp-action="Index">
                <!-- Link to all products -->
                <i data-lucide="shopping-bag" class="pw-icon-sm"></i> <!-- Bag icon -->
                Shop Their Produce
            </a>
            <a class="pw-btn pw-btn--outline pw-btn--xl" href="#growers-section">
                <!-- Scroll back to grid -->
                <i data-lucide="arrow-up" class="pw-icon-sm"></i> <!-- Up arrow icon -->
                Back to the Farmers
            </a>
        </div>

        <p class="gw-cta__bubble-sub reveal" style="margin-top:1.5rem;font-size:.82rem;" data-delay="260">
            <!-- Small reassurance text -->
            No subscription · No commitment · Just great food from real people
        </p>
    </div>
</section>

