@model GFLHApp.Models.Producers
@{
    ViewData["Title"] = "Create Producer";
    ViewData["FullWidth"] = true;
}

<div class="pw-admin-page">
    <div class="pw-admin-header">
        <div class="pw-admin-header__inner">
            <nav aria-label="Breadcrumb">
                <ol class="pw-admin-breadcrumb">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Producers" asp-action="Index">Growers</a></li>
                    <li><span aria-current="page">Create</span></li>
                </ol>
            </nav>
            <div class="pw-admin-header__title">
                <div class="pw-admin-header__icon" aria-hidden="true">
                    <i data-lucide="user-plus" style="width:20px;height:20px;stroke-width:2"></i>
                </div>
                <div>
                    <h1>Create producer</h1>
                    <p>Add a new grower account, profile, and image.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="pw-admin-body">
        <div class="pw-admin-img-col" aria-hidden="true">
            <div class="pw-admin-img-card" id="adminImgCard">
                <div class="pw-admin-img-placeholder" id="adminImgEl">
                    <i data-lucide="sprout" style="width:72px;height:72px;opacity:.45;"></i>
                </div>
                <div class="pw-admin-img-meta">
                    <p class="pw-admin-img-meta__name" id="adminImgName">New producer</p>
                    <p class="pw-admin-img-meta__path" id="adminImgPath">no image selected</p>
                </div>
            </div>

            <div class="pw-admin-producer-card" id="previewCard" style="margin-top:18px;">
                <div class="pw-admin-producer-card__hero">
                    <div class="pw-admin-producer-card__avatar" id="previewAvatar">?</div>
                    <p class="pw-admin-producer-card__name" id="previewName">Producer name</p>
                    <p class="pw-admin-producer-card__email" id="previewEmail">
                        <i data-lucide="mail" style="width:12px;height:12px;"></i>
                        <span id="previewEmailText">-</span>
                    </p>
                    <span class="pw-admin-producer-card__vat" id="previewVat">
                        <i data-lucide="receipt" style="width:11px;height:11px;"></i>
                        VAT Registered
                    </span>
                </div>
                <div class="pw-admin-producer-card__meta">
                    <div class="pw-admin-producer-card__row">
                        <div class="pw-admin-producer-card__row-icon">
                            <i data-lucide="info" style="width:14px;height:14px;stroke-width:2"></i>
                        </div>
                        <div>
                            <span class="pw-admin-producer-card__row-label">About</span>
                            <span class="pw-admin-producer-card__row-value" id="previewInfo">No bio yet.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="producerForm" novalidate>
            <div class="pw-form-card">
                <div asp-validation-summary="ModelOnly" class="pw-form-errors" hidden></div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">Identity</p>
                    <div class="pw-field">
                        <label asp-for="ProducerName">Producer / business name <span class="pw-field__req" aria-hidden="true">*</span></label>
                        <input asp-for="ProducerName" class="pw-input" id="producerName"
                               placeholder="e.g. Green Valley Farm" autocomplete="organization" />
                        <span asp-validation-for="ProducerName" class="pw-field__error"></span>
                        <span id="nameError" class="pw-field__error"></span>
                    </div>
                </div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">Contact</p>
                    <div class="pw-field">
                        <label asp-for="ProducerEmail">Email address <span class="pw-field__req" aria-hidden="true">*</span></label>
                        <input asp-for="ProducerEmail" class="pw-input" id="producerEmail"
                               type="email" placeholder="hello@example.com" autocomplete="email" />
                        <span asp-validation-for="ProducerEmail" class="pw-field__error"></span>
                        <span id="emailError" class="pw-field__error"></span>
                        <span class="pw-field__hint">Used for login, order notifications, and grower communications.</span>
                    </div>
                </div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">About</p>
                    <div class="pw-field">
                        <label asp-for="ProducerInformation">Bio / description <span class="pw-field__req" aria-hidden="true">*</span></label>
                        <textarea asp-for="ProducerInformation" class="pw-textarea" id="producerInfo"
                                  placeholder="Tell customers about your farm, growing practices, certifications..."
                                  rows="5"></textarea>
                        <span asp-validation-for="ProducerInformation" class="pw-field__error"></span>
                        <span id="infoError" class="pw-field__error"></span>
                        <span class="pw-field__hint">Shown on the public producer page. Use 10 to 500 characters.</span>
                    </div>
                </div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">Image</p>
                    <div class="pw-form-row">
                        <div class="pw-field">
                            <label for="imageUpload">Upload producer image</label>
                            <input type="file" id="imageUpload" name="imageUpload" class="pw-file" accept=".jpg,.jpeg,.png,.webp" />
                            <span class="pw-field__hint">Upload a JPG, PNG, or WebP image up to 5 MB. Files save to /images/producers.</span>
                            <span id="imageError" class="pw-field__error"></span>
                            <span class="pw-field__error">@Html.ValidationMessage("imageUpload")</span>
                        </div>

                        <div class="pw-field">
                            <label asp-for="ImagePath">Or choose an existing producer image</label>
                            <select asp-for="ImagePath" class="pw-select" id="liveImagePathInput" asp-items="ViewBag.ExistingImages">
                                <option value="">No existing image selected</option>
                            </select>
                            <span asp-validation-for="ImagePath" class="pw-field__error"></span>
                        </div>
                    </div>
                </div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">Business &amp; Tax</p>
                    <div class="pw-toggle-row">
                        <div class="pw-toggle-row__info">
                            <strong>VAT registered</strong>
                            <span>Enables VAT display on receipts and producer profile.</span>
                        </div>
                        <label class="pw-toggle" aria-label="Toggle VAT registration">
                            <input asp-for="IsVATRegistered" type="checkbox" role="switch" id="isVATRegistered" />
                            <span class="pw-toggle__track" aria-hidden="true"></span>
                        </label>
                    </div>

                    <div class="pw-vat-field" id="vatNumberGroup">
                        <div class="pw-field">
                            <label asp-for="VATNumber">VAT number</label>
                            <input asp-for="VATNumber" class="pw-input" id="vatNumber"
                                   placeholder="e.g. GB123456789"
                                   autocomplete="off"
                                   style="font-family:'JetBrains Mono','Courier New',monospace;letter-spacing:.05em;" />
                            <span asp-validation-for="VATNumber" class="pw-field__error"></span>
                            <span id="vatError" class="pw-field__error"></span>
                            <span class="pw-field__hint">Format: GB followed by 9 digits.</span>
                        </div>
                    </div>
                </div>

                <div class="pw-form-section">
                    <p class="pw-form-section__label">Account login</p>
                    <div class="pw-form-row">
                        <div class="pw-field">
                            <label for="accountPassword">Password <span class="pw-field__req" aria-hidden="true">*</span></label>
                            <input type="password" name="AccountPassword" class="pw-input"
                                   id="accountPassword" placeholder="Minimum 8 characters" autocomplete="new-password" />
                            <span class="pw-field__hint">Must include uppercase, lowercase, a number, and a special character.</span>
                            <span id="passwordError" class="pw-field__error"></span>
                            <span class="pw-field__error">@Html.ValidationMessage("AccountPassword")</span>
                        </div>

                        <div class="pw-field">
                            <label for="confirmPassword">Confirm password <span class="pw-field__req" aria-hidden="true">*</span></label>
                            <input type="password" id="confirmPassword" class="pw-input"
                                   placeholder="Re-enter password" autocomplete="new-password" />
                            <span id="confirmPasswordError" class="pw-field__error"></span>
                        </div>
                    </div>
                </div>

                <div class="pw-form-actions">
                    <a asp-action="Index" class="pw-btn-back">
                        <i data-lucide="arrow-left" style="width:15px;height:15px;" aria-hidden="true"></i>
                        Back
                    </a>
                    <button type="submit" class="pw-btn-save" id="submitBtn">
                        <i data-lucide="check" style="width:15px;height:15px;" aria-hidden="true"></i>
                        Create producer
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/producers/ProducersEdit.css" />
    <link rel="stylesheet" href="~/css/pages/producers/ProducersCreate.css" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/producers/ProducersCreate.js"></script>
}
