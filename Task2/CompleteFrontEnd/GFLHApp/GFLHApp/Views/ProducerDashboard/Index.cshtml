@model IEnumerable<GFLHApp.Models.Products>
@using System.Linq
@{
    ViewData["Title"] = "Producer Hub";
    ViewData["FullWidth"] = true;

    var producerOrders = (ViewBag.ProducerOrders as IEnumerable<GFLHApp.Models.ProducerOrders>)
                         ?? Enumerable.Empty<GFLHApp.Models.ProducerOrders>();

    string producerName   = ViewBag.ProducerName ?? "Producer";
    int    totalProducts  = (int)(ViewBag.TotalProducts  ?? 0);
    int    lowStockCount  = (int)(ViewBag.LowStockCount  ?? 0);
    int    pendingCount   = (int)(ViewBag.PendingCount   ?? 0);
    decimal totalRevenue  = (decimal)(ViewBag.TotalRevenue      ?? 0m);
    decimal monthRevenue  = (decimal)(ViewBag.ThisMonthRevenue  ?? 0m);

    var today = DateTime.Now;
}

<style>
/* ── Dashboard shell ───────────────────────────────── */
.pw-dash {
    min-height: 100vh;
    background: var(--cream);
}

/* ── Header ────────────────────────────────────────── */
.pw-dash-header {
    background: linear-gradient(160deg, var(--cream) 0%, #f0ebe0 100%);
    border-bottom: 1px solid var(--border);
    padding: 80px 0 28px;
    position: relative;
    overflow: hidden;
}
.pw-dash-header__deco {
    position: absolute; pointer-events: none;
    opacity: .07; color: var(--green);
}
.pw-dash-header__deco--1 { top: 18%; right: 6%;  animation: float-a 8s ease-in-out infinite; }
.pw-dash-header__deco--2 { bottom: 10%; left: 3%; animation: float-b 9s ease-in-out infinite 1s; }

.pw-dash-header__inner {
    max-width: 1200px; margin: 0 auto; padding: 0 28px;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 16px;
    flex-wrap: wrap;
}
.pw-dash-header__left h1 {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 700;
    color: var(--text); margin: 0 0 4px; line-height: 1.2;
}
.pw-dash-header__left p {
    font-size: 14px; color: var(--text-muted); margin: 0;
}
.pw-dash-header__actions { display: flex; gap: 10px; flex-wrap: wrap; }

.pw-btn-primary {
    height: 42px; padding: 0 20px;
    background: var(--green); color: #fff;
    border: none; border-radius: var(--r-sm);
    font-family: var(--font-body); font-size: 14px; font-weight: 700;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 7px;
    transition: background .15s, box-shadow .15s, transform .1s;
    box-shadow: 0 2px 8px rgba(22,163,74,.22);
}
.pw-btn-primary:hover { background: var(--green-700); transform: translateY(-1px); color: #fff; }
.pw-btn-ghost {
    height: 42px; padding: 0 18px;
    background: transparent; color: var(--text-muted);
    border: 1.5px solid var(--border); border-radius: var(--r-sm);
    font-family: var(--font-body); font-size: 14px; font-weight: 600;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 7px;
    transition: border-color .15s, color .15s;
}
.pw-btn-ghost:hover { border-color: var(--text-muted); color: var(--text); }

/* ── Body ──────────────────────────────────────────── */
.pw-dash-body {
    max-width: 1200px; margin: 0 auto;
    padding: 32px 28px 80px;
}

/* ── Stats row ─────────────────────────────────────── */
.pw-stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 36px;
}
@@media (max-width: 900px) { .pw-stats-row { grid-template-columns: repeat(2, 1fr); } }
@@media (max-width: 480px) { .pw-stats-row { grid-template-columns: 1fr; } }

.pw-stat-card {
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 20px;
    display: flex; align-items: center; gap: 16px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow .15s, transform .15s;
}
.pw-stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.pw-stat-card--warn { border-color: #fed7aa; background: #fff7ed; }
.pw-stat-card--danger { border-color: #fecaca; background: #fef2f2; }

.pw-stat-card__icon {
    width: 46px; height: 46px; border-radius: var(--r-md);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.pw-stat-card__icon--green  { background: var(--green-100); color: var(--green); }
.pw-stat-card__icon--orange { background: var(--orange-100); color: var(--orange); }
.pw-stat-card__icon--purple { background: var(--purple-100); color: var(--purple); }
.pw-stat-card__icon--red    { background: #fee2e2; color: #DC2626; }

.pw-stat-card__body { min-width: 0; }
.pw-stat-card__value {
    font-family: var(--font-display);
    font-size: 24px; font-weight: 800; color: var(--text);
    line-height: 1.1;
}
.pw-stat-card__label {
    font-size: 12px; font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .05em;
    margin-top: 2px;
}
.pw-stat-card__sub {
    font-size: 11px; color: var(--text-light); margin-top: 1px;
}

/* ── Main grid ─────────────────────────────────────── */
.pw-dash-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    align-items: start;
}
@@media (max-width: 1000px) { .pw-dash-grid { grid-template-columns: 1fr; } }

/* ── Section card ──────────────────────────────────── */
.pw-section-card {
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}
.pw-section-card__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
    background: var(--cream);
}
.pw-section-card__title {
    font-family: var(--font-display);
    font-size: 15px; font-weight: 700; color: var(--text);
    display: flex; align-items: center; gap: 8px; margin: 0;
}
.pw-section-card__link {
    font-size: 13px; font-weight: 600; color: var(--green);
    text-decoration: none; display: flex; align-items: center; gap: 4px;
}
.pw-section-card__link:hover { color: var(--green-700); }

/* ── Order cards ───────────────────────────────────── */
.pw-order-list { padding: 12px; display: flex; flex-direction: column; gap: 10px; }

.pw-order-card {
    border: 1.5px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--cream);
    transition: box-shadow .15s;
}
.pw-order-card:hover { box-shadow: var(--shadow-sm); }
.pw-order-card--pending { border-color: #fed7aa; }
.pw-order-card--accepted { border-color: var(--green-200); }
.pw-order-card--cancelled { opacity: .6; }

.pw-order-card__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px;
    background: #fff;
    flex-wrap: wrap; gap: 8px;
}
.pw-order-card__id {
    font-family: var(--font-display);
    font-size: 14px; font-weight: 700; color: var(--text);
}
.pw-order-card__date { font-size: 12px; color: var(--text-muted); }

.pw-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; border-radius: var(--r-full);
    font-size: 11px; font-weight: 700; letter-spacing: .03em;
}
.pw-badge--pending  { background: var(--orange-100); color: var(--orange); }
.pw-badge--accepted { background: var(--green-100);  color: var(--green); }
.pw-badge--cancelled{ background: #f3f4f6; color: var(--text-muted); }

.pw-order-card__body { padding: 10px 16px; }
.pw-order-card__products {
    display: flex; flex-direction: column; gap: 4px;
    margin-bottom: 8px;
}
.pw-order-card__product-row {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: var(--text);
}
.pw-order-card__product-img {
    width: 32px; height: 32px; border-radius: 6px;
    object-fit: cover; flex-shrink: 0;
    background: var(--green-100);
}
.pw-order-card__product-placeholder {
    width: 32px; height: 32px; border-radius: 6px;
    background: var(--green-100); color: var(--green);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.pw-order-card__product-name { font-weight: 600; flex: 1; }
.pw-order-card__product-qty  { color: var(--text-muted); font-size: 12px; }

.pw-order-card__foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    background: #fff;
    flex-wrap: wrap; gap: 8px;
}
.pw-order-card__subtotal {
    font-size: 14px; font-weight: 700; color: var(--text);
}
.pw-order-card__actions { display: flex; gap: 8px; }

.pw-btn-accept {
    height: 34px; padding: 0 14px;
    background: var(--green); color: #fff;
    border: none; border-radius: var(--r-sm);
    font-size: 12px; font-weight: 700; cursor: pointer;
    display: inline-flex; align-items: center; gap: 5px;
    transition: background .12s;
}
.pw-btn-accept:hover { background: var(--green-700); }

.pw-btn-cancel-sm {
    height: 34px; padding: 0 14px;
    background: transparent; color: #DC2626;
    border: 1.5px solid #fecaca; border-radius: var(--r-sm);
    font-size: 12px; font-weight: 700; cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 5px;
    transition: background .12s, border-color .12s;
}
.pw-btn-cancel-sm:hover { background: #fef2f2; border-color: #DC2626; color: #DC2626; }

/* ── Products sidebar ──────────────────────────────── */
.pw-product-list { padding: 8px; display: flex; flex-direction: column; gap: 6px; }

.pw-product-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px;
    border-radius: var(--r-sm);
    border: 1.5px solid transparent;
    background: var(--cream);
    transition: border-color .12s, background .12s;
}
.pw-product-row:hover { border-color: var(--border); background: #fff; }
.pw-product-row--low { border-color: #fed7aa !important; background: #fff7ed !important; }

.pw-product-row__img {
    width: 40px; height: 40px; border-radius: var(--r-sm);
    object-fit: cover; flex-shrink: 0;
}
.pw-product-row__placeholder {
    width: 40px; height: 40px; border-radius: var(--r-sm);
    background: var(--green-100); color: var(--green);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.pw-product-row__info { flex: 1; min-width: 0; }
.pw-product-row__name {
    font-size: 13px; font-weight: 600; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.pw-product-row__meta { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

.pw-product-row__actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.pw-edit-link {
    font-size: 12px; font-weight: 600; color: var(--text-muted);
    text-decoration: none; padding: 4px 8px;
    border-radius: 6px;
    transition: background .12s, color .12s;
}
.pw-edit-link:hover { background: var(--green-100); color: var(--green); }

/* ── Availability toggle (inline) ──────────────────── */
.pw-avail-toggle {
    position: relative; display: inline-block;
    width: 38px; height: 21px; flex-shrink: 0;
}
.pw-avail-toggle input { opacity: 0; width: 0; height: 0; position: absolute; }
.pw-avail-toggle__track {
    position: absolute; inset: 0;
    background: var(--border); border-radius: 999px;
    cursor: pointer; transition: background .2s;
}
.pw-avail-toggle__track::after {
    content: ''; position: absolute;
    left: 2px; top: 2px; width: 17px; height: 17px;
    border-radius: 50%; background: #fff;
    box-shadow: 0 1px 3px rgba(0,0,0,.15);
    transition: transform .18s cubic-bezier(.34,1.56,.64,1);
}
.pw-avail-toggle input:checked + .pw-avail-toggle__track { background: var(--green); }
.pw-avail-toggle input:checked + .pw-avail-toggle__track::after { transform: translateX(17px); }
.pw-avail-toggle input:focus-visible + .pw-avail-toggle__track {
    outline: 3px solid var(--green-200); outline-offset: 2px;
}

/* ── Empty state ───────────────────────────────────── */
.pw-empty {
    padding: 48px 24px; text-align: center; color: var(--text-muted);
}
.pw-empty svg { opacity: .3; margin-bottom: 12px; }
.pw-empty p { font-size: 14px; margin: 0; }

/* ── Alert banner ──────────────────────────────────── */
.pw-alert {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 18px;
    border-radius: var(--r-sm);
    font-size: 13px; font-weight: 600;
    margin-bottom: 20px;
}
.pw-alert--warn {
    background: #fff7ed; border: 1.5px solid #fed7aa; color: #92400e;
}
.pw-alert--info {
    background: var(--green-100); border: 1.5px solid var(--green-200); color: var(--green-800);
}
</style>

<div class="pw-dash">

    <!-- ── Header ──────────────────────────────────── -->
    <div class="pw-dash-header">
        <div class="pw-dash-header__deco pw-dash-header__deco--1" aria-hidden="true">
            <i data-lucide="sprout" style="width:90px;height:90px;"></i>
        </div>
        <div class="pw-dash-header__deco pw-dash-header__deco--2" aria-hidden="true">
            <i data-lucide="leaf" style="width:70px;height:70px;"></i>
        </div>
        <div class="pw-dash-header__inner">
            <div class="pw-dash-header__left">
                <p style="font-size:13px;color:var(--text-muted);margin:0 0 6px;">@today.ToString("dddd, d MMMM yyyy")</p>
                <h1>Welcome back, @producerName 🌿</h1>
                <p>Here's how your shop is doing today.</p>
            </div>
            <div class="pw-dash-header__actions">
                <a asp-controller="Products" asp-action="Create" class="pw-btn-primary">
                    <i data-lucide="plus" style="width:15px;height:15px;" aria-hidden="true"></i>
                    Add product
                </a>
                <a asp-controller="Products" asp-action="Index" class="pw-btn-ghost">
                    <i data-lucide="store" style="width:15px;height:15px;" aria-hidden="true"></i>
                    View shop
                </a>
            </div>
        </div>
    </div>

    <div class="pw-dash-body">

        <!-- ── Alerts ──────────────────────────────── -->
        @if (pendingCount > 0)
        {
            <div class="pw-alert pw-alert--warn" role="alert">
                <i data-lucide="clock" style="width:18px;height:18px;flex-shrink:0;" aria-hidden="true"></i>
                You have <strong>@pendingCount pending order@(pendingCount == 1 ? "" : "s")</strong> waiting for your response.
            </div>
        }
        @if (lowStockCount > 0)
        {
            <div class="pw-alert pw-alert--warn" role="alert">
                <i data-lucide="package-open" style="width:18px;height:18px;flex-shrink:0;" aria-hidden="true"></i>
                <strong>@lowStockCount product@(lowStockCount == 1 ? " is" : "s are")</strong> running low on stock — restock soon.
            </div>
        }

        <!-- ── Stats ───────────────────────────────── -->
        <div class="pw-stats-row">
            <div class="pw-stat-card">
                <div class="pw-stat-card__icon pw-stat-card__icon--green">
                    <i data-lucide="box" style="width:20px;height:20px;" aria-hidden="true"></i>
                </div>
                <div class="pw-stat-card__body">
                    <div class="pw-stat-card__value">@totalProducts</div>
                    <div class="pw-stat-card__label">Products</div>
                </div>
            </div>

            <div class="pw-stat-card @(pendingCount > 0 ? "pw-stat-card--warn" : "")">
                <div class="pw-stat-card__icon pw-stat-card__icon--orange">
                    <i data-lucide="clock" style="width:20px;height:20px;" aria-hidden="true"></i>
                </div>
                <div class="pw-stat-card__body">
                    <div class="pw-stat-card__value">@pendingCount</div>
                    <div class="pw-stat-card__label">Pending orders</div>
                    <div class="pw-stat-card__sub">awaiting your response</div>
                </div>
            </div>

            <div class="pw-stat-card">
                <div class="pw-stat-card__icon pw-stat-card__icon--purple">
                    <i data-lucide="pound-sterling" style="width:20px;height:20px;" aria-hidden="true"></i>
                </div>
                <div class="pw-stat-card__body">
                    <div class="pw-stat-card__value">£@monthRevenue.ToString("0.00")</div>
                    <div class="pw-stat-card__label">This month</div>
                    <div class="pw-stat-card__sub">£@totalRevenue.ToString("0.00") all time</div>
                </div>
            </div>

            <div class="pw-stat-card @(lowStockCount > 0 ? "pw-stat-card--danger" : "")">
                <div class="pw-stat-card__icon @(lowStockCount > 0 ? "pw-stat-card__icon--red" : "pw-stat-card__icon--green")">
                    <i data-lucide="@(lowStockCount > 0 ? "alert-triangle" : "check-circle")" style="width:20px;height:20px;" aria-hidden="true"></i>
                </div>
                <div class="pw-stat-card__body">
                    <div class="pw-stat-card__value">@lowStockCount</div>
                    <div class="pw-stat-card__label">Low stock</div>
                    <div class="pw-stat-card__sub">≤5 units remaining</div>
                </div>
            </div>
        </div>

        <!-- ── Main grid ────────────────────────────── -->
        <div class="pw-dash-grid">

            <!-- Orders column -->
            <div class="pw-section-card">
                <div class="pw-section-card__head">
                    <h2 class="pw-section-card__title">
                        <i data-lucide="shopping-bag" style="width:17px;height:17px;" aria-hidden="true"></i>
                        Recent orders
                    </h2>
                    <a asp-action="AllOrders" class="pw-section-card__link">
                        View all <i data-lucide="arrow-right" style="width:13px;height:13px;" aria-hidden="true"></i>
                    </a>
                </div>

                @{
                    var recentOrders = producerOrders.Take(6).ToList();
                }

                @if (!recentOrders.Any())
                {
                    <div class="pw-empty">
                        <i data-lucide="inbox" style="width:48px;height:48px;display:block;margin:0 auto 12px;" aria-hidden="true"></i>
                        <p>No orders yet — your first one will appear here.</p>
                    </div>
                }
                else
                {
                    <div class="pw-order-list">
                        @foreach (var order in recentOrders)
                        {
                            string cardMod = order.TrackingStatus == "Pending"   ? "pw-order-card--pending"
                                           : order.TrackingStatus == "Accepted"  ? "pw-order-card--accepted"
                                           : order.TrackingStatus == "Cancelled" ? "pw-order-card--cancelled"
                                           : "";
                            string badgeMod = order.TrackingStatus == "Pending"   ? "pw-badge--pending"
                                            : order.TrackingStatus == "Accepted"  ? "pw-badge--accepted"
                                            : "pw-badge--cancelled";
                            <div class="pw-order-card @cardMod">
                                <div class="pw-order-card__head">
                                    <div>
                                        <span class="pw-order-card__id">Order #@order.Orders.OrdersId</span>
                                        <span class="pw-order-card__date" style="margin-left:8px;">@order.Orders.OrderDate.ToString("d MMM yyyy")</span>
                                    </div>
                                    <span class="pw-badge @badgeMod">@order.TrackingStatus</span>
                                </div>
                                <div class="pw-order-card__body">
                                    <div class="pw-order-card__products">
                                        @foreach (var item in order.OrderProducts)
                                        {
                                            <div class="pw-order-card__product-row">
                                                @if (!string.IsNullOrEmpty(item.Products?.ImagePath))
                                                {
                                                    <img src="@item.Products.ImagePath" alt="@item.Products.ItemName" class="pw-order-card__product-img" />
                                                }
                                                else
                                                {
                                                    <div class="pw-order-card__product-placeholder">
                                                        <i data-lucide="sprout" style="width:14px;height:14px;" aria-hidden="true"></i>
                                                    </div>
                                                }
                                                <span class="pw-order-card__product-name">@item.Products?.ItemName</span>
                                                <span class="pw-order-card__product-qty">× @item.ProductQuantity</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="pw-order-card__foot">
                                    <span class="pw-order-card__subtotal">£@order.ProducerSubtotal.ToString("0.00")</span>
                                    <div class="pw-order-card__actions">
                                        @if (order.TrackingStatus == "Pending")
                                        {
                                            <form asp-action="AcceptProducerOrder" asp-route-id="@order.ProducerOrdersId" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="pw-btn-accept">
                                                    <i data-lucide="check" style="width:13px;height:13px;" aria-hidden="true"></i>
                                                    Accept
                                                </button>
                                            </form>
                                            <a asp-action="CancelProducerOrder" asp-route-id="@order.ProducerOrdersId" class="pw-btn-cancel-sm">
                                                <i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>
                                                Cancel
                                            </a>
                                        }
                                        else if (order.TrackingStatus == "Accepted")
                                        {
                                            <a asp-action="CancelProducerOrder" asp-route-id="@order.ProducerOrdersId" class="pw-btn-cancel-sm">
                                                <i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>
                                                Cancel
                                            </a>
                                        }
                                        else
                                        {
                                            <span style="font-size:12px;color:var(--text-light);">No actions</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Products column -->
            <div>
                <div class="pw-section-card">
                    <div class="pw-section-card__head">
                        <h2 class="pw-section-card__title">
                            <i data-lucide="package" style="width:17px;height:17px;" aria-hidden="true"></i>
                            My products
                        </h2>
                        <a asp-controller="Products" asp-action="Index" class="pw-section-card__link">
                            Manage all <i data-lucide="arrow-right" style="width:13px;height:13px;" aria-hidden="true"></i>
                        </a>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="pw-empty">
                            <i data-lucide="package-open" style="width:40px;height:40px;display:block;margin:0 auto 10px;" aria-hidden="true"></i>
                            <p>No products yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="pw-product-list">
                            @foreach (var product in Model)
                            {
                                bool isLow = product.QuantityInStock <= 5 && product.Available;
                                <div class="pw-product-row @(isLow ? "pw-product-row--low" : "")">
                                    @if (!string.IsNullOrEmpty(product.ImagePath))
                                    {
                                        <img src="@product.ImagePath" alt="@product.ItemName" class="pw-product-row__img" />
                                    }
                                    else
                                    {
                                        <div class="pw-product-row__placeholder">
                                            <i data-lucide="sprout" style="width:16px;height:16px;" aria-hidden="true"></i>
                                        </div>
                                    }
                                    <div class="pw-product-row__info">
                                        <div class="pw-product-row__name">@product.ItemName</div>
                                        <div class="pw-product-row__meta">
                                            £@product.ItemPrice.ToString("0.00") &middot;
                                            @if (isLow)
                                            {
                                                <span style="color:var(--orange);font-weight:600;">@product.QuantityInStock left</span>
                                            }
                                            else
                                            {
                                                <span>@product.QuantityInStock in stock</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="pw-product-row__actions">
                                        <label class="pw-avail-toggle" title="@(product.Available ? "Listed" : "Hidden")">
                                            <input type="checkbox" @(product.Available ? "checked" : "")
                                                   class="pw-avail-toggle__input"
                                                   data-product-id="@product.ProductsId"
                                                   aria-label="Toggle availability for @product.ItemName" />
                                            <span class="pw-avail-toggle__track" aria-hidden="true"></span>
                                        </label>
                                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.ProductsId"
                                           class="pw-edit-link" title="Edit @product.ItemName">
                                            <i data-lucide="pencil" style="width:13px;height:13px;" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div style="padding:14px 16px;border-top:1px solid var(--border);">
                        <a asp-controller="Products" asp-action="Create" class="pw-btn-primary" style="width:100%;justify-content:center;">
                            <i data-lucide="plus" style="width:15px;height:15px;" aria-hidden="true"></i>
                            Add new product
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        'use strict';

        if (window.lucide) lucide.createIcons();

        var token = document.querySelector('input[name="__RequestVerificationToken"]');

        /* ── Availability toggle ──────────────────────────────── */
        document.querySelectorAll('.pw-avail-toggle__input').forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var productId = checkbox.dataset.productId;
                var row       = checkbox.closest('.pw-product-row');

                /* Optimistic UI */
                var wasChecked = !checkbox.checked;
                checkbox.disabled = true;

                var formData = new FormData();
                formData.append('id', productId);
                if (token) formData.append('__RequestVerificationToken', token.value);

                fetch('/ProducerDashboard/ToggleAvailability', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token ? token.value : '' },
                    body: formData
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (!d.success) {
                        checkbox.checked = wasChecked;
                    }
                    checkbox.disabled = false;
                })
                .catch(function () {
                    checkbox.checked = wasChecked;
                    checkbox.disabled = false;
                });
            });
        });

    }());
    </script>

    @* Hidden anti-forgery token for JS fetch *@
    @Html.AntiForgeryToken()
}
