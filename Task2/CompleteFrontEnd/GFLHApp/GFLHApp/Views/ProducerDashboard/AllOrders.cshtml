@model IEnumerable<GFLHApp.Models.ProducerOrders>
@using System.Linq
@{
    ViewData["Title"] = "All Orders";
    ViewData["FullWidth"] = true;

    var orders        = Model.ToList();
    var pendingList   = orders.Where(o => o.TrackingStatus == "Pending").ToList();
    var acceptedList  = orders.Where(o => o.TrackingStatus == "Accepted").ToList();
    var cancelledList = orders.Where(o => o.TrackingStatus == "Cancelled").ToList();
    decimal totalRevenue = acceptedList.Sum(o => o.ProducerSubtotal);
}

<style>
.pw-admin-page { min-height: 100vh; background: var(--cream); }

.pw-admin-header {
    background: linear-gradient(160deg, var(--cream) 0%, #f0ebe0 100%);
    border-bottom: 1px solid var(--border);
    padding: 80px 0 28px;
}
.pw-admin-header__inner {
    max-width: 1100px; margin: 0 auto; padding: 0 24px;
    display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap;
}
.pw-admin-breadcrumb {
    display: flex; align-items: center; gap: 6px;
    list-style: none; margin: 0 0 14px; padding: 0;
    font-size: 13px; font-weight: 500;
}
.pw-admin-breadcrumb li { display: flex; align-items: center; gap: 6px; }
.pw-admin-breadcrumb li + li::before { content: '/'; color: var(--text-muted); opacity: .5; }
.pw-admin-breadcrumb a { color: var(--text-muted); transition: color .15s; text-decoration: none; }
.pw-admin-breadcrumb a:hover { color: var(--green); }
.pw-admin-breadcrumb [aria-current] { color: var(--text); font-weight: 600; }

.pw-admin-header__title {
    display: flex; align-items: center; gap: 14px;
}
.pw-admin-header__icon {
    width: 44px; height: 44px; background: var(--green-100);
    border-radius: var(--r-md);
    display: flex; align-items: center; justify-content: center;
    color: var(--green); flex-shrink: 0;
}
.pw-admin-header__title h1 {
    font-family: var(--font-display);
    font-size: 24px; font-weight: 700; color: var(--text); margin: 0;
}
.pw-admin-header__title p { font-size: 13px; color: var(--text-muted); margin: 2px 0 0; }

.pw-btn-back {
    height: 42px; padding: 0 18px;
    background: transparent; color: var(--text-muted);
    border: 1.5px solid var(--border); border-radius: var(--r-sm);
    font-family: var(--font-body); font-size: 14px; font-weight: 600;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 7px;
    transition: border-color .15s, color .15s;
}
.pw-btn-back:hover { border-color: var(--text-muted); color: var(--text); }

/* ── Body ──────────────────────────────────────────── */
.pw-admin-body {
    max-width: 1100px; margin: 0 auto; padding: 32px 24px 80px;
}

/* ── Summary strip ─────────────────────────────────── */
.pw-orders-summary {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
    margin-bottom: 28px;
}
@@media (max-width: 700px) { .pw-orders-summary { grid-template-columns: repeat(2, 1fr); } }

.pw-summary-chip {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--r-md); padding: 14px 16px;
    display: flex; align-items: center; gap: 10px;
}
.pw-summary-chip__dot {
    width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
}
.pw-summary-chip__dot--pending  { background: var(--orange); }
.pw-summary-chip__dot--accepted { background: var(--green); }
.pw-summary-chip__dot--cancelled{ background: var(--text-light); }
.pw-summary-chip__dot--revenue  { background: var(--purple); }
.pw-summary-chip__val { font-size: 18px; font-weight: 800; color: var(--text); font-family: var(--font-display); }
.pw-summary-chip__lbl { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

/* ── Filter tabs ───────────────────────────────────── */
.pw-filter-tabs {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-bottom: 18px;
}
.pw-tab {
    height: 36px; padding: 0 16px;
    border-radius: var(--r-full);
    border: 1.5px solid var(--border);
    background: #fff;
    font-size: 13px; font-weight: 600; color: var(--text-muted);
    cursor: pointer; transition: all .12s;
}
.pw-tab:hover { border-color: var(--green); color: var(--green); }
.pw-tab.is-active { background: var(--green); border-color: var(--green); color: #fff; }

/* ── Orders grid ───────────────────────────────────── */
.pw-orders-grid {
    display: grid; gap: 14px;
}

.pw-order-card {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--r-md); overflow: hidden;
    transition: box-shadow .15s;
}
.pw-order-card:hover { box-shadow: var(--shadow-md); }
.pw-order-card[data-status="Pending"]  { border-color: #fed7aa; }
.pw-order-card[data-status="Accepted"] { border-color: var(--green-200); }
.pw-order-card[data-status="Cancelled"]{ opacity: .65; }

.pw-order-card__head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px; background: var(--cream);
    border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 8px;
}
.pw-order-card__id {
    font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--text);
}
.pw-order-card__date { font-size: 12px; color: var(--text-muted); }

.pw-badge {
    padding: 3px 10px; border-radius: var(--r-full);
    font-size: 11px; font-weight: 700; letter-spacing: .03em;
    display: inline-flex; align-items: center; gap: 4px;
}
.pw-badge--pending  { background: var(--orange-100); color: var(--orange); }
.pw-badge--accepted { background: var(--green-100);  color: var(--green); }
.pw-badge--cancelled{ background: #f3f4f6; color: var(--text-muted); }

.pw-order-card__body {
    display: flex; align-items: flex-start; gap: 0;
    flex-wrap: wrap;
}
.pw-order-card__products {
    flex: 1; padding: 14px 18px; min-width: 200px;
    display: flex; flex-direction: column; gap: 8px;
}
.pw-order-card__product-row {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px;
}
.pw-order-card__product-img {
    width: 34px; height: 34px; border-radius: 7px;
    object-fit: cover; flex-shrink: 0;
}
.pw-order-card__product-placeholder {
    width: 34px; height: 34px; border-radius: 7px;
    background: var(--green-100); color: var(--green);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}

.pw-order-card__side {
    padding: 14px 18px;
    border-left: 1px solid var(--border);
    min-width: 180px;
    display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; gap: 12px;
}
.pw-order-card__subtotal {
    font-family: var(--font-display); font-size: 20px; font-weight: 800; color: var(--text);
}
.pw-order-card__actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

.pw-btn-accept {
    height: 36px; padding: 0 14px;
    background: var(--green); color: #fff; border: none;
    border-radius: var(--r-sm); font-size: 13px; font-weight: 700; cursor: pointer;
    display: inline-flex; align-items: center; gap: 5px;
    transition: background .12s;
}
.pw-btn-accept:hover { background: var(--green-700); }
.pw-btn-cancel-sm {
    height: 36px; padding: 0 14px;
    background: transparent; color: #DC2626;
    border: 1.5px solid #fecaca; border-radius: var(--r-sm);
    font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 5px;
    transition: background .12s;
}
.pw-btn-cancel-sm:hover { background: #fef2f2; border-color: #DC2626; color: #DC2626; }

/* ── Empty ─────────────────────────────────────────── */
.pw-empty {
    padding: 64px 24px; text-align: center; color: var(--text-muted);
    background: #fff; border: 1.5px solid var(--border); border-radius: var(--r-md);
}
.pw-empty p { font-size: 14px; margin: 0; }
</style>

<div class="pw-admin-page">

    <div class="pw-admin-header">
        <div class="pw-admin-header__inner">
            <div>
                <nav aria-label="Breadcrumb">
                    <ol class="pw-admin-breadcrumb">
                        <li><a asp-action="Index">Dashboard</a></li>
                        <li><span aria-current="page">All orders</span></li>
                    </ol>
                </nav>
                <div class="pw-admin-header__title">
                    <div class="pw-admin-header__icon" aria-hidden="true">
                        <i data-lucide="shopping-bag"></i>
                    </div>
                    <div>
                        <h1>All orders</h1>
                        <p>@orders.Count total &middot; @pendingList.Count pending &middot; £@totalRevenue.ToString("0.00") revenue</p>
                    </div>
                </div>
            </div>
            <a asp-action="Index" class="pw-btn-back">
                <i data-lucide="arrow-left" style="width:15px;height:15px;" aria-hidden="true"></i>
                Dashboard
            </a>
        </div>
    </div>

    <div class="pw-admin-body">

        <!-- Summary -->
        <div class="pw-orders-summary">
            <div class="pw-summary-chip">
                <span class="pw-summary-chip__dot pw-summary-chip__dot--pending"></span>
                <div>
                    <div class="pw-summary-chip__val">@pendingList.Count</div>
                    <div class="pw-summary-chip__lbl">Pending</div>
                </div>
            </div>
            <div class="pw-summary-chip">
                <span class="pw-summary-chip__dot pw-summary-chip__dot--accepted"></span>
                <div>
                    <div class="pw-summary-chip__val">@acceptedList.Count</div>
                    <div class="pw-summary-chip__lbl">Accepted</div>
                </div>
            </div>
            <div class="pw-summary-chip">
                <span class="pw-summary-chip__dot pw-summary-chip__dot--cancelled"></span>
                <div>
                    <div class="pw-summary-chip__val">@cancelledList.Count</div>
                    <div class="pw-summary-chip__lbl">Cancelled</div>
                </div>
            </div>
            <div class="pw-summary-chip">
                <span class="pw-summary-chip__dot pw-summary-chip__dot--revenue"></span>
                <div>
                    <div class="pw-summary-chip__val">£@totalRevenue.ToString("0.00")</div>
                    <div class="pw-summary-chip__lbl">Revenue</div>
                </div>
            </div>
        </div>

        <!-- Filter tabs -->
        <div class="pw-filter-tabs" role="group" aria-label="Filter orders by status">
            <button class="pw-tab is-active" data-filter="all">All (@orders.Count)</button>
            <button class="pw-tab" data-filter="Pending">Pending (@pendingList.Count)</button>
            <button class="pw-tab" data-filter="Accepted">Accepted (@acceptedList.Count)</button>
            <button class="pw-tab" data-filter="Cancelled">Cancelled (@cancelledList.Count)</button>
        </div>

        <!-- Orders -->
        @if (!orders.Any())
        {
            <div class="pw-empty">
                <i data-lucide="inbox" style="width:48px;height:48px;display:block;margin:0 auto 12px;opacity:.3;" aria-hidden="true"></i>
                <p>No orders yet — they'll appear here once customers start buying.</p>
            </div>
        }
        else
        {
            <div class="pw-orders-grid" id="ordersGrid">
                @foreach (var order in orders)
                {
                    string badgeMod = order.TrackingStatus == "Pending"   ? "pw-badge--pending"
                                    : order.TrackingStatus == "Accepted"  ? "pw-badge--accepted"
                                    : "pw-badge--cancelled";
                    <div class="pw-order-card" data-status="@order.TrackingStatus">
                        <div class="pw-order-card__head">
                            <div>
                                <span class="pw-order-card__id">Order #@order.Orders.OrdersId</span>
                                <span class="pw-order-card__date" style="margin-left:10px;">@order.Orders.OrderDate.ToString("d MMM yyyy")</span>
                            </div>
                            <span class="pw-badge @badgeMod">@order.TrackingStatus</span>
                        </div>
                        <div class="pw-order-card__body">
                            <div class="pw-order-card__products">
                                @foreach (var item in order.OrderProducts)
                                {
                                    <div class="pw-order-card__product-row">
                                        @if (!string.IsNullOrEmpty(item.Products?.ImagePath))
                                        {
                                            <img src="@item.Products.ImagePath" alt="@item.Products?.ItemName" class="pw-order-card__product-img" />
                                        }
                                        else
                                        {
                                            <div class="pw-order-card__product-placeholder">
                                                <i data-lucide="sprout" style="width:14px;height:14px;" aria-hidden="true"></i>
                                            </div>
                                        }
                                        <span style="font-weight:600;">@item.Products?.ItemName</span>
                                        <span style="color:var(--text-muted);font-size:12px;">× @item.ProductQuantity</span>
                                        <span style="margin-left:auto;font-size:12px;color:var(--text-muted);">
                                            £@((item.Products?.ItemPrice * item.ProductQuantity)?.ToString("0.00"))
                                        </span>
                                    </div>
                                }
                            </div>
                            <div class="pw-order-card__side">
                                <div>
                                    <div style="font-size:11px;color:var(--text-muted);text-align:right;margin-bottom:2px;">Your subtotal</div>
                                    <div class="pw-order-card__subtotal">£@order.ProducerSubtotal.ToString("0.00")</div>
                                </div>
                                <div class="pw-order-card__actions">
                                    @if (order.TrackingStatus == "Pending")
                                    {
                                        <form asp-action="AcceptProducerOrder" asp-route-id="@order.ProducerOrdersId" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="pw-btn-accept">
                                                <i data-lucide="check" style="width:13px;height:13px;" aria-hidden="true"></i>
                                                Accept
                                            </button>
                                        </form>
                                        <a asp-action="CancelProducerOrder" asp-route-id="@order.ProducerOrdersId" class="pw-btn-cancel-sm">
                                            <i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>
                                            Cancel
                                        </a>
                                    }
                                    else if (order.TrackingStatus == "Accepted")
                                    {
                                        <a asp-action="CancelProducerOrder" asp-route-id="@order.ProducerOrdersId" class="pw-btn-cancel-sm">
                                            <i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>
                                            Cancel
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="font-size:12px;color:var(--text-light);">No actions</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
    (function () {
        'use strict';
        if (window.lucide) lucide.createIcons();

        /* ── Status filter tabs ───────────────────────────────── */
        var tabs = document.querySelectorAll('.pw-tab');
        var cards = document.querySelectorAll('.pw-order-card');

        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                tabs.forEach(function (t) { t.classList.remove('is-active'); });
                tab.classList.add('is-active');

                var filter = tab.dataset.filter;
                cards.forEach(function (card) {
                    if (filter === 'all' || card.dataset.status === filter) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    }());
    </script>
}
