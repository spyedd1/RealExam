@model GFLHApp.Models.Products
@using System.Linq
@{
    ViewData["Title"] = Model.ItemName;
    ViewData["FullWidth"] = true;

    var otherProducts = (ViewBag.OtherProducts as IEnumerable<GFLHApp.Models.Products>)
                        ?? Enumerable.Empty<GFLHApp.Models.Products>();
    var producerName  = Model.Producers?.ProducerName ?? "Local Farm";
    var producerInfo  = Model.Producers?.ProducerInformation;
    var inStock       = Model.Available && Model.QuantityInStock > 0;
    var isLowStock    = inStock && Model.QuantityInStock <= 5;
}

<style>
/* ── Page header strip ──────────────────────────────────── */
.pw-detail-header {
    background: linear-gradient(160deg, var(--cream) 0%, #f0ebe0 100%);
    padding: 100px 0 36px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(0,0,0,.06);
}

/* floating deco in header */
.pw-detail-header__deco {
    position: absolute;
    pointer-events: none;
    opacity: .08;
    color: var(--green);
}
.pw-detail-header__deco--1 { top: 20%; right: 8%;  animation: float-a 7s ease-in-out infinite; }
.pw-detail-header__deco--2 { top: 50%; left: 5%;   animation: float-b 8s ease-in-out infinite 1s; }
.pw-detail-header__deco--3 { bottom: 30%; right: 20%; animation: float-a 6s ease-in-out infinite .5s; }

/* Breadcrumb */
.pw-breadcrumb {
    display: flex; align-items: center; gap: 6px;
    list-style: none; margin: 0; padding: 0;
    font-size: 13px; font-weight: 500; flex-wrap: wrap;
}
.pw-breadcrumb li { display: flex; align-items: center; gap: 6px; }
.pw-breadcrumb li + li::before { content: '/'; color: var(--text-muted); opacity: .6; }
.pw-breadcrumb a { color: var(--text-muted); transition: color .15s; text-decoration: none; }
.pw-breadcrumb a:hover { color: var(--green); }
.pw-breadcrumb [aria-current] { color: var(--text); font-weight: 600; }

/* ── Main product section ───────────────────────────────── */
.pw-detail-section {
    padding: 56px 0 88px;
    background: var(--cream);
}

.pw-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
}

/* ── Image column ───────────────────────────────────────── */
.pw-detail__img-col {
    position: sticky;
    top: 96px;
}

.pw-detail__img-wrap {
    position: relative;
    padding: 18px 0;
}

.pw-detail__img-card {
    border-radius: var(--r-xl);
    overflow: hidden;
    position: relative;
    box-shadow: var(--shadow-lg), 0 0 0 4px var(--green-200);
    transition: transform .18s ease-out, box-shadow .18s ease-out;
    transform-style: preserve-3d;
    will-change: transform;
    background: linear-gradient(135deg, var(--green-100) 0%, var(--cream-2) 100%);
    aspect-ratio: 1 / 1;
    cursor: crosshair;
}

.pw-detail__img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
}

.pw-detail__img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    padding: 80px;
    min-height: 320px;
}

.pw-detail__sticker {
    position: absolute;
    z-index: 3;
}
.pw-detail__sticker--tl { top: -14px; left: 20px;  transform: rotate(-4deg); }
.pw-detail__sticker--br { bottom: -14px; right: 20px; transform: rotate(3.5deg); }

/* Trust row below image */
.pw-detail__trust {
    display: flex; justify-content: center; gap: 20px;
    margin-top: 28px; flex-wrap: wrap;
}
.pw-detail__trust-item {
    display: flex; align-items: center; gap: 5px;
    font-size: 12px; font-weight: 600; color: var(--text-muted);
}

/* ── Info column ────────────────────────────────────────── */
.pw-detail__info-col { display: flex; flex-direction: column; }

.pw-detail__badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

.pw-detail__name {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.8vw, 50px);
    font-weight: 700;
    letter-spacing: -.03em;
    margin: 0 0 12px;
    line-height: 1.06;
    color: var(--text);
}

.pw-detail__producer-row {
    display: flex; align-items: center; gap: 7px;
    font-size: 14px; font-weight: 500;
    color: var(--text-muted); margin-bottom: 28px;
}
.pw-detail__producer-row strong { color: var(--text); }

/* Price block */
.pw-detail__price-block {
    background: var(--green-100);
    border: 2px solid var(--green-200);
    border-radius: var(--r-lg);
    padding: 16px 22px;
    display: flex; align-items: baseline; gap: 12px;
    margin-bottom: 24px;
}
.pw-detail__price {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: 800;
    color: var(--green);
    line-height: 1;
    letter-spacing: -.03em;
}
.pw-detail__price-label { font-size: 13px; color: var(--text-muted); font-weight: 500; }

/* Description */
.pw-detail__desc {
    font-size: 16px; line-height: 1.75;
    color: var(--text-muted); margin-bottom: 24px;
}

/* Small label above sections */
.pw-detail__label {
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .08em;
    color: var(--text-muted); margin-bottom: 8px;
    display: flex; align-items: center; gap: 4px;
}

/* Stock pill */
.pw-detail__stock {
    display: flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 600;
    margin-bottom: 20px; padding: 10px 18px;
    border-radius: var(--r-full); border: 2px solid;
}
.pw-detail__stock--ok     { background: var(--green-100);  border-color: var(--green-200); color: var(--green-800); }
.pw-detail__stock--low    { background: var(--orange-100); border-color: #FED7AA;          color: #9A3412; }
.pw-detail__stock--out    { background: #FEE2E2;           border-color: #FECACA;          color: #991B1B; }
.pw-detail__stock--unavail { background: #F5F5F4;          border-color: var(--border);    color: var(--text-muted); }

/* Add area */
.pw-detail__add-area {
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--r-lg);
    padding: 20px;
    margin-bottom: 24px;
}
.pw-detail__add-label {
    font-size: 13px; font-weight: 600;
    color: var(--text-muted); margin-bottom: 12px;
    display: flex; align-items: center; gap: 5px;
}
.pw-detail__add-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
}

/* Allergen chips */
.pw-detail__allergens { margin-bottom: 20px; }
.pw-allergen-tag {
    display: inline-flex; align-items: center;
    font-size: 11px; font-weight: 700; padding: 3px 9px;
    background: var(--yellow-100); color: #92400E;
    border-radius: var(--r-full); letter-spacing: .02em; text-transform: uppercase;
}
.pw-detail__allergen-list { display: flex; flex-wrap: wrap; gap: 5px; }

/* Producer info card */
.pw-detail__producer-card {
    background: linear-gradient(135deg, var(--green-100) 0%, #DFF6EA 100%);
    border: 2px solid var(--green-200);
    border-radius: var(--r-lg);
    padding: 20px;
    display: flex; gap: 14px; align-items: flex-start;
    margin-bottom: 20px;
}
.pw-detail__producer-avatar {
    width: 44px; height: 44px; flex-shrink: 0;
    background: var(--green); border-radius: var(--r-full);
    display: flex; align-items: center; justify-content: center;
    color: white;
}
.pw-detail__producer-name {
    font-family: var(--font-display); font-size: 16px;
    font-weight: 700; margin: 0 0 4px; color: var(--text);
}
.pw-detail__producer-bio {
    font-size: 13px; color: var(--text-muted);
    margin: 0 0 8px; line-height: 1.55;
}

/* Admin links */
.pw-detail__admin {
    display: flex; gap: 8px; flex-wrap: wrap;
    padding-top: 16px; border-top: 2px solid var(--border);
}
.pw-detail__admin a {
    font-size: 13px; font-weight: 600;
    padding: 6px 16px; border-radius: var(--r-full);
    border: 2px solid var(--border); color: var(--text-muted); transition: all .15s;
}
.pw-detail__admin a:hover          { border-color: var(--green);  color: var(--green);  background: var(--green-100); }
.pw-detail__admin a.danger:hover   { border-color: #DC2626;       color: #DC2626;       background: #FEF2F2; }

/* ── More from producer section ─────────────────────────── */
.pw-more-section {
    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);
    padding: 80px 0 96px;
    position: relative;
}
.pw-more-section::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px; background: var(--green-200);
}

/* ── Shared qty / AJAX / toast  ──────────────────────────── */
.pw-add-group { display: flex; align-items: center; gap: 6px; }
.pw-qty-control {
    display: flex; align-items: center;
    border: 2px solid var(--border); border-radius: var(--r-full);
    background: var(--cream); overflow: hidden;
}
.pw-qty-btn {
    width: 28px; height: 32px; background: none; border: none;
    font-size: 16px; font-weight: 700; color: var(--text-muted);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background .12s, color .12s;
    padding: 0; line-height: 1; font-family: var(--font-body); flex-shrink: 0;
}
.pw-qty-btn:hover { background: var(--green-100); color: var(--green); }
.pw-qty-btn:focus-visible { outline: 2px solid var(--green); outline-offset: -2px; }
.pw-qty-display {
    font-size: 14px; font-weight: 700; color: var(--text);
    min-width: 26px; text-align: center; user-select: none; padding: 0 2px;
}
.pw-spinner {
    display: inline-block; width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,.4); border-top-color: white;
    border-radius: 50%; animation: pw-spin .6s linear infinite; vertical-align: middle;
}
@@keyframes pw-spin { to { transform: rotate(360deg); } }
.pw-add-toast {
    position: fixed; bottom: 28px; left: 50%;
    transform: translateX(-50%) translateY(14px);
    background: var(--text); color: var(--cream);
    padding: 10px 22px; border-radius: var(--r-full);
    font-size: 14px; font-weight: 600;
    display: flex; align-items: center; gap: 10px;
    z-index: 9998; opacity: 0;
    transition: opacity .22s, transform .22s;
    white-space: nowrap; box-shadow: var(--shadow-lg); pointer-events: none;
}
.pw-add-toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }

/* Related card helpers not in site.css */
.pw-card--out { opacity: .72; }
.pw-card--out .pw-card__photo { filter: grayscale(35%); }
.pw-card__stock { position: absolute; top: 12px; left: 12px; z-index: 1; }
.pw-card__img-placeholder {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--green-100) 0%, var(--cream-2) 100%);
}
.pw-card__cat {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 10px; font-weight: 700; padding: 3px 9px;
    border-radius: var(--r-full); letter-spacing: .04em; text-transform: uppercase;
    background: var(--green-100); color: var(--green-800); margin-bottom: 8px;
}

/* ── Responsive ─────────────────────────────────────────── */
@@media (max-width: 900px) {
    .pw-detail-grid { grid-template-columns: 1fr; gap: 40px; }
    .pw-detail__img-col { position: static; }
}
@@media (max-width: 640px) {
    .pw-detail-header { padding: 88px 0 28px; }
    .pw-detail-section { padding: 36px 0 60px; }
    .pw-detail__price { font-size: 36px; }
    .pw-detail__name  { font-size: 28px; }
}
</style>

@* ── Page header strip ──────────────────────────────────── *@
<div class="pw-detail-header">
    <span class="pw-detail-header__deco pw-detail-header__deco--1" aria-hidden="true">
        <i data-lucide="carrot"   style="width:52px;height:52px;"></i>
    </span>
    <span class="pw-detail-header__deco pw-detail-header__deco--2" aria-hidden="true">
        <i data-lucide="leaf"     style="width:44px;height:44px;"></i>
    </span>
    <span class="pw-detail-header__deco pw-detail-header__deco--3" aria-hidden="true">
        <i data-lucide="sprout"   style="width:36px;height:36px;"></i>
    </span>

    <div class="pw-container">
        <nav aria-label="Breadcrumb">
            <ol class="pw-breadcrumb">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i data-lucide="home" style="width:12px;height:12px;" aria-hidden="true"></i>
                        Home
                    </a>
                </li>
                <li><a asp-controller="Products" asp-action="Index">Shop</a></li>
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <li><span>@Model.Category</span></li>
                }
                <li aria-current="page">@Model.ItemName</li>
            </ol>
        </nav>
    </div>
</div>

@* ── Main product section ────────────────────────────────── *@
<section class="pw-detail-section" aria-label="Product details">
    <div class="pw-container">
        <div class="pw-detail-grid">

            @* ── Image column ─────────────────────────────── *@
            <div class="pw-detail__img-col">
                <div class="pw-detail__img-wrap">

                    @* Top-left sticker *@
                    @if (!Model.Available)
                    {
                        <div class="pw-box-sticker pw-detail__sticker pw-detail__sticker--tl"
                             style="background:#F5F5F4;color:var(--text-muted);" aria-hidden="true">
                            Unavailable
                        </div>
                    }
                    else if (isLowStock)
                    {
                        <div class="pw-box-sticker pw-detail__sticker pw-detail__sticker--tl"
                             style="background:var(--orange);color:white;" aria-hidden="true">
                            <i data-lucide="zap" style="width:11px;height:11px;" aria-hidden="true"></i>
                            Only @Model.QuantityInStock left!
                        </div>
                    }
                    else if (inStock)
                    {
                        <div class="pw-box-sticker pw-detail__sticker pw-detail__sticker--tl"
                             style="background:var(--green);color:white;" aria-hidden="true">
                            <i data-lucide="sparkles" style="width:11px;height:11px;" aria-hidden="true"></i>
                            Fresh Pick
                        </div>
                    }

                    @* Reactive 3D image card *@
                    <div class="pw-detail__img-card" id="detailImgCard" role="img"
                         aria-label="Photo of @Model.ItemName">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img src="@Model.ImagePath" alt="@Model.ItemName" class="pw-detail__img" />
                        }
                        else
                        {
                            <div class="pw-detail__img-placeholder">
                                <i data-lucide="sprout"
                                   style="width:100px;height:100px;color:var(--green);opacity:.3;"
                                   aria-hidden="true"></i>
                            </div>
                        }
                    </div>

                    @* Bottom-right sticker *@
                    @if (!string.IsNullOrEmpty(Model.Category))
                    {
                        <div class="pw-box-sticker pw-detail__sticker pw-detail__sticker--br"
                             style="background:var(--yellow);color:var(--text);" aria-hidden="true">
                            @Model.Category
                        </div>
                    }
                </div>

                @* Trust row *@
                <div class="pw-detail__trust" aria-label="Product credentials">
                    <span class="pw-detail__trust-item">
                        <i data-lucide="leaf"    style="width:13px;height:13px;color:var(--green);" aria-hidden="true"></i>
                        Locally grown
                    </span>
                    <span class="pw-detail__trust-item">
                        <i data-lucide="truck"   style="width:13px;height:13px;" aria-hidden="true"></i>
                        Next-day delivery
                    </span>
                    <span class="pw-detail__trust-item">
                        <i data-lucide="recycle" style="width:13px;height:13px;color:var(--green);" aria-hidden="true"></i>
                        Zero plastic
                    </span>
                </div>
            </div>

            @* ── Info column ──────────────────────────────── *@
            <div class="pw-detail__info-col">

                @* Badges *@
                <div class="pw-detail__badges">
                    @if (!string.IsNullOrEmpty(Model.Category))
                    {
                        <span class="pw-badge pw-badge--green">@Model.Category</span>
                    }
                    @if (!Model.Available)
                    {
                        <span class="pw-badge" style="background:#F5F5F4;color:var(--text-muted);">Unavailable</span>
                    }
                    else if (Model.QuantityInStock == 0)
                    {
                        <span class="pw-badge" style="background:#FEE2E2;color:#991B1B;">Out of Stock</span>
                    }
                    else if (isLowStock)
                    {
                        <span class="pw-badge pw-badge--orange">
                            <i data-lucide="zap" class="pw-icon-sm" aria-hidden="true"></i>
                            Low Stock
                        </span>
                    }
                    else
                    {
                        <span class="pw-badge pw-badge--green">
                            <i data-lucide="circle-check" class="pw-icon-sm" aria-hidden="true"></i>
                            In Stock
                        </span>
                    }
                </div>

                @* Product name *@
                <h1 class="pw-detail__name">@Model.ItemName</h1>

                @* Producer row *@
                <div class="pw-detail__producer-row">
                    <i data-lucide="map-pin" style="width:14px;height:14px;" aria-hidden="true"></i>
                    By <strong>@producerName</strong>
                </div>

                @* Price *@
                <div class="pw-detail__price-block" aria-label="Price £@Model.ItemPrice.ToString("F2")">
                    <span class="pw-detail__price">£@Model.ItemPrice.ToString("F2")</span>
                    <span class="pw-detail__price-label">per unit · inc. VAT</span>
                </div>

                @* Description *@
                <p class="pw-detail__desc">@Model.Description</p>

                @* Allergens *@
                @if (!string.IsNullOrWhiteSpace(Model.Allergens))
                {
                    <div class="pw-detail__allergens">
                        <p class="pw-detail__label">
                            <i data-lucide="triangle-alert" style="width:11px;height:11px;color:#D97706;" aria-hidden="true"></i>
                            Contains allergens
                        </p>
                        <div class="pw-detail__allergen-list" aria-label="Allergens: @Model.Allergens">
                            @foreach (var a in Model.Allergens.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <span class="pw-allergen-tag">@a.Trim()</span>
                            }
                        </div>
                    </div>
                }

                @* Stock status pill *@
                @{
                    var stockClass = !Model.Available              ? "pw-detail__stock--unavail"
                                   : Model.QuantityInStock == 0   ? "pw-detail__stock--out"
                                   : isLowStock                   ? "pw-detail__stock--low"
                                                                  : "pw-detail__stock--ok";
                }
                <div class="pw-detail__stock @stockClass" role="status">
                    @if (!Model.Available)
                    {
                        <i data-lucide="circle-x"     style="width:15px;height:15px;" aria-hidden="true"></i>
                        <span>Currently unavailable from this producer</span>
                    }
                    else if (Model.QuantityInStock == 0)
                    {
                        <i data-lucide="circle-x"     style="width:15px;height:15px;" aria-hidden="true"></i>
                        <span>Out of stock — check back soon</span>
                    }
                    else if (isLowStock)
                    {
                        <i data-lucide="zap"          style="width:15px;height:15px;" aria-hidden="true"></i>
                        <span>Only <strong>@Model.QuantityInStock</strong> left — order soon!</span>
                    }
                    else
                    {
                        <i data-lucide="circle-check" style="width:15px;height:15px;" aria-hidden="true"></i>
                        <span><strong>@Model.QuantityInStock</strong> in stock and ready to go</span>
                    }
                </div>

                @* Add to basket *@
                <div class="pw-detail__add-area">
                    <p class="pw-detail__add-label">
                        <i data-lucide="shopping-basket" style="width:13px;height:13px;" aria-hidden="true"></i>
                        Add to your basket
                    </p>
                    @if (inStock)
                    {
                        <div class="pw-detail__add-row">
                            <div class="pw-qty-control" role="group" aria-label="Quantity">
                                <button type="button" class="pw-qty-btn pw-qty-dec" aria-label="Decrease quantity">−</button>
                                <span class="pw-qty-display" aria-live="polite" aria-atomic="true">1</span>
                                <button type="button" class="pw-qty-btn pw-qty-inc" aria-label="Increase quantity">+</button>
                            </div>
                            <form class="pw-add-form" asp-controller="BasketProducts" asp-action="AddAjax"
                                  method="post" style="margin:0;flex:1;">
                                <input type="hidden" name="ProductsId" value="@Model.ProductsId" />
                                <input type="hidden" name="Quantity"   class="pw-qty-value" value="1" />
                                <button type="submit" class="pw-btn pw-btn--primary pw-btn--lg pw-add-btn"
                                        style="width:100%;" aria-label="Add @Model.ItemName to basket">
                                    <i data-lucide="plus" style="width:16px;height:16px;" aria-hidden="true"></i>
                                    Add to Basket
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <button type="button" class="pw-btn pw-btn--lg"
                                style="background:var(--cream-2);color:var(--text-muted);cursor:not-allowed;width:100%;"
                                disabled aria-disabled="true">
                            @(!Model.Available ? "Unavailable" : "Out of Stock")
                        </button>
                    }
                </div>

                @* Producer info card *@
                <div class="pw-detail__producer-card" aria-label="About the producer">
                    <div class="pw-detail__producer-avatar" aria-hidden="true">
                        <i data-lucide="sprout" style="width:20px;height:20px;"></i>
                    </div>
                    <div>
                        <p class="pw-detail__producer-name">@producerName</p>
                        @if (!string.IsNullOrWhiteSpace(producerInfo))
                        {
                            <p class="pw-detail__producer-bio">
                                @(producerInfo.Length > 150 ? producerInfo.Substring(0, 150) + "…" : producerInfo)
                            </p>
                        }
                        <a class="pw-link" asp-controller="Producers" asp-action="Index"
                           style="font-size:13px;">
                            See all their products →
                        </a>
                    </div>
                </div>

                @* Admin links (producer only) *@
                @if (User.IsInRole("Producer"))
                {
                    <div class="pw-detail__admin">
                        <a asp-action="Edit"   asp-route-id="@Model.ProductsId" aria-label="Edit @Model.ItemName">
                            <i data-lucide="pencil"   style="width:13px;height:13px;vertical-align:middle;" aria-hidden="true"></i>
                            Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.ProductsId" class="danger"
                           aria-label="Delete @Model.ItemName">
                            <i data-lucide="trash-2"  style="width:13px;height:13px;vertical-align:middle;" aria-hidden="true"></i>
                            Delete
                        </a>
                        <a asp-action="Index" style="margin-left:auto;">← Back to my products</a>
                    </div>
                }
                else
                {
                    <div style="margin-top:16px;">
                        <a class="pw-link" asp-action="Index" style="font-size:14px;">← Back to shop</a>
                    </div>
                }

            </div>
        </div>
    </div>
</section>

@* ── More from this producer ────────────────────────────── *@
@{
    var otherList = otherProducts.ToList();
}
@if (otherList.Any())
{
    <section class="pw-more-section" aria-labelledby="more-heading">
        <div class="pw-container">

            <div class="pw-section__header reveal reveal--blur">
                <span class="pw-section__eyebrow">
                    <i data-lucide="sprout" class="pw-icon-sm" aria-hidden="true"></i>
                    From the same farm
                </span>
                <h2 class="pw-section__title" id="more-heading">
                    More from <em class="pw-text--green">@producerName</em>
                </h2>
                <p class="pw-section__subtitle">
                    Hand-grown by the same people, with the same love and care.
                </p>
            </div>

            <div class="pw-grid pw-grid--3">
                @foreach (var other in otherList)
                {
                    var otherInStock  = other.Available && other.QuantityInStock > 0;
                    var otherLowStock = otherInStock && other.QuantityInStock <= 5;
                    var otherCardMod  = (!other.Available || other.QuantityInStock == 0) ? "pw-card--out" : "";
                    var otherProd     = other.Producers?.ProducerName ?? "Local Farm";

                    <article class="pw-card pw-card--product reveal reveal--pop @otherCardMod"
                             data-product-card
                             aria-label="@other.ItemName, £@other.ItemPrice.ToString("F2")">

                        <div class="pw-card__stock" aria-hidden="true">
                            @if (!other.Available)
                            {
                                <span class="pw-badge" style="background:#F5F5F4;color:var(--text-muted);">Unavailable</span>
                            }
                            else if (other.QuantityInStock == 0)
                            {
                                <span class="pw-badge" style="background:#FEE2E2;color:#991B1B;">Out of Stock</span>
                            }
                            else if (otherLowStock)
                            {
                                <span class="pw-badge pw-badge--orange">
                                    <i data-lucide="zap" class="pw-icon-sm" aria-hidden="true"></i>
                                    Only @other.QuantityInStock left
                                </span>
                            }
                            else
                            {
                                <span class="pw-badge pw-badge--green">
                                    <i data-lucide="circle-check" class="pw-icon-sm" aria-hidden="true"></i>
                                    In Stock
                                </span>
                            }
                        </div>

                        <div class="pw-card__img-wrap" aria-hidden="true">
                            @if (!string.IsNullOrEmpty(other.ImagePath))
                            {
                                <img src="@other.ImagePath" alt="" class="pw-card__photo" loading="lazy" />
                            }
                            else
                            {
                                <div class="pw-card__img-placeholder">
                                    <i data-lucide="sprout"
                                       style="width:52px;height:52px;color:var(--green);opacity:.35;"
                                       aria-hidden="true"></i>
                                </div>
                            }
                        </div>

                        <div class="pw-card__body">
                            <p class="pw-card__farm">
                                <i data-lucide="map-pin"
                                   style="width:10px;height:10px;vertical-align:middle;margin-right:2px;"
                                   aria-hidden="true"></i>
                                @otherProd
                            </p>
                            <span class="pw-card__cat">@other.Category</span>
                            <h3 class="pw-card__name">@other.ItemName</h3>
                            <p class="pw-card__desc"
                               style="-webkit-line-clamp:2;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;">
                                @other.Description
                            </p>

                            <div class="pw-card__footer">
                                <span class="pw-card__price">£@other.ItemPrice.ToString("F2")</span>
                                @if (!other.Available)
                                {
                                    <button type="button" class="pw-btn pw-btn--sm"
                                            style="background:var(--cream-2);color:var(--text-muted);cursor:not-allowed;"
                                            disabled aria-disabled="true">Unavailable</button>
                                }
                                else if (otherInStock)
                                {
                                    <div class="pw-add-group">
                                        <div class="pw-qty-control" role="group" aria-label="Quantity">
                                            <button type="button" class="pw-qty-btn pw-qty-dec" aria-label="Decrease">−</button>
                                            <span class="pw-qty-display">1</span>
                                            <button type="button" class="pw-qty-btn pw-qty-inc" aria-label="Increase">+</button>
                                        </div>
                                        <form class="pw-add-form" asp-controller="BasketProducts"
                                              asp-action="AddAjax" method="post" style="margin:0;">
                                            <input type="hidden" name="ProductsId" value="@other.ProductsId" />
                                            <input type="hidden" name="Quantity"   class="pw-qty-value" value="1" />
                                            <button type="submit"
                                                    class="pw-btn pw-btn--sm pw-btn--primary pw-add-btn"
                                                    aria-label="Add @other.ItemName to basket">
                                                <i data-lucide="plus" style="width:13px;height:13px;" aria-hidden="true"></i>
                                                Add
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <button type="button" class="pw-btn pw-btn--sm"
                                            style="background:var(--cream-2);color:var(--text-muted);cursor:not-allowed;"
                                            disabled aria-disabled="true">Out of Stock</button>
                                }
                            </div>

                            <div style="margin-top:8px;">
                                <a class="pw-link" asp-action="Details" asp-route-id="@other.ProductsId"
                                   style="font-size:13px;" aria-label="View details for @other.ItemName">
                                    View details →
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="pw-section__cta reveal" data-delay="200">
                <a class="pw-btn pw-btn--outline pw-btn--lg" asp-action="Index">
                    See all products →
                </a>
            </div>

        </div>
    </section>
}

@section Scripts {
<script>
(function () {
    'use strict';

    /* ── Reactive 3D image tilt ─────────────────────────── */
    (function () {
        var card = document.getElementById('detailImgCard');
        if (!card) return;
        var ticking = false;
        var lastE;

        card.addEventListener('mousemove', function (e) {
            lastE = e;
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(function () {
                var r  = card.getBoundingClientRect();
                var x  = ((lastE.clientX - r.left) / r.width  - 0.5) * 2;
                var y  = ((lastE.clientY - r.top)  / r.height - 0.5) * 2;
                card.style.transform =
                    'perspective(900px) rotateY(' + (x * 13) + 'deg) rotateX(' + (-y * 11) + 'deg) scale(1.03)';
                card.style.boxShadow =
                    '0 32px 72px rgba(0,0,0,.2), 0 0 0 4px var(--green-200)';
                ticking = false;
            });
        }, { passive: true });

        card.addEventListener('mouseleave', function () {
            card.style.transform = '';
            card.style.boxShadow = '';
        });
    }());

    /* ── Quantity +/− controls ──────────────────────────── */
    document.querySelectorAll('.pw-qty-control').forEach(function (ctrl) {
        var dec     = ctrl.querySelector('.pw-qty-dec');
        var inc     = ctrl.querySelector('.pw-qty-inc');
        var display = ctrl.querySelector('.pw-qty-display');
        var parent  = ctrl.closest('.pw-add-group') || ctrl.closest('.pw-detail__add-row');
        var hidden  = parent ? parent.querySelector('.pw-qty-value') : null;

        function getQty() { return parseInt(display.textContent) || 1; }
        function setQty(n) {
            n = Math.max(1, Math.min(99, n));
            display.textContent = n;
            if (hidden) hidden.value = n;
        }
        if (dec) dec.addEventListener('click', function () { setQty(getQty() - 1); });
        if (inc) inc.addEventListener('click', function () { setQty(getQty() + 1); });
    });

    /* ── Particle burst ─────────────────────────────────── */
    function burstParticles(el) {
        var colors = ['#16A34A','#F59E0B','#F97316','#EC4899','#8B5CF6','#4ADE80','#FEF08A','#FB923C'];
        var r  = el.getBoundingClientRect();
        var cx = r.left + r.width / 2;
        var cy = r.top  + r.height / 2;
        for (var i = 0; i < 18; i++) {
            (function (i) {
                setTimeout(function () {
                    var p     = document.createElement('div');
                    var size  = 5 + Math.random() * 11;
                    var angle = Math.random() * Math.PI * 2;
                    var speed = 55 + Math.random() * 130;
                    var dx    = Math.cos(angle) * speed;
                    var dy    = Math.sin(angle) * speed - 60;
                    p.style.cssText =
                        'position:fixed;border-radius:50%;pointer-events:none;z-index:9999;' +
                        'left:'   + (cx - size / 2) + 'px;top:' + (cy - size / 2) + 'px;' +
                        'width:'  + size + 'px;height:' + size + 'px;' +
                        'background:' + colors[Math.floor(Math.random() * colors.length)] + ';';
                    document.body.appendChild(p);
                    p.animate(
                        [{ transform: 'translate(0,0) scale(1)', opacity: 1 },
                         { transform: 'translate(' + dx + 'px,' + dy + 'px) scale(0)', opacity: 0 }],
                        { duration: 550 + Math.random() * 350, easing: 'ease-out', fill: 'forwards' }
                    ).onfinish = function () { p.remove(); };
                }, i * 22);
            }(i));
        }
    }

    /* ── Toast ──────────────────────────────────────────── */
    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function showAddToast(msg) {
        var t = document.createElement('div');
        t.className = 'pw-add-toast';
        t.setAttribute('role', 'status');
        t.setAttribute('aria-live', 'polite');
        t.innerHTML = '🛒 ' + msg;
        document.body.appendChild(t);
        requestAnimationFrame(function () {
            requestAnimationFrame(function () { t.classList.add('is-visible'); });
        });
        setTimeout(function () {
            t.classList.remove('is-visible');
            setTimeout(function () { t.remove(); }, 350);
        }, 2800);
    }

    /* ── AJAX add to basket ─────────────────────────────── */
    document.querySelectorAll('.pw-add-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();

            var btn      = form.querySelector('.pw-add-btn');
            var qtyInput = form.querySelector('.pw-qty-value');
            var qty      = parseInt(qtyInput ? qtyInput.value : '1') || 1;
            var tokenEl  = form.querySelector('[name="__RequestVerificationToken"]');
            var token    = tokenEl ? tokenEl.value : '';
            var origHTML = btn.innerHTML;

            btn.disabled  = true;
            btn.innerHTML = '<span class="pw-spinner"></span>';

            fetch(form.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: new URLSearchParams({
                    ProductsId: form.querySelector('[name="ProductsId"]').value,
                    Quantity:   qty,
                    __RequestVerificationToken: token
                })
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    btn.innerHTML        = '✓';
                    btn.style.background = 'var(--green-700)';

                    if (window.updateBasketBadge) window.updateBasketBadge(data.basketCount);
                    burstParticles(btn);
                    showAddToast(
                        (qty > 1 ? '<strong>' + qty + '×</strong> ' : '') +
                        escHtml(data.itemName) + ' added to basket!'
                    );

                    setTimeout(function () {
                        btn.disabled         = false;
                        btn.innerHTML        = origHTML;
                        btn.style.background = '';
                    }, 1800);
                } else {
                    btn.disabled         = false;
                    btn.innerHTML        = origHTML;
                    btn.style.background = '#DC2626';
                    showAddToast(escHtml(data.message || 'Could not add to basket.'));
                    setTimeout(function () { btn.style.background = ''; }, 1800);
                }
            })
            .catch(function () {
                btn.disabled  = false;
                btn.innerHTML = origHTML;
                showAddToast('Something went wrong — please try again.');
            });
        });
    });

}());
</script>
}
