@model IEnumerable<GFLHApp.Models.OrderProducts>
@{
    ViewData["Title"] = "Order Details";
    var firstItem = Model.FirstOrDefault();
}

<h1>Order Details</h1>

@if (firstItem != null)
{
    <div style="max-width:800px; margin:auto;">

        <h2>Order Information</h2>
        <hr />

        <table border="1" cellpadding="12" cellspacing="0" width="350">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th align="left">Field</th>
                    <th align="left">Details</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Order ID</strong></td>
                    <td>@firstItem.Orders.OrdersId</td>
                </tr>
                <tr>
                    <td><strong>Order Date</strong></td>
                    <td>@firstItem.Orders.OrderDate</td>
                </tr>
                <tr>
                    <td><strong>Status</strong></td>
                    <td>@firstItem.Orders.TrackingStatus</td>
                </tr>
                <tr>
                    <td><strong>Subtotal</strong></td>
                    <td>£@firstItem.Orders.OrdersTotal.ToString("0.00")</td>
                </tr>
            </tbody>
        </table>

        <br />

        @if (firstItem.Orders.Delivery)
        {
            <h2>Delivery</h2>
            <hr />

            <table border="1" cellpadding="12" cellspacing="0" width="350">
                <thead bgcolor="#333" style="color:white;">
                    <tr>
                        <th align="left">Field</th>
                        <th align="left">Details</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Order Method</strong></td>
                        <td>Delivery</td>
                    </tr>
                    <tr>
                        <td><strong>Delivery Type</strong></td>
                        <td>@firstItem.Orders.DeliveryMethod</td>
                    </tr>
                </tbody>
            </table>

            <br />
        }

        @if (firstItem.Orders.Collection)
        {
            <h2>Collection</h2>
            <hr />

            <table border="1" cellpadding="12" cellspacing="0" width="350">
                <thead bgcolor="#333" style="color:white;">
                    <tr>
                        <th align="left">Field</th>
                        <th align="left">Details</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Order Method</strong></td>
                        <td>Collection</td>
                    </tr>
                    <tr>
                        <td><strong>Collection Date</strong></td>
                        <td>@firstItem.Orders.DateOfCollection?.ToString("d")</td>
                    </tr>
                </tbody>
            </table>
        }

        <br />

        <h2>Ordered Items</h2>
        <hr />

        <table border="1" cellpadding="12" cellspacing="0" width="100%">
            <thead bgcolor="#333" style="color:white;">
                <tr>
                    <th align="left">Product</th>
                    <th align="left">Quantity</th>
                    <th align="left">Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Products.ItemName</td>
                        <td>@item.ProductQuantity</td>
                        <td>£@item.Products.ItemPrice.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>No order details found.</p>
}