@model IEnumerable<GFLHApp.Models.Producers>
@using System.Linq
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Producers";
    ViewData["AdminSection"] = "producers";
    string search = ViewBag.Search ?? "";
}

<style>
.adm-filters { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; align-items: flex-end; }
.adm-filter-group { display: flex; flex-direction: column; gap: 4px; }
.adm-filter-group label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); }
.adm-filter-input { height: 38px; padding: 0 12px; font-family: var(--font-body); font-size: 13px; font-weight: 500; color: var(--text); background: #fff; border: 1.5px solid var(--border); border-radius: var(--r-sm); outline: none; transition: border-color .15s; }
.adm-filter-input:focus { border-color: var(--green); box-shadow: 0 0 0 3px var(--green-100); }
.adm-btn-filter { height: 38px; padding: 0 16px; background: var(--green); color: #fff; border: none; border-radius: var(--r-sm); font-size: 13px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
.adm-btn-filter:hover { background: var(--green-700); }
.adm-btn-clear { height: 38px; padding: 0 14px; background: transparent; color: var(--text-muted); border: 1.5px solid var(--border); border-radius: var(--r-sm); font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
.adm-btn-clear:hover { border-color: var(--text-muted); color: var(--text); }

.adm-card { background: #fff; border: 1.5px solid var(--border); border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
.adm-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.adm-table th { padding: 9px 14px; text-align: left; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); border-bottom: 1.5px solid var(--border); background: var(--cream); }
.adm-table td { padding: 11px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; }
.adm-table tr:last-child td { border-bottom: none; }
.adm-table tr:hover td { background: #fafaf9; }
.adm-badge { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: var(--r-full); font-size: 11px; font-weight: 700; }
.adm-badge--ok  { background: var(--green-100); color: var(--green); }
.adm-badge--off { background: #f3f4f6; color: var(--text-muted); }
.adm-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--green-100); color: var(--green);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 800; flex-shrink: 0;
}
.adm-tbl-btn { height: 28px; padding: 0 10px; border-radius: var(--r-sm); font-size: 11px; font-weight: 700; cursor: pointer; border: 1.5px solid var(--border); background: transparent; color: var(--text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: all .1s; }
.adm-tbl-btn:hover { border-color: var(--green); color: var(--green); background: var(--green-100); }
.adm-results-info { font-size: 13px; color: var(--text-muted); padding: 12px 18px; border-bottom: 1px solid var(--border); background: var(--cream); }
</style>

<form method="get" action="/AdminDashboard/Producers">
    <div class="adm-filters">
        <div class="adm-filter-group">
            <label>Search</label>
            <input name="search" class="adm-filter-input" value="@search" placeholder="Name or email…" style="width:260px;" />
        </div>
        <button type="submit" class="adm-btn-filter"><i data-lucide="search" style="width:13px;height:13px;" aria-hidden="true"></i>Search</button>
        <button asp-controller="Producers" asp-action="Create" class="adm-btn-filter"><i  style="width:13px;height:13px;" aria-hidden="true"></i>Create Producer</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a href="/AdminDashboard/Producers" class="adm-btn-clear"><i data-lucide="x" style="width:13px;height:13px;" aria-hidden="true"></i>Clear</a>
        }
    </div>
</form>

<div class="adm-card">
    <div class="adm-results-info">@Model.Count() producer@(Model.Count() == 1 ? "" : "s") found</div>

    @if (Model.Any())
    {
        <div style="overflow-x:auto;">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Producer</th>
                        <th>Email</th>
                        <th>VAT</th>
                        <th>Products</th>
                        <th>Total orders</th>
                        <th>Revenue</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model)
                {
                    int    prodCount  = p.Products?.Count ?? 0;
                    int    orderCount = p.ProducerOrders?.Count ?? 0;
                    decimal revenue   = p.ProducerOrders?.Where(o => o.TrackingStatus == "Accepted").Sum(o => o.ProducerSubtotal) ?? 0m;
                    <tr>
                        <td style="padding:8px 8px 8px 14px;">
                            <div class="adm-avatar">@(p.ProducerName?.Substring(0,1).ToUpper() ?? "?")</div>
                        </td>
                        <td>
                            <div style="font-weight:700;">@p.ProducerName</div>
                            @if (!string.IsNullOrEmpty(p.ProducerInformation))
                            { <div style="font-size:11px;color:var(--text-muted);max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.ProducerInformation</div> }
                        </td>
                        <td style="color:var(--text-muted);">@p.ProducerEmail</td>
                        <td>
                            @if (p.IsVATRegistered)
                            { <span class="adm-badge adm-badge--ok">VAT reg</span>
                              if (!string.IsNullOrEmpty(p.VATNumber))
                              { <div style="font-size:10px;color:var(--text-light);margin-top:2px;">@p.VATNumber</div> }
                            }
                            else { <span class="adm-badge adm-badge--off">No VAT</span> }
                        </td>
                        <td style="font-weight:600;">@prodCount</td>
                        <td style="font-weight:600;">@orderCount</td>
                        <td style="font-weight:700;color:var(--green);">£@revenue.ToString("0.00")</td>
                        <td>
                            <div style="display:flex;gap:5px;">
                                <a href="/Producers/Details/@p.ProducersId" class="adm-tbl-btn">View</a>
                                <a href="/Producers/Edit/@p.ProducersId" class="adm-tbl-btn"><i data-lucide="pencil" style="width:11px;height:11px;" aria-hidden="true"></i>Edit</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div style="padding:48px;text-align:center;color:var(--text-muted);">
            <i data-lucide="sprout" style="width:40px;height:40px;display:block;margin:0 auto 10px;opacity:.3;" aria-hidden="true"></i>
            <p style="font-size:14px;margin:0;">No producers found.</p>
        </div>
    }
</div>

@section Scripts { <script>if (window.lucide) lucide.createIcons();</script> }
