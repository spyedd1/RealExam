@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Account";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<span class="pw-manage-content__eyebrow">Privacy · Danger Zone</span>
<h2 class="pw-manage-content__title">Delete Your Account</h2>
<p class="pw-manage-content__sub">This will permanently remove all your personal data. This action cannot be undone.</p>

<div class="pw-manage-alert pw-manage-alert--danger" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div><strong>Deleting your account is permanent.</strong> Your profile, orders, and all associated data will be gone forever. Consider downloading your data first.</div>
</div>

<div class="pw-danger-zone" style="max-width:480px;">
    <h3 class="pw-danger-zone__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        Confirm deletion
    </h3>
    <p class="pw-danger-zone__desc">Once deleted, your Greenfield account and all data are gone permanently with no recovery option.</p>

    <form id="delete-user" method="post" class="pw-manage-form">
        <div asp-validation-summary="ModelOnly" class="pw-manage-alert pw-manage-alert--danger" role="alert"></div>
        @if (Model.RequirePassword)
        {
            <div class="form-floating mb-4">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Your current password" />
                <label asp-for="Input.Password">Confirm with your password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
        }
        <button class="pw-btn pw-btn--danger pw-btn--md" type="submit" style="width:100%;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            Delete my account permanently
        </button>
    </form>
</div>

<div style="margin-top:20px;">
    <a asp-page="./PersonalData" class="pw-btn pw-btn--ghost pw-btn--sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Cancel
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
