@page
@model ResetAuthenticatorModel
@{
    ViewData["Title"] = "Reset Authenticator Key";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<span class="pw-manage-content__eyebrow">Security · Two-Factor Auth</span>
<h2 class="pw-manage-content__title">Reset Authenticator Key</h2>
<p class="pw-manage-content__sub">Generate a new secret key for your authenticator app.</p>

<div class="pw-manage-alert pw-manage-alert--warning" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div>
        <strong>Your authenticator app will stop working immediately after resetting.</strong><br>
        2FA will be disabled until you reconfigure your authenticator with the new key. If you don't complete setup, you may lose access to your account.
    </div>
</div>

<div class="pw-danger-zone">
    <h3 class="pw-danger-zone__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
        Confirm reset
    </h3>
    <p class="pw-danger-zone__desc">After resetting, you'll need to re-scan the QR code and re-verify your authenticator app before 2FA is active again.</p>
    <form id="reset-authenticator-form" method="post">
        <button id="reset-authenticator-button" class="pw-btn pw-btn--danger pw-btn--md" type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
            Reset authenticator key
        </button>
    </form>
</div>
