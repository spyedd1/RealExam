@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
    ViewData["FullWidth"] = true;
}

<div class="pw-auth-page">
    <div class="pw-auth-blob pw-auth-blob--1" style="background:var(--orange);opacity:.12"></div>
    <div class="pw-auth-blob pw-auth-blob--2"></div>

    <div class="pw-auth-card">
        <div class="pw-auth-card__header" style="background:linear-gradient(135deg,#1c1917 0%,#292524 50%,#1c1917 100%)">
            <div class="pw-auth-card__brand">
                <i data-lucide="sprout" style="width:18px;height:18px;stroke-width:2.5"></i>
                Greenfield
            </div>
            <h1 class="pw-auth-card__title">Access denied</h1>
            <p class="pw-auth-card__subtitle">You don't have permission to view this page</p>
        </div>

        <div class="pw-auth-card__body">
            <div class="pw-auth-status">
                <div class="pw-auth-status__icon pw-auth-status__icon--warning">
                    <i data-lucide="shield-alert" style="width:34px;height:34px;stroke-width:1.75"></i>
                </div>
                <p class="pw-auth-status__title">Restricted area</p>
                <p class="pw-auth-status__body">
                    You don't have the required permissions to access this resource.
                    If you think this is a mistake, please contact support.
                    Please ensure you are logged in to an account to make use of the system.
                </p>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="pw-btn pw-btn--primary pw-btn--md" style="width:100%;justify-content:center;">
                    <i data-lucide="home" style="width:16px;height:16px;stroke-width:2.5"></i>
                    Back to home
                </a>
            </div>
        </div>
    </div>
</div>
