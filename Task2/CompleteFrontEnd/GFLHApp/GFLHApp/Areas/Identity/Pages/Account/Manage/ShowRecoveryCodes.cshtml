@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

<partial name="_StatusMessage" for="StatusMessage" />

<span class="pw-manage-content__eyebrow">Security · Two-Factor Auth</span>
<h2 class="pw-manage-content__title">Your Recovery Codes</h2>
<p class="pw-manage-content__sub">Each code can be used once to sign in if you lose access to your authenticator app.</p>

<div class="pw-manage-alert pw-manage-alert--warning" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div><strong>Save these codes somewhere safe.</strong> They won't be shown again. If you lose your device without these codes, you will lose access to your account.</div>
</div>

<div class="pw-recovery-grid" role="list" aria-label="Recovery codes">
    @foreach (var code in Model.RecoveryCodes)
    {
        <code class="pw-recovery-code" role="listitem">@code</code>
    }
</div>

<div style="margin-top:24px;">
    <a asp-page="./TwoFactorAuthentication" class="pw-btn pw-btn--ghost pw-btn--sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Back to 2FA settings
    </a>
</div>
