@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Check your email";
    ViewData["FullWidth"] = true;
}

<div class="pw-auth-page">
    <div class="pw-auth-blob pw-auth-blob--1"></div>
    <div class="pw-auth-blob pw-auth-blob--2"></div>

    <div class="pw-auth-card">
        <div class="pw-auth-card__header">
            <div class="pw-auth-card__brand">
                <i data-lucide="sprout" style="width:18px;height:18px;stroke-width:2.5"></i>
                Greenfield
            </div>
            <h1 class="pw-auth-card__title">Email on its way</h1>
            <p class="pw-auth-card__subtitle">Password reset instructions sent</p>
        </div>

        <div class="pw-auth-card__body">
            <div class="pw-auth-status">
                <div class="pw-auth-status__icon pw-auth-status__icon--success">
                    <i data-lucide="mail-check" style="width:34px;height:34px;stroke-width:1.75"></i>
                </div>
                <p class="pw-auth-status__title">Check your inbox</p>
                <p class="pw-auth-status__body">
                    We've sent password reset instructions to your email address.
                    The link will expire in 24 hours — check your spam folder if you don't see it.
                </p>
                <a asp-page="./Login" class="pw-btn pw-btn--primary pw-btn--md" style="width:100%;justify-content:center;">
                    <i data-lucide="arrow-left" style="width:16px;height:16px;stroke-width:2.5"></i>
                    Back to sign in
                </a>
            </div>
        </div>

        <div class="pw-auth-card__footer">
            <div class="pw-auth-link-row">
                <span>Didn't receive it?</span>
                <a asp-page="./ForgotPassword">Try again</a>
            </div>
        </div>
    </div>
</div>
