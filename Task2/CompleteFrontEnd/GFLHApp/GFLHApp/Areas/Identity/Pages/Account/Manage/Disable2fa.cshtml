@page
@model Disable2faModel
@{
    ViewData["Title"] = "Disable 2FA";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<span class="pw-manage-content__eyebrow">Security · Two-Factor Auth</span>
<h2 class="pw-manage-content__title">Disable Two-Factor Authentication</h2>
<p class="pw-manage-content__sub">You're about to turn off the extra security layer on your account.</p>

<div class="pw-manage-alert pw-manage-alert--warning" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div>
        <strong>This only disables 2FA — it does not change your authenticator app keys.</strong><br>
        If you also want to change the key used in your authenticator app, you'll need to
        <a asp-page="./ResetAuthenticator" class="pw-link" style="font-size:inherit;">reset your authenticator keys</a> separately.
    </div>
</div>

<div class="pw-danger-zone">
    <h3 class="pw-danger-zone__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Confirm action
    </h3>
    <p class="pw-danger-zone__desc">Your account will be less secure without two-factor authentication.</p>
    <form method="post">
        <button class="pw-btn pw-btn--danger pw-btn--md" type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9.09" y1="9" x2="14.91" y2="9"/><line x1="12" y1="12" x2="12" y2="15"/></svg>
            Disable 2FA
        </button>
    </form>
</div>
