@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    ViewData["FullWidth"] = true;
}

<div class="pw-auth-page">
    <div class="pw-auth-blob pw-auth-blob--1"></div>
    <div class="pw-auth-blob pw-auth-blob--2"></div>

    <div class="pw-auth-card">
        <div class="pw-auth-card__header">
            <div class="pw-auth-card__brand">
                <i data-lucide="sprout" style="width:18px;height:18px;stroke-width:2.5"></i>
                Greenfield
            </div>
            <h1 class="pw-auth-card__title">Choose a new password</h1>
            <p class="pw-auth-card__subtitle">Pick something strong and memorable</p>
        </div>

        <div class="pw-auth-card__body">
            <form method="post" class="pw-auth-form">
                <div asp-validation-summary="ModelOnly" class="pw-auth-errors" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                    <label asp-for="Input.Email">Email address</label>
                    <span asp-validation-for="Input.Email" class="pw-auth-field-error"></span>
                </div>

                <div class="form-floating mb-3 pw-auth-input-wrap">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="New password" id="resetPw" style="padding-right:48px" />
                    <label asp-for="Input.Password">New password</label>
                    <button type="button" class="pw-auth-eye" aria-label="Toggle password visibility" onclick="togglePw('resetPw',this)">
                        <i data-lucide="eye" style="width:17px;height:17px;stroke-width:2"></i>
                    </button>
                    <span asp-validation-for="Input.Password" class="pw-auth-field-error"></span>
                </div>

                <div class="form-floating mb-4 pw-auth-input-wrap">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm password" id="resetPwConfirm" style="padding-right:48px" />
                    <label asp-for="Input.ConfirmPassword">Confirm new password</label>
                    <button type="button" class="pw-auth-eye" aria-label="Toggle password visibility" onclick="togglePw('resetPwConfirm',this)">
                        <i data-lucide="eye" style="width:17px;height:17px;stroke-width:2"></i>
                    </button>
                    <span asp-validation-for="Input.ConfirmPassword" class="pw-auth-field-error"></span>
                </div>

                <button type="submit" class="pw-btn pw-btn--primary pw-btn--lg pw-auth-submit">
                    <i data-lucide="lock" style="width:17px;height:17px;stroke-width:2.5"></i>
                    Reset password
                </button>
            </form>
        </div>

        <div class="pw-auth-card__footer">
            <div class="pw-auth-link-row">
                <a asp-page="./Login">
                    <i data-lucide="arrow-left" style="width:14px;height:14px;stroke-width:2.5;vertical-align:middle;margin-right:4px"></i>
                    Back to sign in
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePw(id, btn) {
            const input = document.getElementById(id);
            const isText = input.type === 'text';
            input.type = isText ? 'password' : 'text';
            btn.innerHTML = isText
                ? '<i data-lucide="eye" style="width:17px;height:17px;stroke-width:2"></i>'
                : '<i data-lucide="eye-off" style="width:17px;height:17px;stroke-width:2"></i>';
            lucide.createIcons();
        }
    </script>
}
